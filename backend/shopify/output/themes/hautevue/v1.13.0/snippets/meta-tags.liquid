<meta property="og:site_name" content="{{ shop.name }}">
<meta property="og:url" content="{{ canonical_url }}">
<meta property="og:title" content="{{ page_title | escape }}">
<meta property="og:type" content="website">
<meta property="og:description" content="{{ page_description | default: shop.description | escape }}">

{%- if request.page_type == 'product' -%}
  <meta property="og:type" content="product">
  <meta property="og:price:amount" content="{{ product.selected_or_first_available_variant.price | money_without_currency }}">
  <meta property="og:price:currency" content="{{ cart.currency.iso_code }}">
{%- endif -%}

{%- assign og_image = og_image_url | default: page.image | default: product.featured_image | default: collection.image -%}
{%- if og_image -%}
  <meta property="og:image" content="{{ og_image | image_url: width: 1200 }}">
  <meta property="og:image:secure_url" content="{{ og_image | image_url: width: 1200 }}">
  <meta property="og:image:width" content="1200">
{%- endif -%}

<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ page_title | escape }}">
<meta name="twitter:description" content="{{ page_description | default: shop.description | escape }}">
