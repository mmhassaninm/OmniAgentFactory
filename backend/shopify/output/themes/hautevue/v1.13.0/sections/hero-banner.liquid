<section class="hero-banner" style="background-image: {{ settings.image | img_url: 'master' }};"><div class="container"><h1>{{ settings.heading | escape }}</h1><p>{{ settings.subheading | escape }}</p><a href="{{ settings.cta_url }}" class="btn">{{ settings.cta_label | escape }}</a></div></section>{% schema %}{% assigns settings = settings %}{% schema %}{% name "Hero Banner" %}{% settings ["image", "heading", "subheading", "cta_label", "cta_url"] %}{% presets ["background-image"] %}{% endschema %}