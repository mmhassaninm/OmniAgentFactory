<section class="featured-products" style="background-image: {{ settings.background_image | img_url: 'master' }};"><div class="container"><h2>{{ settings.heading | escape }}</h2><div class="product-grid" data-columns="{{ settings.grid_columns }}"><{% for block in blocks %}{% if block.settings.product %}<div class="product-card"><img src="{{ block.settings.product | img_url: 'medium' }}" alt=""><h3>{{ block.settings.product | t }}</h3><p>Price: {{ block.settings.product.price | money }}</p></div>{% endif %}{% endfor %}</div></div></section>{% schema %}{% assigns settings = settings %}{% assigns blocks = blocks %}{% schema %}{% name "Featured Products" %}{% settings ["background_image", "heading", "grid_columns"] %}{% blocks ["product-card"] %}{% presets ["background-image"] %}{% endschema %}