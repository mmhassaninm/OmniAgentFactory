{% schema %}
{
  'name': 'cart-items',
  'settings': [
    {
      'type': 'text',
      'id': 'heading',
      'label': 'Heading',
      'default': 'Cart Items'
    },
    {
      'type': 'text',
      'id': 'subheading',
      'label': 'Subheading',
      'default': 'Items in your cart'
    }
  ],
  'presets': [
    {
      'name': 'default',
      'settings': {
        'heading': 'Cart Items',
        'subheading': 'Items in your cart'
      }
    }
  ],
  'blocks': []
}{% endschema %}

<div class="cart-items">
  <h2>{{ settings.heading }}</h2>
  <p>{{ settings.subheading }}</p>
  <div class="cart-list">
    {% for item in cart.items %}
      <div class="cart-item">
        <img src="{{ item.image | img_url }}" alt="" class="product-image">
        <h3>{{ item.title }}</h3>
        <p>{{ item.price | money }}</p>
        <button class="remove-button">Remove</button>
      </div>
    {% endfor %}
  </div>
</div>
