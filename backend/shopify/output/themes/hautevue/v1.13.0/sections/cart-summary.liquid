
{% schema %}
{
  "name": "Cart summary",
  "settings": [
    {
      "type": "text",
      "id": "subtotal",
      "label": "Subtotal"
    },
    {
      "type": "text",
      "id": "tax",
      "label": "Tax"
    },
    {
      "type": "text",
      "id": "total",
      "label": "Total"
    }
  ],
  "presets": []
}
{% endschema %}

<section class="cart-summary">
  <h2>{{ settings.subtotal | money }}</h2>
  <p>Subtotal: {{ settings.subtotal | money }}</p>
  <p>Tax: {{ settings.tax | money }}</p>
  <p>Total: {{ settings.total | money }}</p>
</section>
