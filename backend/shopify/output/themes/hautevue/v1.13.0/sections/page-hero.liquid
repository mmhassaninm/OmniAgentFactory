
{% schema %}
{
  "name": "Page hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Page image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Page Name"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Page description"
    }
  ],
  "presets": []
}
{% endschema %}

<section class="page-hero hero" style="--primary-color: #3B3F4E; --background-color: #F2F2F2;">
  <img src="{{ settings.image | img_url }}" alt="{{ settings.heading }}" />
  <h1>{{ settings.heading }}</h1>
  <p>{{ settings.subheading }}</p>
  <button class="call-to-action">Learn more</button>
</section>
