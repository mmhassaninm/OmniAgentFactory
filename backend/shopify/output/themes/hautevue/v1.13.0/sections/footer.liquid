{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "contact",
      "label": "Contact info"
    },
    {
      "type": "text",
      "id": "social_media",
      "label": "Social media links"
    },
    {
      "type": "text",
      "id": "copyright",
      "label": "Copyright"
    }
  ],
  "presets": [
    {
      "enable": true,
      "settings": {
        "contact": "123 Main St, Anytown, USA",
        "social_media": "Twitter: @HauteVue, Facebook: @HauteVue",
        "copyright": "2023 HauteVue Inc."
      }
    }
  ]
}
{% endschema %}

<div class="footer" role="contentinfo">
  <div class="container">
    <div class="contact-info">
      <p>{{ settings.contact }}</p>
    </div>
    <div class="social-media-links">
      <p>{{ settings.social_media }}</p>
    </div>
    <div class="copyright">
      <p>{{ settings.copyright }}</p>
    </div>
  </div>
</div>