{% schema %}
{
  'name': 'related-products',
  'settings': [
    {
      'type': 'image_picker',
      'id': 'background_image',
      'label': 'Background image'
    },
    {
      'type': 'text',
      'id': 'heading',
      'label': 'Heading',
      'default': 'Related Products'
    }
  ],
  'presets': [
    {
      'name': 'default',
      'settings': {
        'background_image': '',
        'heading': 'Related Products'
      }
    }
  ],
  'blocks': [
    {
      'type': 'product-card',
      'name': 'Related Product',
      'settings': [
        {
          'type': 'product_picker',
          'id': 'product',
          'label': 'Product'
        }
      ]
    }
  ]
}{% endschema %}

<div class="related-products">
  <div class="grid-container">
    <img src="{{ settings.background_image | img_url }}" alt="" class="hero-image">
    <h2>{{ settings.heading }}</h2>
    <div class="product-grid">
      {% for block in blocks %}
        {% if block.settings.product %}
          <div class="product-card">
            <img src="{{ block.settings.product | product_image_url }}" alt="{{ block.settings.product | product_title }}" class="product-image">
            <h3>{{ block.settings.product | product_title }}</h3>
            <p>{{ block.settings.product | product_price }}</p>
            <a href="{{ block.settings.product | product_url }}" class="cta-button">Buy Now</a>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>
