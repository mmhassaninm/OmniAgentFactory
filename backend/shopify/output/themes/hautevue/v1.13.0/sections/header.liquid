{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 80,
      "max": 300,
      "step": 10,
      "unit": "px",
      "label": "Logo width",
      "default": 150
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    }
  ],
  "presets": [
    {
      "enable": true,
      "settings": {
        "logo": "https://example.com/logo.png",
        "logo_width": 150,
        "menu": "main-menu"
      }
    }
  ]
}
{% endschema %}

<div class="header" role="banner">
  <div class="container">
    <div class="logo">
      <img src="{{ settings.logo | img_url: 'medium' }}" alt="{{ settings.logo | escape }}" style="width: {{ settings.logo_width }}px;">
    </div>
    <nav class="menu" aria-label="Main menu">
      <ul>
        <li><a href="{{ routes.home }}">Home</a></li>
        <li><a href="{{ routescollections }}">Collections</a></li>
        <li><a href="{{ routes.search }}">Search</a></li>
      </ul>
    </nav>
    <div class="search">
      <form action="{{ routes.search }}" method="get">
        <input type="search" name="q" placeholder="Search...">
        <button type="submit">Search</button>
      </form>
    </div>
    <div class="cart">
      <a href="{{ routes.cart }}" class="cart-icon"><span aria-label="Cart items">{{ cart.item_count }}</span></a>
    </div>
  </div>
  <div class="mobile-menu">
    <button class="mobile-menu-toggle" aria-label="Toggle menu">Menu</button>
    <nav class="mobile-menu" aria-label="Mobile menu">
      <ul>
        <li><a href="{{ routes.home }}">Home</a></li>
        <li><a href="{{ routescollections }}">Collections</a></li>
        <li><a href="{{ routes.search }}">Search</a></li>
      </ul>
    </nav>
  </div>
</div>