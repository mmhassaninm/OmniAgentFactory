<header class="site-header" role="banner" style="position: fixed; top: 0; left: 0; width: 100%; background-color: #F2F2F2; padding: 1rem; display: flex; align-items: center; justify-content: space-between;">
	<div class="logo" style="width: {{ settings.logo_width }}px;">{% if settings.logo %}
		<img src="{{ settings.logo | img_url: 'large' }}" alt="{{ settings.logo | escape }}" style="width: {{ settings.logo_width }}px; height: auto;">
	{% endif %}</div>
	<nav class="main-navigation" style="display: flex; align-items: center;">{% if settings.menu %}
		<ul style="list-style: none; margin: 0; padding: 0;">
			{% for link in settings.menu %}
				<li style="margin-right: 1rem;"><a href="{{ link.url | url }}">{{ link.title | escape }}</a></li>
			{% endfor %}
		</ul>
	{% endif %}</nav>
	<button class="menu-toggle" style="display: none;"></button>
	<button class="search-toggle" style="display: none;"></button>
	<div class="cart-icon" style="display: flex; align-items: center;">{% if customer %}
		<img src="{{ 'cart-icon.png' | asset }}" alt="Shopping cart" style="width: 2rem; height: 2rem; margin-right: 0.5rem;">
		<span style="font-family: Montserrat; font-size: 1.2rem;">{{ customer.order_count }}</span>
	{% endif %}</div>
</header>{% schema %}
{
  "name": "header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 80,
      "max": 300,
      "step": 10,
      "unit": "px",
      "label": "Logo width",
      "default": 150
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    }
  ],
  "presets": []
}{% endschema %}