<section class="page-call-to-action" role="button" aria-label="{{ settings.label | escape }}" style="background-color: #3B3F4E; color: #F2F2F2; padding: 1rem 2rem; border: none; border-radius: 0.5rem; cursor: pointer;">
	<a href="{{ settings.url | url }}">{{ settings.label | escape }}</a>
</section>{% schema %}
{
  "name": "page-call-to-action",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Button label",
      "default": "Contact us"
    },
    {
      "type": "url",
      "id": "url",
      "label": "Button URL"
    }
  ],
  "presets": []
}{% endschema %}