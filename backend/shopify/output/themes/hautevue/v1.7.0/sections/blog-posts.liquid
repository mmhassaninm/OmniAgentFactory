{% schema %}
{
  'name': 'blog-posts'
}
{
  'settings': [
    {
      'type': 'blog',
      'id': 'blog',
      'label': 'Blog'
    }
  ]
}
{
  'presets': [
    {
      'name': 'default',
      'settings': {}
    }
  ]
}
<div class="blog-grid">
  {% for post in blog.posts %}
    <div class="blog-item">
      <h2>{{ post.title | escape }}</h2>
      <p>{{ post.description | escape }}</p>
      <img src="{{ post.image | img_url: 'medium' }}" alt="{{ post.title | escape }}">
    </div>
  {% endfor %}
</div>
{% schema %}{% endschema %}