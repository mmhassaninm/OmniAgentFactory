{% schema %}
{
  'name': 'blog-hero'
}
{
  'settings': [
    {
      'type': 'image_picker',
      'id': 'image',
      'label': 'Hero image'
    },
    {
      'type': 'text',
      'id': 'title',
      'label': 'Blog title'
    },
    {
      'type': 'text',
      'id': 'description',
      'label': 'Blog description'
    }
  ]
}
{
  'presets': [
    {
      'name': 'default',
      'settings': {
        'image': '',
        'title': '',
        'description': ''
      }
    }
  ]
}
<div class="blog-hero" style="background-image: url('{{ settings.image | img_url: 'large' }}');">
  <h1>{{ settings.title | escape }}</h1>
  <p>{{ settings.description | escape }}</p>
</div>
{% schema %}{% endschema %}