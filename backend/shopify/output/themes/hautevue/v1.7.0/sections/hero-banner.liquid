
  <section class="hero-banner" style="background-image:linear-gradient(to bottom, {{ settings.bg_color }} 0%, {{ settings.bg_color }} {{ settings.bg_color_transparency }}%), url('{{ settings.image | img_url }}')">
    <div class="container">
      <h1>{{ settings.heading }}</h1>
      <h2>{{ settings.subheading }}</h2>
      <a href="{{ settings.cta_url }}" class="btn">{{ settings.cta_label }}</a>
    </div>
  </section>
  {% schema %}
  {
    "name": "hero-banner",
    "settings":
      [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Latest Arrivals"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading",
          "default": "Shop our curated selection of fashion must-haves"
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "Button label",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "cta_url",
          "label": "Button URL"
        }
      ],
    "presets": []
  }
  {% endschema %}
  