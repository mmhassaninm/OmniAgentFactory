<section class="product-call-to-action" style="--primary-color: #3B3F4E; --bg-color: #F2F2F2;" role="region" aria-label="Product call-to-action">
  <button style="background-color: var(--primary-color); color: #FFFFFF;" type="button" id="call-to-action-button">
    {{ settings.label | escape }}
  </button>
  <a href="{{ settings.url }}" style="text-decoration: none; color: #3B3F4E;" target="_blank" rel="noopener noreferrer">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="svg-icon ml-2">
      <path d="M3 3l6 6 6-6" />
    </svg>
  </a>
  {% schema %}
  {
    "name": "product-call-to-action",
    "settings": [
      {
        "type": "text",
        "id": "label",
        "label": "Button label",
        "default": "Add to cart"
      },
      {
        "type": "url",
        "id": "url",
        "label": "Button URL"
      }
    ],
    "presets": []
  }
  {% endschema %}
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const callToActionButton = document.getElementById('call-to-action-button');
    callToActionButton.addEventListener('click', function() {
      console.log('Call to action button clicked.');
    });
  });
</script>

<style>
  @media only screen and (max-width: 768px) {
    .product-call-to-action {
      display: block;
      width: 100%;
      text-align: center;
    }
    #call-to-action-button {
      display: block;
      width: 100%;
      padding: 10px;
      font-size: 16px;
    }
  }
</style>