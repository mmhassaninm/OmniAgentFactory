<section class="page-content" role="region" aria-label="{{ settings.title | escape }}" style="display: flex; flex-direction: column; align-items: center; padding: 2rem;">
	<div class="container">
		<h2>{{ settings.title | escape }}</h2>
		<p>{{ settings.description | escape }}</p>
		{% for block in blocks %}{% if block.settings.title %}
			<h3>{{ block.settings.title | escape }}</h3>
			<p>{{ block.settings.description | escape }}</p>
		{% endif %}{% endfor %}
	</div>
</section>{% schema %}
{
  "name": "page-content",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section title"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Section description"
    }
  ],
  "presets": [],
  "blocks": [
    {
      "type": "page-section",
      "name": "section",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Section title"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Section description"
        }
      ]
    }
  ]
}{% endschema %}