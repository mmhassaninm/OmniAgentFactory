{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "New Arrivals"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Shop our latest fashion trends"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    }
  ],
  "presets": [
    {
      "name": "Default",
      "settings": {}
    }
  ]
}
{% endschema %}

<div class="hero-banner" style="background-image: {{ settings.image | img_url: 'master' }}; background-size: cover; background-position: center; background-color: #F2F2F2;">
  <div class="container">
    <h1>{{ settings.heading }}</h1>
    <p>{{ settings.subheading }}</p>
    <a href="{{ settings.cta_url }}" class="btn btn-primary">{{ settings.cta_label }}</a>
  </div>
</div>