{% schema %}
{
  'name': 'Product Reviews',
  'settings': [],
  'presets': [],
  'sections': [{
    'type': 'review',
    'name': 'review',
    'settings': [
      {
        'type': 'text',
        'id': 'rating',
        'label': 'Rating'
      },
      {
        'type': 'text',
        'id': 'review',
        'label': 'Review'
      }
    ]
  }]
}
{% endschema %}
<div class="product-reviews">
  {% for review in product.reviews %}
    <div class="review">
      <img src="{{ review.customer.image | img_url: '30x30' }}" alt="{{ review.customer.name }}">
      <p>{{ review.rating }} out of 5 stars</p>
      <p>{{ review.body }}</p>
    </div>
  {% endfor %}
</div>