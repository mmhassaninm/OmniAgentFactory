{% schema %}
{
  'name': 'Cart Hero',
  'settings': [
    {
      'type': 'text',
      'id': 'subtotal',
      'label': 'Subtotal',
      'default': '$50.00'
    },
    {
      'type': 'text',
      'id': 'tax',
      'label': 'Tax',
      'default': '$10.00'
    },
    {
      'type': 'text',
      'id': 'total',
      'label': 'Total',
      'default': '$60.00'
    }
  ],
  'presets': [],
  'sections': []
}
{% endschema %}
<div class="cart-hero">
  <h1>Cart</h1>
  <p>Subtotal: {{ settings.subtotal | money }}</p>
  <p>Tax: {{ settings.tax | money }}</p>
  <p>Total: {{ settings.total | money }}</p>
  <a href="/cart" class="btn">Proceed to checkout</a>
</div>