{% schema %}
{
  "name": "Call to Action",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Sign up for Exclusive Offers"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Get 10% off your first order"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    }
  ],
  "presets": [
    {
      "name": "Default",
      "settings": {}
    }
  ]
}
{% endschema %}

<div class="call-to-action">
  <div class="container">
    <h1>{{ settings.heading }}</h1>
    <p>{{ settings.subheading }}</p>
    <a href="{{ settings.cta_url }}" class="btn btn-primary">Sign up now</a>
  </div>
</div>