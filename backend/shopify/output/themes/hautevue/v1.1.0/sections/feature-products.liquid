{% schema %}
{
  "name": "Feature Products",
  "settings": [
    {
      "type": "product_picker",
      "id": "products",
      "label": "Featured products",
      "default": ""
    }
  ],
  "presets": [
    {
      "name": "Default",
      "settings": {}
    }
  ]
}
{% endschema %}

<div class="feature-products">
  <div class="container">
    <div class="product-grid" style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px;">
      {% for product in settings.products | json_array | sort_by: 'created_at' | reverse %}
        <div class="product">
          <a href="{{ product.url }}">
            <img src="{{ product.image | img_url: 'master' }}" alt="{{ product.title }}" style="width: 100%; height: 150px; object-fit: cover; border-radius: 10px;">
            <h4>{{ product.title }}</h4>
            <p>{{ product.price | money }}</p>
          </a>
        </div>
      {% endfor %}
    </div>
  </div>
</div>