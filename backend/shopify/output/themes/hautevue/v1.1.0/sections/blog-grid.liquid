{% schema %}
{
  'name': 'Blog Grid',
  'settings': [
    {
      'type': 'blog_picker',
      'id': 'blog',
      'label': 'Blog'
    }
  ],
  'presets': [
    {
      'name': 'Default',
      'settings': {
        'blog': ''
      }
    }
  ]
}
{% endschema %}

<div class="blog-grid">
  {% if settings.blog != blank %}
    {% assign posts = collections[settings.blog].items %}
    <div class="grid">
      {% for post in posts %}
        <div class="grid-item">
          <img src="{{ post.image | img_url }}" alt="{{ post.title }}" style="object-fit: cover;" aria-label="{{ post.title }}">
          <h3>{{ post.title }}</h3>
          <p>{{ post.description }}</p>
        </div>
      {% endfor %}
    </div>
  {% endif %}
</div>
