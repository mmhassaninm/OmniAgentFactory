{% schema %}
{
  'name': 'Page Hero',
  'settings': [
    {
      'type': 'image_picker',
      'id': 'image',
      'label': 'Page image'
    },
    {
      'type': 'text',
      'id': 'heading',
      'label': 'Heading',
      'default': 'Page Name'
    }
  ],
  'presets': [
    {
      'default': {
        'image': '//:image_url/',
        'heading': 'Page Name'
      }
    }
  ]
}
{% endschema %}

<section class="page-hero" style="background-image: url('{{ settings.image | img_url: 'master' }}'); background-size: cover; background-position: center; display: flex; flex-direction: column; justify-content: center; align-items: center; padding: 20px;">
  <h1>{{ settings.heading }}</h1>
</section>