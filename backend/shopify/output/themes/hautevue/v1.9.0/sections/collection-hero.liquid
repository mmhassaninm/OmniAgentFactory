{% schema %}
{
  "name": "Collection Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Collection image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Collection Name"
    }
  ],
  "presets": [
    {
      "name": "Default",
      "settings": {
        "heading": "Collection Name"
      }
    }
  ]
}
{% endschema %}
<div class="collection-hero">
  <img src="{{ section.settings.image | img_url: 'master' }}" alt="Collection Image">
  <h1>{{ section.settings.heading }}</h1>
</div>
