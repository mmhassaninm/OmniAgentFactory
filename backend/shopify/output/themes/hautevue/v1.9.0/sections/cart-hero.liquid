{% schema %}
{
  "name": "Cart Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Cart image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your Cart"
    }
  ],
  "presets": [
    {
      "name": "Default",
      "settings": {
        "heading": "Your Cart"
      }
    }
  ]
}
{% endschema %}
<div class="cart-hero">
  <img src="{{ section.settings.image | img_url: 'master' }}" alt="Cart Image">
  <h1>{{ section.settings.heading }}</h1>
</div>
