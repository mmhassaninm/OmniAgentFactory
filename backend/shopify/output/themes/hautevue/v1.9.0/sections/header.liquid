{% schema %}
{
  'name': 'Header',
  'settings': [
    {
      'type': 'image_picker',
      'id': 'logo',
      'label': 'Logo'
    },
    {
      'type': 'range',
      'id': 'logo_width',
      'min': 80,
      'max': 300,
      'step': 10,
      'unit': 'px',
      'label': 'Logo width',
      'default': 150
    },
    {
      'type': 'link_list',
      'id': 'menu',
      'label': 'Navigation menu',
      'default': 'main-menu'
    }
  ],
  'presets': [
    {
      'default': {
        'logo': '//:image_url/',
        'logo_width': 150,
        'menu': 'main-menu'
      }
    }
  ]
}
{% endschema %}

<header class="header" style="background-color: #3B3F4E; padding: 10px;">
  <a href="{{ shop.url }}" class="logo" style="width: {{ settings.logo_width }}px;"><img src="{{ settings.logo | img_url: 'master' }}" alt="{{ shop.name }}" style="width: {{ settings.logo_width }}px;"></a>
  <nav class="menu">
    <ul>
      {% for link in settings.menu %}
        <li><a href="{{ link.url }}">{{ link.title }}</a></li>
      {% endfor %}
    </ul>
  </nav>
  <button class="mobile-menu-toggle" aria-label="Toggle navigation menu" style="display: none;">Menu</button>
</header>