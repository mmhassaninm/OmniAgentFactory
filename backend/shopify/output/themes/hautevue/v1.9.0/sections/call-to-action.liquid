{% schema %}
{
  "name": "Call to Action",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Limited Time Offer"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "Get 15% off your first purchase"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Shop Now"
    }
  ],
  "presets": []
}
{% endschema %}

<section class="call-to-action">
  <div class="container">
    <h1>{{ settings.heading | escape }}</h1>
    <p>{{ settings.description | escape }}</p>
    <a href="{{ settings.cta_url | escape }}" class="btn">{{ settings.cta_label | escape }}</a>
  </div>
</section>