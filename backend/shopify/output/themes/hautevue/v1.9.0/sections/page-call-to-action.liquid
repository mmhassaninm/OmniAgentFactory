{% schema %}
{
  'name': 'Page Call-to-Action',
  'settings': [
    {
      'type': 'text',
      'id': 'heading',
      'label': 'Heading',
      'default': 'Contact us'
    },
    {
      'type': 'text',
      'id': 'description',
      'label': 'Description',
      'default': 'Get in touch with us'
    }
  ],
  'presets': [
    {
      'default': {
        'heading': 'Contact us',
        'description': 'Get in touch with us'
      }
    }
  ]
}
{% endschema %}

<section class="page-call-to-action">
  <h2>{{ settings.heading }}</h2>
  <p>{{ settings.description }}</p>
  <a href="{{ shop.url }}" class="btn">Contact us</a>
</section>