{% schema %}
{
  "name": "Product Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Product image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Product Name"
    }
  ],
  "presets": []
}
{% endschema %}

<section class="product-hero" style="background-image: {{ settings.image | img_url: 'master' }};">
  <div class="container">
    <h1>{{ settings.heading | escape }}</h1>
  </div>
</section>