{% schema %}
{
  "name": "Blog Grid",
  "settings": [
    {
      "type": "range",
      "id": "grid_columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "unit": "",
      "label": "Grid columns",
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "label": "Show excerpt"
    }
  ],
  "presets": [
  ],
  "blocks": [
    {
      "type": "blog_grid_item",
      "name": "Blog Grid Item",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "excerpt",
          "label": "Excerpt"
        }
      ]
    }
  ],
  "default_mode": "edit"
}
{% endschema %}

<div class="blog-grid" role="region" aria-label="Blog grid">
  {% for item in collection.items %}
    <div class="blog-grid-item" role="listitem">
      <h2>{{ item.title }}</h2>
      <img src="{{ item.image | img_url: 'medium' }}" alt="{{ item.title }}" width="100%" height="auto" loading="lazy">
      {% if settings.show_excerpt %}
        <p>{{ item.excerpt }}</p>
      {% endif %}
    </div>
  {% endfor %}
</div>