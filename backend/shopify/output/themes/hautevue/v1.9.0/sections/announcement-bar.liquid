<section class="announcement-bar" role="alert" aria-label="{{ 'announcement-bar.aria-label' | t }}">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-12 col-lg-8">
        <p class="message">{{ settings.message | escape }}</p>
      </div>
      <div class="col-12 col-lg-4">
        <a href="{{ 'shop.url' | url }}" class="btn btn-lg btn-block cta-button" role="button">{{ settings.cta_label | escape }}</a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name":"announcement-bar",
  "settings":[
    {
      "type":"text",
      "id":"message",
      "label":"{{ 'announcement-bar.message' | t }}",
      "default":"New arrivals now available"
    },
    {
      "type":"text",
      "id":"cta_label",
      "label":"{{ 'announcement-bar.cta-label' | t }}",
      "default":"Shop now"
    }
  ],
  "presets":[
    {
      "name":"default",
      "settings":{
        "message":"New arrivals now available",
        "cta_label":"Shop now"
      }
    }
  ]
}
{% endschema %}