{% schema %}
{
  "name": "Collection Call-to-Action",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop this collection"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "Get 15% off your first purchase"
    }
  ],
  "presets": [
    {
      "name": "Default",
      "settings": {
        "heading": "Shop this collection",
        "description": "Get 15% off your first purchase"
      }
    }
  ]
}
{% endschema %}
<div class="collection-call-to-action">
  <h1>{{ section.settings.heading }}</h1>
  <p>{{ section.settings.description }}</p>
  <button>Shop this collection</button>
</div>
