{% schema %}
{
  "name": "Cart Items",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_quantity",
      "label": "Show quantity"
    }
  ],
  "presets": [
  ],
  "blocks": [
    {
      "type": "cart_item",
      "name": "Cart Item",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price"
        },
        {
          "type": "text",
          "id": "quantity",
          "label": "Quantity"
        }
      ]
    }
  ],
  "default_mode": "edit"
}
{% endschema %}

<div class="cart-items" role="list" aria-label="Cart items">
  {% for item in cart.items %}
    <div class="cart-item" role="listitem">
      <h2>{{ item.title }}</h2>
      <p>Price: {{ item.price | money }}</p>
      {% if settings.show_quantity %}
        <p>Quantity: {{ item.quantity }}</p>
      {% endif %}
    </div>
  {% endfor %}
</div>