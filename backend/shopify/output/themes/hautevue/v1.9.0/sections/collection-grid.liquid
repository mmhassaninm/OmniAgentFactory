{% schema %}
{
  "name": "Collection Grid",
  "settings": [
    {
      "type": "range",
      "id": "grid_columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "unit": "",
      "label": "Grid columns",
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "show_price",
      "label": "Show price"
    }
  ],
  "presets": [
    {
      "name": "Default",
      "settings": {
        "grid_columns": 3,
        "show_price": false
      }
    }
  ]
}
{% endschema %}
<div class="collection-grid" aria-label="Collection Grid">
  {% for block in section.blocks %}
    {% if block.type == 'product_grid_item' %}
      <div class="grid-item">
        <h2>{{ block.settings.title }}</h2>
        <img src="{{ block.settings.image | img_url: 'master' }}" alt="Product Image">
        {% if section.settings.show_price %}
          <p>Price: {{ product.price | money }}</p>
        {% endif %}
      </div>
    {% endif %}
  {% endfor %}
</div>
