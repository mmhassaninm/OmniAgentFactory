{% schema %}
{
  "name": "New Arrivals",
  "settings": [
    {
      "type": "range",
      "id": "grid_columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "unit": "",
      "label": "Grid columns",
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "show_price",
      "label": "Show price"
    }
  ],
  "blocks": [
    {
      "type": "product_grid_item",
      "name": "Product Grid Item",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price"
        }
      ]
    }
  ],
  "presets": []
}
{% endschema %}

<div class="new-arrivals" style="grid-template-columns: repeat({{ settings.grid_columns }}, 1fr);">
  {% for block in blocks %}
    {% if block.settings.image != blank %}
      <div class="product-grid-item">
        <img src="{{ block.settings.image | img_url: 'master' }}" alt="{{ block.settings.title | escape }}">
        <h2>{{ block.settings.title | escape }}</h2>
        {% if settings.show_price %}
          <p>Price: {{ block.settings.price | money }}</p>
        {% endif %}
      </div>
    {% endif %}
  {% endfor %}
</div>