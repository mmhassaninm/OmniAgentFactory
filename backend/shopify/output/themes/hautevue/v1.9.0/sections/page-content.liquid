{% schema %}
{
  'name': 'Page Content',
  'settings': [
    {
      'type': 'text',
      'id': 'heading',
      'label': 'Heading',
      'default': 'Page content'
    }
  ],
  'presets': [
    {
      'default': {
        'heading': 'Page content'
      }
    }
  ]
}
{% endschema %}

<section class="page-content">
  <h2>{{ settings.heading }}</h2>
  <div class="page-content-text">
    {% for block in blocks %}
      {% if block.settings.text != blank %}
        <p>{{ block.settings.text | escape }}</p>
      {% endif %}
    {% endfor %}
  </div>
</section>