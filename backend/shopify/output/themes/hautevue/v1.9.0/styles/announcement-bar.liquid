.announcement-bar {
  background-color: {{ config.theme.settings.primary_color | hex }};
  color: {{ config.theme.settings.bg_color | hex }};
  padding: 1rem;
  font-family: Montserrat, sans-serif;
}

.announcement-bar .message {
  font-size: 1.25rem;
  font-weight: 600;
}

.announcement-bar .cta-button {
  background-color: {{ config.theme.settings.primary_color | hex }};
  color: {{ config.theme.settings.bg_color | hex }};
  border: none;
  padding: 1rem 2rem;
  font-size: 1.25rem;
  font-weight: 600;
  text-transform: uppercase;
}

@media (max-width: 768px) {
  .announcement-bar .cta-button {
    padding: 1rem;
  }
}