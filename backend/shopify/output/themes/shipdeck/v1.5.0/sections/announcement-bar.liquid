<!-- Announcement Bar -->
<section class="announcement-bar" role="alert">
  <div class="container">
    <div class="row">
      <div class="col-12 text-center">
        <h2>
          {{ heading | escape }}
        </h2>
        <p>
          {{ subheading | escape }}
        </p>
      </div>
    </div>
  </div>
  <div class="timer-container">
    <div class="timer">
      <span class="days">{{ days }}</span>
      <span class="hours">{{ hours }}</span>
      <span class="minutes">{{ minutes }}</span>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "announcement-bar",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Limited Time Offer"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Don't miss out on our best deals"
    },
    {
      "type": "number",
      "id": "days",
      "min": 1,
      "max": 30,
      "step": 1,
      "label": "Days remaining"
    },
    {
      "type": "number",
      "id": "hours",
      "min": 0,
      "max": 23,
      "step": 1,
      "label": "Hours remaining"
    },
    {
      "type": "number",
      "id": "minutes",
      "min": 0,
      "max": 59,
      "step": 1,
      "label": "Minutes remaining"
    }
  ],
  "presets": [
    {
      "name": "Default"
    }
  ]
}
{% endschema %}