<!-- Hero Banner Section -->
<section class="hero-banner" role="region" aria-label="{{ 'hero_banner.title' | t }}">
  <div class="container hero-banner__container">
    <div class="hero-banner__background" style="background-image: url('{{ section.settings.image | image_url: width: 1200 }}');"></div>
    <h1 class="hero-banner__heading" aria-hidden="true">{{ section.settings.heading | escape }}</h1>
    <div class="hero-banner__content">
      <h2 class="hero-banner__subheading" aria-hidden="true">{{ section.settings.subheading | escape }}</h2>
      <a class="button hero-banner__cta" href="{{ section.settings.cta_url | escape }}" aria-label="{{ section.settings.cta_label | t }}">{{ section.settings.cta_label | escape }}</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "hero-banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Best Deals"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Shop now and get free shipping"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}