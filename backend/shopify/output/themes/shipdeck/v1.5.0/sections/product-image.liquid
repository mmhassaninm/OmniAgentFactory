<!-- Product Image Section -->
<div class="product-image" role="img" aria-label="{{ section.settings.alt_text | t }}">
  <img class="product-image__image" src="{{ section.settings.image | image_url: width: 800 }}" alt="{{ section.settings.alt_text | escape }}" loading="lazy">
</div>

{% schema %}
{
  "name": "product-image",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Product image"
    },
    {
      "type": "text",
      "id": "alt_text",
      "label": "Alt text",
      "default": "Product image"
    }
  ],
  "presets": [
    {
      "name": "Product Image"
    }
  ]
}
{% endschema %}