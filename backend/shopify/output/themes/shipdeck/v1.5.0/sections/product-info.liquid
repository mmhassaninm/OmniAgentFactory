<!-- Product Info Section -->
<div class="product-info" role="region" aria-label="{{ 'product_info.title' | t }}">
  <div class="container product-info__container">
    <div class="product-info__content">
      <h2 class="product-info__title" aria-hidden="true">{{ product.title | escape }}</h2>
      <p class="product-info__description" aria-hidden="true">{{ product.description | escape }}</p>
      <p class="product-info__price" aria-hidden="true">{{ product.price | money }}</p>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "product-info",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product",
      "default": "current-product"
    },
    {
      "type": "price",
      "id": "price",
      "label": "Price",
      "default": "current-product.price"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "current-product.description"
    }
  ],
  "presets": [
    {
      "name": "Product Info"
    }
  ]
}
{% endschema %}