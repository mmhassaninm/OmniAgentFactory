{% schema %}
  {
    "name": "Content Area",
    "settings": [
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Page Content"
      },
      {
        "type": "text",
        "id": "text",
        "label": "Text",
        "default": ""
      }
    ],
    "presets": [
      {
        "name": "Default"
      }
    ]
  }
  {% endschema %}
  <div class="content-area">
    <h2>{{ heading | t }}</h2>
    <p>{{ text | t }}</p>
  </div>