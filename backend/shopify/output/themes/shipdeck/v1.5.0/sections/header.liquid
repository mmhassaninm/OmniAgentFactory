{% schema %}
  {
    "name": "Header",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo"
      },
      {
        "type": "range",
        "id": "logo_width",
        "min": 80,
        "max": 300,
        "step": 10,
        "unit": "px",
        "label": "Logo width",
        "default": 150
      },
      {
        "type": "link_list",
        "id": "menu",
        "label": "Navigation menu",
        "default": "main-menu"
      }
    ],
    "presets": [
      {
        "name": "Default"
      }
    ]
  }
  {% endschema %}
  <header class="site-header">
    <div class="logo" style="max-width: {{ logo_width | escape }}px">
      <img src="{{ logo | image_url: width: 800 | image_tag }}" alt="Site Logo">
    </div>
    <nav>
      <ul>
        {% for link in menu %}
          <li>
            <a href="{{ link.url | escape }}">{{ link.title | escape }}</a>
          </li>
        {% endfor %}
      </ul>
    </nav>
  </header>