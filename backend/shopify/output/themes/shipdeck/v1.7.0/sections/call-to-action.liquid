{% schema %}
{
  'name': 'call-to-action',
  'settings': [
    {
      'type': 'text',
      'id': 'heading',
      'label': 'Heading',
      'default': 'Join Our Community'
    },
    {
      'type': 'text',
      'id': 'subheading',
      'label': 'Subheading',
      'default': 'Get exclusive discounts and early access to new products'
    },
    {
      'type': 'text',
      'id': 'cta_label',
      'label': 'Button label',
      'default': 'Sign Up'
    },
    {
      'type': 'url',
      'id': 'cta_url',
      'label': 'Button URL'
    }
  ],
  'presets': [{
    'name': 'Call to Action'
  }]
}
{% endschema %}

<div class="call-to-action" style="background-color: #3498db; color: #f9f9f9; padding: 20px; text-align: center;">
  <h1>{{ section.settings.heading }}</h1>
  <p>{{ section.settings.subheading }}</p>
  <a href="{{ section.settings.cta_url }}" class="btn">{{ section.settings.cta_label }}</a>
</div>