{% schema %}
{
  'name': 'collection-grid',
  'settings': [
    {
      'type': 'product_list',
      'id': 'products',
      'label': 'Collection products'
    }
  ],
  'presets': [
    {
      'name': 'Collection Grid'
    }
  ],
  'sections': [
  ],
  'default': 'default'
}{% endschema %}
<div class="container mx-auto p-4 mb-12">
  <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
    {% for product in collection.products %}
      <div class="bg-white p-4 rounded shadow-md">
        <a href="{{ product.url | escape }}" class="block">
          <img class="object-cover object-center w-full h-64 md:h-96 lg:h-128" src="{{ product.image | image_url: width: 400 | image_url }}" alt="{{ product.title | escape }}"/>
          <h3 class="font-sans text-lg font-bold mb-4 text-gray-800">{{ product.title | escape }}</h3>
        </a>
      </div>
    {% endfor %}
  </div>
</div>