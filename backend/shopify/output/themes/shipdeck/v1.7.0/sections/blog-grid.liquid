<section class="blog-grid" aria-label="Grid of blog posts">
  <div class="container">
    <div class="row g-3">
      {% for post in section.settings.posts %}
        <div class="col-12 col-md-6 col-lg-4">
          <div class="blog-post">
            <a href="{{ post.url }}" aria-label="{{ post.title }}">
              <div class="blog-post-image" style="background-image: url('{{ post.image | image_url: width: 400 | image_tag }}')"></div>
              <h2>{{ post.title }}</h2>
            </a>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Blog grid",
  "settings": [
    {
      "type": "blog_list",
      "id": "posts",
      "label": "Blog posts"
    }
  ],
  "presets": [
    {
      "name": "Blog Grid"
    }
  ]
}
{% endschema %}