{% schema %}
{
  'name': 'featured-products',
  'settings': [
    {
      'type': 'product_list',
      'id': 'products',
      'label': 'Featured products'
    }
  ],
  'presets': [{
    'name': 'Featured Products'
  }]
}
{% endschema %}

<div class="featured-products" style="display: grid; gap: 20px;">
  {% for product in section.settings.products.products %}
    <div class="product-card" style="display: flex; flex-direction: column;" data-aos="fade-up">
      <img src="{{ product.image | image_url: width: 300 }}" alt="{{ product.title }}">
      <h2>{{ product.title }}</h2>
      <p>{{ product.description }}</p>
      <a href="{{ product.url }}" class="btn">Shop Now</a>
    </div>
  {% endfor %}
</div>