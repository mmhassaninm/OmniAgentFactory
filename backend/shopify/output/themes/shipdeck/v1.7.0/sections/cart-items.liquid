{% schema %}
{
  'name': 'cart-items',
  'settings': [
    {
      'type': 'product_list',
      'id': 'products',
      'label': 'Cart products'
    }
  ],
  'presets': [
    {
      'name': 'Cart Items'
    }
  ],
  'sections': [
  ],
  'default': 'default'
}{% endschema %}
<div class="container mx-auto p-4 mb-12">
  <div class="font-sans text-lg font-bold mb-4 text-gray-800">
    <h2>Cart Items</h2>
  </div>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    {% for item in cart.items %}
      <div class="bg-white p-4 rounded shadow-md">
        <a href="{{ item.product.url | escape }}" class="block">
          <img class="object-cover object-center w-full h-64 md:h-96 lg:h-128" src="{{ item.product.image | image_url: width: 400 | image_url }}" alt="{{ item.product.title | escape }}"/>
          <h3 class="font-sans text-lg font-bold mb-4 text-gray-800">{{ item.product.title | escape }}</h3>
        </a>
      </div>
    {% endfor %}
  </div>
</div>