{% schema %}
{
  'name': 'collection-hero',
  'settings': [
    {
      'type': 'image_picker',
      'id': 'image',
      'label': 'Background image'
    },
    {
      'type': 'text',
      'id': 'heading',
      'label': 'Heading',
      'default': 'Collection Name'
    }
  ],
  'presets': [
    {
      'name': 'Collection Hero'
    }
  ],
  'sections': [
  ],
  'default': 'default'
}{% endschema %}
<div class="h-screen lg:h-screen bg-cover bg-center bg-no-repeat mb-12" style="background-image: url('{{ settings.image | image_url: width: 1200 | image_url }}');">
  <div class="container mx-auto p-4 text-gray-800">
    <h1 class="font-sans text-3xl font-bold mb-4 text-white" style="background-color: {{ theme.settings.colors.primary }};">{{ settings.heading | escape }}</h1>
  </div>
</div>