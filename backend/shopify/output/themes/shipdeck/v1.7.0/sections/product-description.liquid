{% schema %}
{
  'name': 'product-description',
  'settings': [
    {
      'type': 'text',
      'id': 'description',
      'label': 'Product description'
    }
  ],
  'presets': [{
    'name': 'Product Description'
  }]
}
{% endschema %}

<div class="product-description">
  <h2>Product Description</h2>
  <p>{{ section.settings.description }}</p>
</div>