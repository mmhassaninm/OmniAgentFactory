{% schema %}
{
  'name': 'hero-banner',
  'settings': [
    {
      'type': 'image_picker',
      'id': 'image',
      'label': 'Background image'
    },
    {
      'type': 'text',
      'id': 'heading',
      'label': 'Heading',
      'default': 'Best Dropshipped Products'
    },
    {
      'type': 'text',
      'id': 'subheading',
      'label': 'Subheading',
      'default': 'Shop now and get free shipping'
    },
    {
      'type': 'text',
      'id': 'cta_label',
      'label': 'Button label',
      'default': 'Shop Now'
    },
    {
      'type': 'url',
      'id': 'cta_url',
      'label': 'Button URL'
    }
  ],
  'presets': [{
    'name': 'Hero Banner'
  }]
}
{% endschema %}

<div class="hero-banner" style="background-image: url('{{ section.settings.image | image_url: width: 1200 }}'); background-size: cover; background-position: center; height: 100vh; display: flex; justify-content: center; align-items: center;">
  <h1>{{ section.settings.heading }}</h1>
  <p>{{ section.settings.subheading }}</p>
  <a href="{{ section.settings.cta_url }}" class="btn">{{ section.settings.cta_label }}</a>
</div>