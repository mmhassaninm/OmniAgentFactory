<section class="cart-summary" aria-label="Cart summary and subtotal">
  <div class="container">
    <div class="row justify-content-between align-items-center">
      <div class="col-12 col-md-6">
        <h3>{{ t 'Subtotal' }}</h3>
        <p>{{ section.settings.subtotal | money }}</p>
      </div>
      <div class="col-12 col-md-6 d-flex justify-content-end">
        <button type="button" class="btn btn-primary" aria-label="Checkout">
          <span>{{ section.settings.cta_label }}</span>
          <a href="{{ section.settings.cta_url }}" aria-label="Checkout"></a>
        </button>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Cart summary",
  "settings": [
    {
      "type": "price",
      "id": "subtotal",
      "label": "Subtotal"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Checkout"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    }
  ],
  "presets": [
    {
      "name": "Cart Summary"
    }
  ]
}
{% endschema %}