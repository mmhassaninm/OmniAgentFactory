{% schema %}
{
  'name': 'announcement-bar',
  'settings': [
    {
      'type': 'text',
      'id': 'heading',
      'label': 'Heading',
      'default': 'Promo Message'
    },
    {
      'type': 'text',
      'id': 'subheading',
      'label': 'Subheading',
      'default': 'Get 10% off your first order'
    },
    {
      'type': 'text',
      'id': 'cta_label',
      'label': 'Button label',
      'default': 'Shop Now'
    },
    {
      'type': 'url',
      'id': 'cta_url',
      'label': 'Button URL'
    }
  ],
  'presets': [
    {
      'name': 'Default Announcement Bar'
    }
  ]
}
{% endschema %}

<!-- Announcement Bar Section -->
<div class="announcement-bar bg-primary text-white py-4 text-center" role="complementary">
  <h2>{{ section.settings.heading }}</h2>
  <p>{{ section.settings.subheading }}</p>
  <a class="btn btn-light" href="{{ section.settings.cta_url }}" role="button">
    {{ section.settings.cta_label }}
  </a>
</div>