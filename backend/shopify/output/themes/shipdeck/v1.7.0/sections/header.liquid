{% schema %}
{
  'name': 'header',
  'settings': [
    {
      'type': 'image_picker',
      'id': 'logo',
      'label': 'Logo'
    },
    {
      'type': 'range',
      'id': 'logo_width',
      'min': 80,
      'max': 300,
      'step': 10,
      'unit': 'px',
      'label': 'Logo width',
      'default': 150
    },
    {
      'type': 'link_list',
      'id': 'menu',
      'label': 'Navigation menu',
      'default': 'main-menu'
    }
  ],
  'presets': [
    {
      'name': 'Default Header'
    }
  ]
}
{% endschema %}

<!-- Header Section -->
<header class="sticky-top bg-light" role="banner">
  <nav class="container">
    <div class="row align-items-center justify-content-between">
      <div class="col-md-3">
        <img src="{{ section.settings.logo | image_url: width: 150 }}" alt="{{ shop.name }}" class="img-fluid logo" style="width: {{ section.settings.logo_width }}px;">
      </div>
      <div class="col-md-6 text-center">
        <ul>
          {{ section.settings.menu | link_list: max_link_width: 300 | escape }}
        </ul>
      </div>
      <div class="col-md-3 text-right">
        <button class="btn btn-light d-md-none" aria-label="Toggle navigation" type="button">
          <span class="sr-only">Toggle navigation</span>
          <span class="navbar-toggler-icon"></span>
        </button>
        <button class="btn btn-light d-none d-md-inline" aria-label="Toggle cart" type="button">
          <span class="sr-only">Toggle cart</span>
          <i class="bi bi-bag"></i>
        </button>
        <form role="search" method="get" action="{{ routes.search_url }}">
          <div class="input-group input-group-sm">
            <input type="search" class="form-control" name="q" placeholder="Search" value="{{ search_query }}" aria-label="Search">
            <button class="btn btn-light" type="submit" aria-label="Search">
              <i class="bi bi-search"></i>
            </button>
          </div>
        </form>
      </div>
    </div>
  </nav>
</header>