<section class="page-hero" aria-label="Page hero with image and headline">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-12 col-md-8">
        <div class="page-hero-image" style="background-image: url('{{ section.settings.image | image_url: width: 1200 | image_tag }}')"></div>
        <h1>{{ section.settings.heading }}</h1>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Page hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Page Title"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}