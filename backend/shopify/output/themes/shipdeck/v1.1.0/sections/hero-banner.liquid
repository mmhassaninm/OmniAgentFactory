<!-- Hero Banner Section -->
<section role="region" aria-label="Hero Banner" class="hero-banner" style="background-image: url({{ section.settings.image | image_url: width: 1200 }}); background-position: center; background-size: cover; background-repeat: no-repeat; height: 100vh; display: flex; flex-direction: column; justify-content: flex-end; padding: 2rem;">
  <div class="container">
    <h1>{{ section.settings.heading }}</h1>
    <h2>{{ section.settings.subheading }}</h2>
    <a href="{{ section.settings.cta_url }}" class="btn btn-primary">{{ section.settings.cta_label }}</a>
  </div>
</section>

{% schema %}
{
  "name": "hero-banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Welcome to Shipdeck"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Shop now and get free shipping on orders over $149"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}