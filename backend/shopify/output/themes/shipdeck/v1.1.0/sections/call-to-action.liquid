<!-- Call to Action Section -->
<section role="region" aria-label="Call to Action" class="call-to-action">
  <div class="container">
    <h2>{{ section.settings.heading }}</h2>
    <h3>{{ section.settings.subheading }}</h3>
    <a href="{{ section.settings.cta_url }}" class="btn btn-primary">{{ section.settings.cta_label }}</a>
  </div>
</section>

{% schema %}
{
  "name": "call-to-action",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "New Arrivals"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Shop our latest products"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    }
  ],
  "presets": [
    {
      "name": "Call to Action"
    }
  ]
}
{% endschema %}