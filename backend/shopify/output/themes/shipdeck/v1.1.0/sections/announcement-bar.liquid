<section class="announcement-bar" role="alert" aria-label="{% t 'announcements' %}">
  <div class="container">
    <div class="announcement-bar__content">
      <h4 class="announcement-bar__heading">{{ heading | escape }}</h4>
      <p class="announcement-bar__subheading">{{ subheading | escape }}</p>
      <a href="{% if settings.button_link %}{{ settings.button_link }}{% else %}{{ 'button.url' | shopify_link }}{% endif %}" class="announcement-bar__button{% if settings.button_link %} link{% endif %}">{{ 'button.caption' | t }}</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "announcement-bar",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Announcement"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Shop now and get free shipping on orders over $149"
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar"
    }
  ],
  "responsive_notes": "Stack vertically on mobile"
}
{% endschema %}