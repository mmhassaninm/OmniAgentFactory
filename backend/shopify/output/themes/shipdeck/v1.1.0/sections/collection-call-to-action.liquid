{% schema %}
{
  "name": "Collection Call to Action",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Explore"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Browse our collection"
    }
  ],
  "presets": [
    {
      "name": "Default"
    }
]
}{% endschema %}

<div role='banner' aria-label='Collection Call to Action' class='section call-to-action'>
  <div class='container'>
    <h2>{{ heading | escape }}</h2>
    <p>{{ subheading | escape }}</p>
    <a href='#' class='btn'>Explore</a>
  </div>
</div>

<style>
  .call-to-action {
    background: {{ settings.bg_color | color }};
    color: {{ settings.text_color | color }};
    padding: 2rem;
  }

  @media (max-width: 768px) {
    .call-to-action {
      flex-direction: column;
    }
  }
</style>