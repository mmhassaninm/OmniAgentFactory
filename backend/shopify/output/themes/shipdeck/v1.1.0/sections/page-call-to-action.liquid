{% schema %}
{
  "name": "Page Call to Action",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Contact Us"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Get in touch with us"
    }
  ],
  "presets": [
    {
      "name": "CTA Banner"
    }
  ],
  "blocks": []
}
{% endschema %}

<div class="page-call-to-action" style="background-color: {{ settings.bg | color }}">
  <div class="container">
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.subheading }}</p>
    <a href="#" class="button">Get in touch</a>
    <p>Responsive notes: Stack vertically on mobile</p>
  </div>
</div>