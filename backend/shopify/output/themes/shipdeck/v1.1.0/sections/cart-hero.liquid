{% schema %}
{
  "name": "Cart Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your Cart"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
]
}{% endschema %}

<div role='banner' aria-label='Cart Hero' class='section hero-banner'>
  <div class='container'>
    <img src="{{ image | image_url: width: 1200 | alt: heading }}" alt="{{ heading | escape }}" class='hero-image'/>
    <h2>{{ heading | escape }}</h2>
  </div>
</div>

<style>
  .hero-banner {
    background: {{ settings.bg_color | color }};
    color: {{ settings.text_color | color }};
    padding: 2rem;
  }

  .hero-image {
    width: 100%;
    height: 100vh;
    object-fit: cover;
  }

  @media (max-width: 768px) {
    .hero-image {
      height: auto;
    }
  }
</style>