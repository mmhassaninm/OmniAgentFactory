{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 80,
      "max": 300,
      "step": 10,
      "unit": "px",
      "label": "Logo width",
      "default": 150
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    }
  ],
  "presets": [
    {
      "name": "Main Navigation"
    }
  ],
  "blocks": []
}
{% endschema %}

<header class="header" style="background-color: {{ settings.bg | color }}">
  <div class="container">
    <nav class="nav">
      <div class="logo" style="width: {{ settings.logo_width }}px">
        <a href="#"><img src="{{ section.settings.logo | image_url: width: 1200 | image_tag }}" alt="{{ section.settings.logo | escape }}"></a>
      </div>
      <div class="menu">
        <ul>
          {% for link in section.settings.menu %}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {% endfor %}
        </ul>
      </div>
      <div class="search-cart">
        <div class="search">
          <input type="search" placeholder="Search">
          <button type="submit"></button>
        </div>
        <div class="cart">
          <a href="#"><i class="fa fa-shopping-cart"></i> Cart</a>
        </div>
      </div>
    </nav>
  </div>
  <div class="hamburger" style="background-color: {{ settings.bg | color }}">
    <div class="bar"></div>
    <div class="bar"></div>
    <div class="bar"></div>
  </div>
  <p>Responsive notes: Collapse menu to hamburger on mobile</p>
</header>