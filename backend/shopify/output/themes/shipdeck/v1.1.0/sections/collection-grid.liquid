{% schema %}
{
  "name": "Collection Grid",
  "settings": [
    {
      "type": "product_list",
      "id": "products",
      "label": "Collection products"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "product",
      "settings": [
        {
          "type": "product_picker",
          "id": "product_id",
          "label": "Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Default"
    }
]
}{% endschema %}

<div role='main' aria-label='Collection Grid' class='section collection-grid'>
  <div class='container'>
    <h2>Collection Grid</h2>
    <div class='grid'>
      {% for product in products %}
        <div class='grid-item'>
          <img src="{{ product.image | image_url: width: 400 | alt: product.title }}" alt="{{ product.title | escape }}" class='thumb'/>
          <h3>{{ product.title | escape }}</h3>
          <p>{{ product.price | money }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

<style>
  .collection-grid {
    background: {{ settings.bg_color | color }};
    color: {{ settings.text_color | color }};
    padding: 2rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
  }

  .grid-item {
    cursor: pointer;
  }

  @media (max-width: 768px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>