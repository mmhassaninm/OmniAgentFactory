<!-- Product Hero Section -->
<section role="region" aria-label="Product Hero" class="product-hero" style="background-image: url({{ section.settings.image | image_url: width: 1200 }}); background-position: center; background-size: cover; background-repeat: no-repeat; height: 100vh; display: flex; flex-direction: column; justify-content: flex-end; padding: 2rem;">
  <div class="container">
    <h1>{{ section.settings.heading }}</h1>
  </div>
</section>

{% schema %}
{
  "name": "product-hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Product image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Product name"
    }
  ],
  "presets": [
    {
      "name": "Product Hero"
    }
  ]
}
{% endschema %}