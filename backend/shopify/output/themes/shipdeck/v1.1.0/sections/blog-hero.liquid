
{% schema %}
{
  "name": "Blog hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Blog"
    }
  ],
  "presets": [
    {
      "name": "Default"
    }
  ],
  "blocks": []
}
{% endschema %}

<div class="blog-hero">
  <div class="background-image" style="background-image: url('{{ section.settings.image | image_url: width: 1200 | escape }}');"></div>
  <h1>{{ section.settings.heading | escape }}</h1>
</div>
