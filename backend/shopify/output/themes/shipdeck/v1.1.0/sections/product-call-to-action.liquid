{% schema %}
{
  "name": "Product Call to Action",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Add to Cart"
    }
  ],
  "presets": [
    {
      "name": "Default"
    }
]
}{% endschema %}

<div role='banner' aria-label='Call to Action' class='section call-to-action'>
  <div class='container'>
    <h2>{{ heading | escape }}</h2>
    <a href='#' class='btn'>Add to Cart</a>
  </div>
</div>

<style>
  .call-to-action {
    background: {{ settings.bg_color | color }};
    color: {{ settings.text_color | color }};
    padding: 2rem;
  }

  @media (max-width: 768px) {
    .call-to-action {
      flex-direction: column;
    }
  }
</style>