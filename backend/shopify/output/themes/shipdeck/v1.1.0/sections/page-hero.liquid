{% schema %}
{
  "name": "Page Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Page name"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ],
  "blocks": []
}
{% endschema %}

<section class="page-hero" style="background-image: {{ section.settings.image | image_url: width: 1200 | image_tag }}">
  <div class="container">
    <h1>{{ section.settings.heading }}</h1>
    <p>Responsive notes: Use full-width image on mobile</p>
  </div>
</section>