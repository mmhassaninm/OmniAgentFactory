<section class="blog-hero" role="region" aria-label="Blog Hero">{% schema %}
{
  "name": "blog-hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Blog image"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Blog title"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Blog description"
    }
  ],
  "presets": [
    {
      "name": "Blog Hero"
    }
  ]
}{% endschema %}
<div class="container">
  <div class="row">
    <div class="col-12">
      <h2>{{ section.settings.title | escape }}</h2>
      <p>{{ section.settings.description | escape }}</p>
      <img src="{{ section.settings.image | image_url: width: 800 | alt: section.settings.title | escape }}" alt="{{ section.settings.title | escape }}"/>;
    </div>
  </div>
</div>

{% if section.settings.image %}
<div class="hero-image" style="background-image: url('{{ section.settings.image | image_url: width: 1200 | alt: section.settings.title | escape }}');"></div>
{% endif %}<style>
.blog-hero { display: flex; justify-content: center; align-items: center; }
.blog-hero .hero-image { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background-size: cover; background-position: center; }
</style>