{% schema %}
{
  'name': 'Page Hero',
  'settings': [
    {
      'type': 'image_picker',
      'id': 'image',
      'label': 'Page image'
    },
    {
      'type': 'text',
      'id': 'title',
      'label': 'Page title'
    },
    {
      'type': 'text',
      'id': 'description',
      'label': 'Page description'
    }
  ],
  'presets': [
    {
      'name': 'Hero Banner'
    }
  ],
  'default_settings': {
    'image': null,
    'title': '',
    'description': ''
  }
}
{% endschema %}

<section class="page-hero">
  <div class="hero">
    <img src="{{ section.settings.image | image_url: width: 1200 | image_tag }}" alt="{{ section.settings.title }}">
    <h1>{{ section.settings.title }}</h1>
    <p>{{ section.settings.description }}</p>
  </div>
</section>