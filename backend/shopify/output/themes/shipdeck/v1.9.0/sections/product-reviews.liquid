<section class="product-reviews" role="region">
  <div class="container">
    <h2>{{ section.settings.title | escape }}</h2>
    <div class="product-reviews-container">
      {% for review in reviews %}
        {% include 'review.liquid' %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product Reviews",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Reviews title"
    },
    {
      "type": "text",
      "id": "testimonial",
      "label": "Testimonial"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "rating",
          "id": "rating",
          "label": "Rating"
        },
        {
          "type": "text",
          "id": "reviewer",
          "label": "Reviewer"
        },
        {
          "type": "text",
          "id": "review",
          "label": "Review"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Reviews"
    }
  ],
  "responsive_notes": "Hide reviews on mobile"
}
{% endschema %}