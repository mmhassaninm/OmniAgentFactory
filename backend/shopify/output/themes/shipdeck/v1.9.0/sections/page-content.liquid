{% schema %}
{
  'name': 'Page Content',
  'settings': [
    {
      'type': 'text',
      'id': 'heading',
      'label': 'Page heading',
      'default': 'Our Story'
    }
  ],
  'blocks': [
    {
      'type': 'text_block',
      'name': 'Text Block',
      'settings': [
        {
          'type': 'text',
          'id': 'text',
          'label': 'Text'
        }
      ]
    }
  ],
  'presets': [
    {
      'name': 'Content Section'
    }
  ],
  'default_settings': {
    'heading': 'Our Story'
  }
}
{% endschema %}

<section class="page-content">
  <div class="content">
    <h1>{{ section.settings.heading }}</h1>
    {% for block in section.blocks %}
      {{ block.settings.text | escape }}
    {% endfor %}
  </div>
</section>