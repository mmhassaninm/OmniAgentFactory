{% schema %}
{
  'name': 'Blog Grid',
  'settings': [
    {
      'type': 'range',
      'id': 'blog_grid_columns',
      'min': 2,
      'max': 5,
      'step': 1,
      'unit': 'columns',
      'label': 'Grid columns',
      'default': 3
    },
    {
      'type': 'text',
      'id': 'grid_heading',
      'label': 'Grid heading',
      'default': 'Our Blog'
    }
  ],
  'presets': [
    {
      'name': 'Grid Layout'
    }
  ],
  'blocks': [
    {
      'type': 'blog_post',
      'name': 'Blog Post',
      'settings': [
        {
          'type': 'image_picker',
          'id': 'image',
          'label': 'Blog post image'
        },
        {
          'type': 'text',
          'id': 'title',
          'label': 'Blog post title'
        },
        {
          'type': 'text',
          'id': 'cta_label',
          'label': 'Button label',
          'default': 'Read More'
        }
      ]
    }
  ],
  'default_settings': {
    'blog_grid_columns': 3,
    'grid_heading': 'Our Blog'
  }
}
{% endschema %}

<section class="blog-grid">
  <div class="grid">
    {% for post in section.settings.blog_grid_columns %}
      <div class="grid-item">
        <img src="{{ post.image | image_url: width: 400 | image_tag }}" alt="{{ post.title }}">
        <h2>{{ post.title }}</h2>
        <p>{{ post.text }}</p>
        <a href="{{ post.url }}" class="btn">{{ post.cta_label }}</a>
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  'name': 'Blog Post',
  'settings': [
    {
      'type': 'image_picker',
      'id': 'image',
      'label': 'Blog post image'
    },
    {
      'type': 'text',
      'id': 'title',
      'label': 'Blog post title'
    },
    {
      'type': 'text',
      'id': 'text',
      'label': 'Blog post text'
    },
    {
      'type': 'text',
      'id': 'cta_label',
      'label': 'Button label',
      'default': 'Read More'
    },
    {
      'type': 'text',
      'id': 'url',
      'label': 'Button URL'
    }
  ],
  'default_settings': {
    'image': null,
    'title': '',
    'text': '',
    'cta_label': 'Read More',
    'url': ''
  }
}
{% endschema %}

{% if section.settings.blog_grid_columns > 1 %}
  <div class="grid">
    {% for post in collection.all.limit(section.settings.blog_grid_columns) %}
      <div class="grid-item">
        <img src="{{ post.image | image_url: width: 400 | image_tag }}" alt="{{ post.title }}">
        <h2>{{ post.title }}</h2>
        <p>{{ post.text }}</p>
        <a href="{{ post.url }}" class="btn">{{ post.cta_label }}</a>
      </div>
    {% endfor %}
  </div>
{% else %}
  <div class="list-view">
    {% for post in collection.all %}
      <div class="list-item">
        <img src="{{ post.image | image_url: width: 400 | image_tag }}" alt="{{ post.title }}">
        <h2>{{ post.title }}</h2>
        <p>{{ post.text }}</p>
        <a href="{{ post.url }}" class="btn">{{ post.cta_label }}</a>
      </div>
    {% endfor %}
  </div>
{% endif %}