<section class="cart-items" role="region" aria-label="Cart Items">{% schema %}
{
  "name": "cart-items",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Cart heading",
      "default": "Your Cart"
    }
  ],
  "blocks": [
    {
      "type": "cart_item",
      "name": "Cart Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Product image"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price"
        },
        {
          "type": "text",
          "id": "quantity",
          "label": "Quantity"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Cart Items"
    }
  ]
}{% endschema %}
<div class="container">
  <div class="row">
    <div class="col-12">
      <h2>{{ section.settings.heading | escape }}</h2>
      <ul>
        {% for block in section.blocks %}
          <li>
            <div class="cart-item">
              <img src="{{ block.settings.image | image_url: width: 400 | alt: block.settings.name | escape }}" alt="{{ block.settings.name | escape }}"/>;
              <p>{{ block.settings.name | escape }}</p>
              <p>Price: {{ block.settings.price | money }}</p>
              <p>Quantity: {{ block.settings.quantity | escape }}</p>
            </div>
          </li>
        {% endfor %}
      </ul>
    </div>
  </div>
</div>

<style>
.cart-items { display: flex; justify-content: center; align-items: center; }
.cart-item { display: flex; flex-direction: column; justify-content: center; align-items: center; padding: 20px; border: 1px solid #ddd; border-radius: 10px; box-shadow: 0 0 10px rgba(0, 0, 0, 0.1); }
</style>