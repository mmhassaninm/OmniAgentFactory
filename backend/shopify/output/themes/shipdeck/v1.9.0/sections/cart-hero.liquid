<section class="cart-hero" role="region" aria-label="Cart Hero">{% schema %}
{
  "name": "cart-hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Cart image"
    },
    {
      "type": "text",
      "id": "total",
      "label": "Subtotal"
    },
    {
      "type": "text",
      "id": "shipping",
      "label": "Shipping"
    }
  ],
  "presets": [
    {
      "name": "Cart Hero"
    }
  ]
}{% endschema %}
<div class="container">
  <div class="row">
    <div class="col-12">
      <h2>Cart</h2>
      <p>Subtotal: {{ section.settings.total | money }}</p>
      <p>Shipping: {{ section.settings.shipping | money }}</p>
      <img src="{{ section.settings.image | image_url: width: 800 | alt: 'Cart' | escape }}" alt="Cart"/>;
    </div>
  </div>
</div>

{% if section.settings.image %}
<div class="hero-image" style="background-image: url('{{ section.settings.image | image_url: width: 1200 | alt: 'Cart' | escape }}');"></div>
{% endif %}<style>
.cart-hero { display: flex; justify-content: center; align-items: center; }
.cart-hero .hero-image { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background-size: cover; background-position: center; }
</style>