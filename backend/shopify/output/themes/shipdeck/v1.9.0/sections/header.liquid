{% schema %}
{
  'name': 'Header',
  'settings': [
    {
      'type': 'image_picker',
      'id': 'logo',
      'label': 'Logo'
    },
    {
      'type': 'range',
      'id': 'logo_width',
      'min': 80,
      'max': 300,
      'step': 10,
      'unit': 'px',
      'label': 'Logo width',
      'default': 150
    },
    {
      'type': 'link_list',
      'id': 'menu',
      'label': 'Navigation menu',
      'default': 'main-menu'
    }
  ],
  'presets': [
    {
      'name': 'Sticky Header'
    }
  ],
  'default_settings': {
    'logo': null,
    'logo_width': 150,
    'menu': 'main-menu'
  }
}
{% endschema %}

<header class="header">
  <nav class="nav">
    <a href="#" class="logo">
      <img src="{{ section.settings.logo | image_url: width: 1200 | image_tag }}" alt="{{ shop.name }}">
    </a>
    <ul>
      {% for link in section.settings.menu.links %}
        <li>
          <a href="{{ link.url }}"{% if link.active %} class="active"{% endif %}>{{ link.name }}</a>
        </li>
      {% endfor %}
    </ul>
    <button class="hamburger" aria-label="Toggle Navigation">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </nav>
</header>