<section class="product-grid" role="region">
  <div class="container">
    <h2>{{ section.settings.product_grid_heading | escape }}</h2>
    <div class="product-grid-container">
      {% for product in collection.products %}
        {% include 'product-card.liquid' %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product Grid",
  "settings": [
    {
      "type": "range",
      "id": "product_grid_columns",
      "min": 2,
      "max": 5,
      "step": 1,
      "unit": "columns",
      "label": "Grid columns",
      "default": 3
    },
    {
      "type": "text",
      "id": "product_grid_heading",
      "label": "Grid heading",
      "default": "Our Products"
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Product image"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price"
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "Button label",
          "default": "Buy Now"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Grid"
    }
  ],
  "responsive_notes": "Change grid to list view on mobile"
}
{% endschema %}