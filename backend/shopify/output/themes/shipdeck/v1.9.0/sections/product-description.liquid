<section class="product-description" role="region">
  <div class="container">
    <h2>{{ section.settings.description | escape }}</h2>
    <p>{{ section.settings.features | escape }}</p>
  </div>
</section>

{% schema %}
{
  "name": "Product Description",
  "settings": [
    {
      "type": "text",
      "id": "description",
      "label": "Product description"
    },
    {
      "type": "text",
      "id": "features",
      "label": "Product features"
    }
  ],
  "presets": [
    {
      "name": "Product Description"
    }
  ],
  "blocks": [],
  "responsive_notes": "Hide features on mobile"
}
{% endschema %}