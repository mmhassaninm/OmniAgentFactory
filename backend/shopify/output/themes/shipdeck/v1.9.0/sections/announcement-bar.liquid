<section role="region" aria-label="Announcement bar" class="announcement-bar">
  <div class="container">
    <div class="announcement-bar__content">
      <h2>{{ setting.heading }}</h2>
      <p>{{ setting.message }}</p>
      <a href="{{ setting.cta_url }}" class="btn btn--primary">Shop Now</a>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "announcement-bar",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Limited Time Offer"
    },
    {
      "type": "text",
      "id": "message",
      "label": "Message",
      "default": "Get 10% off your first purchase!"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    }
  ],
  "presets": [
    {
      "name": "Default"
    }
  ],
  "defaults": [
    {
      "heading": "Limited Time Offer",
      "message": "Get 10% off your first purchase!"
    }
  ]
}
{% endschema %}