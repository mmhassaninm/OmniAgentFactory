<section class="product-hero" role="region">
  <div class="container">
    <img src="{{ section.settings.image | image_url: width: 1200 }}" alt="{{ section.settings.image.alt | escape }}" class="background-image">
    <h1>{{ product.name }}</h1>
    <p>{{ product.price | money }}</p>
  </div>
</section>

{% schema %}
{
  "name": "Product Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Product image"
    },
    {
      "type": "text",
      "id": "name",
      "label": "Product name"
    },
    {
      "type": "price",
      "id": "price",
      "label": "Price"
    }
  ],
  "presets": [
    {
      "name": "Product Hero"
    }
  ],
  "blocks": [],
  "responsive_notes": "Reduce hero height to 60vh on mobile"
}
{% endschema %}