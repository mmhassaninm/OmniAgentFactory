<section class="blog-grid" aria-label="Blog grid"><div class="container"><div class="blog-grid__inner"><h2 class="blog-grid__title">{{ t('Blog posts') }}</h2><ul class="blog-grid__list" aria-label="Blog posts list"><% for post in collection.items limit: settings.post_count %><li class="blog-grid__item" aria-label="Blog post item"><article class="blog-grid__article"><img class="blog-grid__image" src="{{ post.image | image_url: width: 1200 | image_tag }}" alt="{{ post.image.alt }}"><h3 class="blog-grid__title">{{ post.title }}</h3><p class="blog-grid__excerpt">{{ post.excerpt }}</p></article></li><% endfor %></ul></div></div></section>{% schema %}{% assigns settings = settings %}{% schema %}name: 'Blog grid'settings: [  {type: 'collection', id: 'collection_id', label: 'Blog collection'},  {type: 'range', id: 'post_count', min: 2, max: 6, step: 1, unit: '', label: 'Number of posts'},  {type: 'color', id: 'background_color', label: 'Background color'},  {type: 'color', id: 'text_color', label: 'Text color'}]%}{% presets %}{% preset 'Hero Banner' %}{% endpresets %}{% endschema %}