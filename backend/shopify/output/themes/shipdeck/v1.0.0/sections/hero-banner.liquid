<section class="hero-banner" role="region" aria-label="Hero Banner">{% comment %} Hero Banner Section {% endcomment %}{% schema %}{% assigns settings = {image: '', heading: 'Welcome', subheading: '', cta_label: 'Shop Now', cta_url: ''} %}{% if settings.image %}<div style="background-image: url('{{ settings.image | image_url: width: 1200 }}');" class="background-image"></div>{% endif %}<div class="container"><h1>{{ settings.heading | escape }}{% if settings.subheading %}<p>{{ settings.subheading | escape }}</p>{% endif %}<a href="{{ settings.cta_url }}" class="button">{{ settings.cta_label | escape }}</a></h1></div>{% schema %}{% endschema %}