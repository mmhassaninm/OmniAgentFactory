<section class="cart-items" aria-label="Cart items"><div class="container"><div class="cart-items__inner"><h2 class="cart-items__title">{{ t('Cart items') }}</h2><ul class="cart-items__list" aria-label="Cart items list"><% for item in cart.items %><li class="cart-item" aria-label="Cart item"><article class="cart-item__inner"><img class="cart-item__image" src="{{ item.image | image_url: width: 1200 | image_tag }}" alt="{{ item.image.alt }}"><h3 class="cart-item__title">{{ item.title }}</h3><p class="cart-item__price">{{ item.price | money }}</p><p class="cart-item__quantity">{{ item.quantity }}</p><button class="cart-item__remove" onclick="{%- if settings.collection_id %}remove_from_cart('{{ settings.collection_id }}', '{{ item.id }}');{% endif %}">{{ t('Remove from cart') }}</button></article></li><% endfor %></ul></div></div></section>{% schema %}{% assigns settings = settings %}{% schema %}name: 'Cart items'settings: [  {type: 'collection', id: 'collection_id', label: 'Cart collection'},  {type: 'text', id: 'title', label: 'Cart items title'},  {type: 'collection', id: 'collection_id', label: 'Cart collection'},  {type: 'range', id: 'quantity_range', min: 1, max: 10, step: 1, unit: '', label: 'Number of items to display'},  {type: 'color', id: 'background_color', label: 'Background color'},  {type: 'color', id: 'text_color', label: 'Text color'}]%}{% presets %}{% preset 'Hero Banner' %}{% endpresets %}{% endschema %}