<div class="container"><div class="row align-items-center"><div class="col-12"><p class="h4">{{ section.settings.heading }}</p><p>{{ section.settings.description }}</p><button type="button" class="btn btn-secondary" aria-label="{{ 'announcement.dismiss' | t }}" onclick="setTimeout(() => { document.querySelector('.announcement-bar').style.display = 'none'; }, {{ section.settings.dismiss_countdown }} * 1000);">{{ 'announcement.dismiss' | t }}</button></div></div></div>{% schema %}{% assign presets = ['Default Announcement'] %}{% schema %}