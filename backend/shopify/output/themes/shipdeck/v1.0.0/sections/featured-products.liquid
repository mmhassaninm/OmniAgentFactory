<section class="featured-products" role="region" aria-label="Featured Products">{% comment %} Featured Products Section {% endcomment %}{% schema %}{% assigns settings = {collection_id: '', product_count: 4} %}{% assign products = collection.products | limit: settings.product_count %}{% if products %}<div class="grid"><ul class="products">{% for product in products %}<li class="product-grid-item"><a href="{{ product.url }}"><img src="{{ product.image | image_url: width: 400 }}" alt="{{ product.title }}" class="product-image"><h2 class="product-title">{{ product.title }}</h2><p class="product-price">{{ product.price | money }}</p></a></li>{% endfor %}</ul></div>{% endif %}{% schema %}{% endschema %}