<section class="cart-call-to-action" aria-label="Proceed to checkout"><div class="container"><div class="cart-call-to-action__inner"><a class="cart-call-to-action__button" href="{{ settings.checkout_url }}" onclick="{%- if settings.checkout_url %}location.href = '{{ settings.checkout_url }}';{% endif %}">{{ t('Proceed to checkout') }}</a></div></div></section>{% schema %}{% assigns settings = settings %}{% schema %}name: 'Cart call to action'settings: [  {type: 'url', id: 'checkout_url', label: 'Checkout URL'}]%}{% presets %}{% preset 'Hero Banner' %}{% endpresets %}{% endschema %}