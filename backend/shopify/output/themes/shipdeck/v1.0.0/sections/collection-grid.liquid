
{% schema %}
{
  "name": "Collection Grid",
  "settings": [
    {
      "type": "collection",
      "id": "collection_id",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "product_count",
      "min": 2,
      "max": 6,
      "step": 1,
      "unit": "",
      "label": "Number of products",
      "default": 4
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product Grid Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Product image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Product title"
        },
        {
          "type": "price",
          "id": "price",
          "label": "Product price"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Default Grid"
    }
  ]
}
{% endschema %}

<div class="collection-grid">
  <div class="container">
    <div class="row">
      {% for block in blocks %}
        <div class="col-md-3">
          <div class="product-grid-item">
            <img src="{{ block.settings.image | image_url: width: 400 }}" alt="{{ block.settings.title }}"/>
            <h2>{{ block.settings.title }}</h2>
            <p>{{ block.settings.price }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>
