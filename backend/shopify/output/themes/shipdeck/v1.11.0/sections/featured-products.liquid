<section class="container mx-auto py-12 lg:py-20" role="region" aria-label="Featured Products">
  <div class="max-w-7xl mx-auto text-center">
    <h2 class="text-3xl font-bold text-gray-900 sm:text-4xl" data-aos="fade-up">Featured Products</h2>
    <div class="grid grid-cols-1 gap-4 lg:grid-cols-{{ section.settings.product_count }} gap-4 lg:gap-6" data-aos="fade-up">
      {% for product in section.blocks.product %}
        <div class="group relative cursor-pointer hover:shadow-md transition duration-300 ease-in-out">
          <img src="{{ product.settings.product_image | image_url: width: 400 | image_tag }}" alt="{{ product.settings.product_image | escape }}" class="object-cover object-center h-64 w-full group-hover:scale-110 transition duration-300 ease-in-out">
          <div class="bg-gray-900 bg-opacity-50 absolute bottom-0 left-0 w-full h-full p-4 text-white text-lg font-light transition duration-300 ease-in-out group-hover:scale-100">
            <h3 class="text-2xl font-bold mb-2">{{ product.settings.product_name }}</h3>
            <p class="text-lg">{{ product.settings.product_description }}</p>
            <p class="text-lg font-bold">{{ product.settings.product_price }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>{% schema %}
{
  "name": "Featured Products",
  "settings": [
    {
      "type": "number",
      "id": "product_count",
      "min": 1,
      "max": 4,
      "step": 1,
      "label": "Number of products",
      "default": 4
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product_picker",
          "id": "product_id",
          "label": "Product ID"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Products"
    }
  ]
}{% endschema %}