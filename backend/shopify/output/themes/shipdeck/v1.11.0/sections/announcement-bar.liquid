<div id="announcement-bar" class="announcement-bar" style="background-color: #{{ primary | color_to_rgb }};"><h2>{{ heading | escape }}</h2><p>{{ subheading | escape }}</p><button onclick="window.location.href = '{{ cta_url | escape }}'">{{ cta_label | escape }}</button></div>{% schema %}
  {
    "name": "announcement-bar",
    "settings": [
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Exclusive Offer"
      },
      {
        "type": "text",
        "id": "subheading",
        "label": "Subheading",
        "default": "Get 10% off your first purchase"
      },
      {
        "type": "text",
        "id": "cta_label",
        "label": "Button label",
        "default": "Shop Now"
      },
      {
        "type": "url",
        "id": "cta_url",
        "label": "Button URL"
      }
    ],
    "presets": [
      {
        "name": "Default"
      }
    ]
  }{% endschema %}