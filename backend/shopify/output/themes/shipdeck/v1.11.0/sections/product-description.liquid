<section class="container mx-auto py-12 lg:py-20" role="region" aria-label="Product Description">
  <div class="max-w-7xl mx-auto text-center">
    <h2 class="text-3xl font-bold text-gray-900 sm:text-4xl">{{ product.name }}</h2>
    <p class="text-lg font-light text-gray-600 sm:text-xl">{{ section.settings.description }}</p>
  </div>
</section>{% schema %}
{
  "name": "Product Description",
  "settings": [
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": ""
    }
  ],
  "presets": [
    {
      "name": "Product Description"
    }
  ]
}{% endschema %}