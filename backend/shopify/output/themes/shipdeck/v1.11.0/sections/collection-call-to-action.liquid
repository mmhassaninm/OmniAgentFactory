{% schema %}
  name: 'collection_call_to_action'
  label: 'Collection Call to Action'
  settings:
    - type: 'text'
      id: 'heading'
      label: 'Heading'
      default: 'Shop the Collection'
    - type: 'text'
      id: 'subheading'
      label: 'Subheading'
      default: 'Browse our curated selection of products'
    - type: 'text'
      id: 'cta_label'
      label: 'Button Label'
      default: 'Shop Now'
    - type: 'url'
      id: 'cta_url'
      label: 'Button URL'
  section: 'collection-call-to-action'
  responsive_notes: 'Increase font size on mobile for better readability'
  {% endschema %}

  <style>
    /* Minimal theme styles */
    .collection-call-to-action {
      text-align: center;
      padding: 20px;
    }
  </style>

  <div class='collection-call-to-action'>
    <h1>{{ settings.heading }}</h1>
    <p>{{ settings.subheading }}</p>
    <a href '{{ settings.cta_url }}' class='btn'>
      {{ settings.cta_label }}
    </a>
  </div>