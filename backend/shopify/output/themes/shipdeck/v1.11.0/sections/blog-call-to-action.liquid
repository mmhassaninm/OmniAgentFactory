<div class="blog-call-to-action">
  <h2>{{ settings.heading }}</h2>
  <p>{{ settings.subheading }}</p>
  <button>{{ settings.cta_label }}</button>
</div>
{% schema %}
{
  "name": "blog-call-to-action",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Read More"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Catch up on the latest news and updates"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Read More"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    }
  ],
  "presets": [
    {
      "name": "Default"
    }
  ]
}
{% endschema %}