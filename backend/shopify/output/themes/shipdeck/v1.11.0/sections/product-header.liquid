<section class="container mx-auto py-12 lg:py-20" role="region" aria-label="Product Header">
  <div class="max-w-7xl mx-auto text-center">
    <div class="flex justify-center mb-4">
      <img src="{{ section.settings.image | image_url: width: 1200 | image_tag }}" alt="{{ section.settings.image | escape }}" class="object-cover object-center w-48 h-48">
    </div>
    <p class="text-lg font-light text-gray-600 sm:text-xl">{{ product.price }}</p>
    <h2 class="text-3xl font-bold text-gray-900 sm:text-4xl">{{ product.title }}</h2>
  </div>
</section>{% schema %}
{
  "name": "Product Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Product image"
    }
  ],
  "presets": [
    {
      "name": "Product Header"
    }
  ]
}{% endschema %}