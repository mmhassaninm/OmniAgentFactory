<div class="cart-items">
  <h2>Cart Items</h2>
  <div class="cart-item-list">{% for block in blocks %}
    {% if block.settings.product_id %}
      <div class="cart-item">
        <h3>{{ block.settings.product_id }}</h3>
      </div>
    {% endif %}
  {% endfor %}
  </div>
  <p>Number of items: {{ settings.item_count }}</p>
</div>
{% schema %}
{
  "name": "cart-items",
  "settings": [
    {
      "type": "number",
      "id": "item_count",
      "min": 1,
      "max": 10,
      "step": 1,
      "label": "Number of items",
      "default": 5
    }
  ],
  "blocks": [
    {
      "type": "cart_item",
      "name": "Cart Item",
      "settings": [
        {
          "type": "product_picker",
          "id": "product_id",
          "label": "Product ID"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Default"
    }
  ]
}
{% endschema %}