<section class="container mx-auto py-12 lg:py-20" role="banner" aria-label="Hero Banner">
  <div class="max-w-7xl mx-auto text-center">
    <img src="{{ section.settings.image | image_url: width: 1200 | image_tag }}" alt="Hero Background Image" class="w-full object-cover lg:h-80 object-center">
    <h1 class="text-4xl font-bold text-gray-900 sm:text-5xl" data-aos="fade-up">{{ section.settings.heading }}</h1>
    <p class="text-lg font-light text-gray-600 sm:text-xl" data-aos="fade-up">{{ section.settings.subheading }}</p>
    <a href="{{ section.settings.cta_url }}" class="bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded" data-aos="fade-up">{{ section.settings.cta_label }}</a>
  </div>
</section>{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Welcome to Shipdeck"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Your one-stop shop for unique gifts"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}{% endschema %}