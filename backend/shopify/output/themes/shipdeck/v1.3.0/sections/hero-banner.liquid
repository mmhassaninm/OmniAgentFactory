<section class="hero-banner" style="background-image: url('{{ section.settings.image | image_url: width: 1200 }}'); background-size: cover; background-position: center; display: flex; justify-content: center; align-items: center; height: 100vh;" role="region" aria-label="Hero banner"><div style="text-align: center;"><h1>{{ section.settings.heading | escape }}</h1><h2>{{ section.settings.subheading | escape }}</h2><a href="{{ section.settings.cta_url | escape }}" class="button" role="button" aria-label="Explore now">{{ section.settings.cta_label | escape }}</a></div></section>{% schema %}{% schema.name 'Hero Banner' %}{% schema.settings %}[{{ section.settings }}]{% endschema %}