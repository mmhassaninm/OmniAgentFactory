{% schema %}
{
  "name": "Product Variants",
  "settings": [
    {
      "type": "select",
      "id": "variant",
      "label": "Variant",
      "options": [
        "size",
        "color"
      ]
    }
  ],
  "presets": [
    {
      "name": "Default"
    }
  ]
}
{% endschema %}

<div class="product-variants">
  <h2>Choose a {{ variant }}</h2>
  <p>Price: {{ product.price | money }}</p>
  <p>Availability: {{ product.available }}</p>
</div>