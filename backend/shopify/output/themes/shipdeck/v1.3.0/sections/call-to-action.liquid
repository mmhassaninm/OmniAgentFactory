<section class="call-to-action" role="region" aria-label="Call to action"><div class="inner"><h2>{{ section.settings.label | escape }}</h2><p>{{ section.settings.description | escape }}</p><a href="{{ section.settings.url | escape }}" class="button" role="button" aria-label="{{ section.settings.label | escape }}">{{ section.settings.label | escape }}</a></div></section>{% schema %}{% schema.name 'Call to Action' %}{% schema.settings %}[{{ section.settings }}]{% endschema %}