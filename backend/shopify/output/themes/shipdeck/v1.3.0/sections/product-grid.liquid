<section class="product-grid" role="region" aria-label="Product grid"><h2>{{ section.settings.title | escape }}</h2><div class="product-grid-container"><select id="sort-by" name="sort_by"><option value="price"{% if 'sort_by' | equal: 'price' %} selected{% endif %}>Price</option><option value="name"{% if 'sort_by' | equal: 'name' %} selected{% endif %}>Name</option><option value="rating"{% if 'sort_by' | equal: 'rating' %} selected{% endif %}>Rating</option></select>{% for block in block.product-grid-item %}<div class="product-grid-item"><img src="{{ block.settings.image | image_url: width: 400 }}" alt="" role="img" loading="lazy"><h3>{{ product.title }}</h3><p>{{ product.price | money }}</p>{% if product.rating %}<span class="rating" aria-label="Rating">{{ product.rating }}</span>{% endif %}</div>{% endfor %}</div></section>{% schema %}{% schema.name 'Product Grid' %}{% schema.settings %}[{{ section.settings }}]{% schema.blocks %}[{{ block.product-grid-item.settings }}]{% endschema %}