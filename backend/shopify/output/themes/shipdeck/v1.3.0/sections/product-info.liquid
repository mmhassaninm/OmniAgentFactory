<section class="product-info" role="region" aria-label="Product info"><div class="inner"><h2>{{ product.title }}</h2><p>{{ product.price | money }}</p>{% if product.rating %}<span class="rating" aria-label="Rating">{{ product.rating }}</span>{% endif %}<p>{{ product.reviews }} reviews</p></div></section>{% schema %}{% schema.name 'Product Info' %}{% schema.settings %}[{{ section.settings }}]{% endschema %}