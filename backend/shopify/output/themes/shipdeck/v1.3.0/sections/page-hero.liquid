<section class="page-hero" aria-label="Page hero">
  <img src="{{ section.settings.image | image_url: width: 1200 | image_tag }}" alt="{{ section.settings.heading | escape }}">
  <h1>{{ section.settings.heading | escape }}</h1>
  <p>{{ section.settings.subheading | escape }}</p>
  {% schema %}
  {
    "name": "page-hero",
    "settings": [
      {
        "type": "image_picker",
        "id": "image",
        "label": "Background image"
      },
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Page title"
      },
      {
        "type": "text",
        "id": "subheading",
        "label": "Subheading",
        "default": "Page subtitle"
      }
    ],
    "presets": [{"name": "Hero Banner"}]
  }
  {% endschema %}
</section>
