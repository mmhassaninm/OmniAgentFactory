{% schema %}
{
  'name': 'header',
  'settings': [
    {
      'type': 'image_picker',
      'id': 'logo',
      'label': 'Logo'
    },
    {
      'type': 'range',
      'id': 'logo_width',
      'min': 80,
      'max': 300,
      'step': 10,
      'unit': 'px',
      'label': 'Logo width',
      'default': 150
    },
    {
      'type': 'link_list',
      'id': 'menu',
      'label': 'Navigation menu',
      'default': 'main-menu'
    }
  ],
  'presets': [
    {
      'name': 'Default Header'
    }
  ]
}
{% endschema %}

<section role='navigation' aria-label='Header'>{% if section.settings.logo %}
  <div class='logo' style='width: {{ section.settings.logo_width }}px;'>
    <a href='#'>
      <img src='{{ section.settings.logo | image_url: width: 1200 | image_tag }}' alt='Logo'/>
    </a>
  </div>
{% endif %}
  <nav>{% if section.settings.menu %}
    <ul>{% for link in section.settings.menu %}
      <li><a href='#'>{{ link }}</a></li>
    {% endfor %}</ul>
  {% endif %}
  <div class='search'><input type='search' placeholder='Search...'/></div>
  <div class='cart-icon'><a href='#'><svg><use xlink:href='#cart-icon'/></svg></a></div>
</nav>
</section>

<style>
  .logo {
    display: flex;
    justify-content: center;
  }
  .logo a {
    text-decoration: none;
  }
  .logo img {
    width: 100%;
    height: auto;
  }
  @media (max-width: 768px) {
    .logo img {
      width: 50%;
    }
  }
</style>