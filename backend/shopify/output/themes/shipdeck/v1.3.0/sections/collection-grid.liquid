{% schema %}
{
  "name": "Collection Grid",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Collection"
    },
    {
      "type": "select",
      "id": "sort_by",
      "label": "Sort by",
      "default": "price",
      "options": [
        "price",
        "name",
        "rating"
      ]
    }
  ],
  "blocks": [
    {
      "type": "product-grid-item",
      "name": "Grid item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Product image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Default"
    }
  ]
}
{% endschema %}

<div class="collection-grid">
  <h2>{{ title }}</h2>
  <ul>
    {% for product in collection.products %}
    <li>
      <img src="{{ product.image | image_url: width: 400 }}" alt="{{ product.image.alt }}">
      <h3>{{ product.title }}</h3>
      <p>Price: {{ product.price | money }}</p>
    </li>
    {% endfor %}
  </ul>
</div>