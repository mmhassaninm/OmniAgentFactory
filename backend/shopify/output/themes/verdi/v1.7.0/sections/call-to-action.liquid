<section class="call-to-action" style="background-color: #F2F2F2; color: #34C759;--primary-color: #34C759;--background-color: #F2F2F2;" aria-label="Join our community"><div class="container"><h2>{{ section.settings.heading | escape }}</h2><p>{{ section.settings.subheading | escape }}</p><a href="{{ section.settings.signup_url | escape }}" class="btn">Sign-up now</a></div></section>{% schema %}{% if section.settings.heading != blank %}name: {{ section.settings.heading | escape }}{% endif %}{% if section.settings.subheading != blank %}description: {{ section.settings.subheading | escape }}{% endif %}settings: [{% for setting in section.settings %}{% if setting.type == 'text' %}{% if setting.id == 'heading' %}{% assign heading = setting.value | default: 'Join our community' %}{% endif %}{% if setting.id == 'subheading' %}{% assign subheading = setting.value | default: 'Get 10% off your first purchase' %}{% endif %}{% elseif setting.type == 'url' %}{% assign signup_url = setting.value %}{% endif %}{% endfor %}]{% if section.settings.heading != blank %}title: {{ section.settings.heading | escape }}{% endif %}{% if section.settings.subheading != blank %}description: {{ section.settings.subheading | escape }}{% endif %}{% if signup_url != blank %}sign-up-url: {{ signup_url }}{% endif %}presets: [{"name": "Call to Action"}]{% endschema %}