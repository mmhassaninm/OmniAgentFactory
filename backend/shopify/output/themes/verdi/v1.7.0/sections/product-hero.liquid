<section class="product-hero" style="background-color: #F2F2F2; color: #34C759;--primary-color: #34C759;--background-color: #F2F2F2;" aria-label="Product hero"><div class="container"><img src="{{ section.settings.image | image_url: width: 1200 | alt: section.settings.description | escape }}" alt="{{ section.settings.description | escape }}" style="width: 100%;"/><p>{{ section.settings.description | escape }}</p></div></section>{% schema %}{% if section.settings.description != blank %}name: {{ section.settings.description | escape }}{% endif %}{% if section.settings.image != blank %}image: {{ section.settings.image | image_url: width: 1200 | alt: section.settings.description | escape }}{% endif %}settings: [{% for setting in section.settings %}{% if setting.type == 'image_picker' %}{% assign image = setting.value %}{% endif %}{% if setting.type == 'text' %}{% assign description = setting.value | default: '' %}{% endif %}{% endfor %}]{% if section.settings.description != blank %}title: {{ section.settings.description | escape }}{% endif %}{% if section.settings.image != blank %}image: {{ section.settings.image | image_url: width: 1200 | alt: section.settings.description | escape }}{% endif %}presets: [{"name": "Product Hero"}]{% endschema %}