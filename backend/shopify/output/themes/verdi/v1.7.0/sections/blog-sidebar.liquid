<!-- Blog sidebar with categories and tags -->
<section aria-label="Blog sidebar with categories and tags" class="blog-sidebar">
  <h2>{{ section.settings.title | escape }}</h2>
  <ul>
    {% for block in block.list %}
      <li>
        {{ block.settings.label | escape }}
        {{ block.settings.value | escape }}
      </li>
    {% endfor %}
  </ul>
</section>

{% schema %}
{
  "name":"blog-sidebar",
  "settings":[
    {
      "type":"text",
      "id":"title",
      "label":"Title",
      "default":"Categories"
    }
  ],
  "blocks":[
    {
      "type":"category-option",
      "name":"category-option",
      "settings":[
        {
          "type":"text",
          "id":"label",
          "label":"Label"
        },
        {
          "type":"text",
          "id":"value",
          "label":"Value"
        }
      ]
    }
  ],
  "presets":[
    {
      "name":"Default"
    }
  ],
  "default_settings":{
    "title":"Categories"
  }
}
{% endschema %}