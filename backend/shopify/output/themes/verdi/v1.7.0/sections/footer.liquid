<section class="footer" aria-label="Footer">
  <div class="container">
    <div class="row">
      <div class="col-md-4">
        <h2>{{ settings.title | escape }}</h2>
        <p>{{ settings.address | escape }}</p>
        <p>{{ settings.phone | escape }}</p>
        <p>{{ settings.email | escape }}</p>
      </div>
      <div class="col-md-4">
        <h2>{{ block.settings.label | escape }}</h2>
        <a href="{{ block.settings.value | escape }}" target="_blank" rel="noopener" aria-label="{{ block.settings.label | escape }}"><i class="{% if block.settings.label == 'Facebook' %}fab fa-facebook{% elsif block.settings.label == 'Instagram' %}fab fa-instagram{% elsif block.settings.label == 'Twitter' %}fab fa-twitter{% else %}fab fa-facebook{% endif %}"></i></a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "footer",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Contact Us"
    },
    {
      "type": "text",
      "id": "address",
      "label": "Address"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email"
    }
  ],
  "blocks": [
    {
      "type": "social-media-icon",
      "name": "social-media-icon",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label"
        },
        {
          "type": "text",
          "id": "value",
          "label": "Value"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Default"
    }
  ],
  "classes": [
    "d-flex flex-wrap justify-content-between"
  ]
}
{% endschema %}