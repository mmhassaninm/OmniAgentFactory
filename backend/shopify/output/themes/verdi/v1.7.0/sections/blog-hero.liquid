{% schema %}
{
  "name": "Blog Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Blog image"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Blog description",
      "default": ""
    }
  ],
  "presets": [
    {
      "name": "Default"
    }
  ],
  "blocks": [],
  "responsive_notes": "Hide on mobile"
}
{% endschema %}
<section class="blog-hero" style="background-color: {{ theme.settings.backgroundColor | escape }};">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-12 col-md-6">
        <img src="{{ section.settings.image | image_url: width: 1200 | image_tag }}" alt="{{ section.settings.image.alt }}">
      </div>
      <div class="col-12 col-md-6">
        <h2>{{ section.settings.description }}</h2>
      </div>
    </div>
  </div>
</section>
