<section class="collection-products">
  <div class="container">
    {% for product in section.settings.products.products %}
      <div class="product-grid-item" aria-label="Product Grid Item">
        <a href="{{ product.url }}" class="product-link">
          <img src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.title }}" loading="lazy" class="product-image">
          <h3 class="product-title">{{ product.title }}</h3>
          <div class="product-price">{{ product.price | money }}</div>
        </a>
      </div>
    {% endfor %}
  </div>
</section>{% schema %}
{
  "name": "Collection Products",
  "settings": [
    {
      "type": "collection_list",
      "id": "products",
      "label": "Products to display",
      "default": "grid"
    }
  ],
  "blocks": [
    {
      "type": "product-grid",
      "name": "product-grid",
      "settings": [
        {
          "type": "product_picker",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Grid of Products"
    }
  ]
}{% endschema %}