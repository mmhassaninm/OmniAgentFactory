<section data-section-id=\"cart-products\" class=\"cart-products section{% if block.settings.products != 'cart' %} cart-products--{{ block.settings.products }}{% endif %}\" data-section-type=\"cart-products\" style=\"background-color: #F2F2F2; color: #333;\" aria-label=\"{% t 'Cart products' %}\">\
  <div class=\"container\">\
    <h2>{{ block.settings.products | t }}</h2>\
    <div class=\"cart-products__list\">\
      {% for item in cart.items %}\
        {% assign product = item.product %}\
        <div class=\"cart-item\" data-block-id=\"cart-item\">\
          <div class=\"cart-item__content\">\
            <img src=\"{{ product.image | image_url: width: 1200 | image_tag }}\" alt=\"{{ product.image.alt | escape }}\" style=\"width: 100%; height: auto;\">\
            <h3>{{ product.title | escape }}</h3>\
            <p>Quantity: {{ item.quantity }}</p>\
            <p>Price: {{ item.line_price | money }}</p>\
          </div>\
        </div>\
      {% endfor %}\
    </div>\
  </div>\
</section>\
\
{% schema %}\
  {\
    \"name\":\"cart-products\",\
    \"settings\":[\
      {\
        \"type\":\"cart_list\",\
        \"id\":\"products\",\
        \"label\":\"Products in cart\",\
        \"default\":\"cart\"\
      }\
    ],\
    \"blocks\":[\
      {\
        \"type\":\"cart-item\",\
        \"name\":\"cart-item\",\
        \"settings\":[\
          {\
            \"type\":\"product_picker\",\
            \"id\":\"product\",\
            \"label\":\"Product\"\
          }\
        ]\
      }\
    ],\
    \"presets\":[\
      {\
        \"name\":\"Default\"\
      }\
    ]\
  }\
{% endschema %}