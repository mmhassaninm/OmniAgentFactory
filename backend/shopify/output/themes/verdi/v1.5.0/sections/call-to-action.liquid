<section class=\"call-to-action\" style=\"color: #34C759; background-color: #F2F2F2;\">\
{% schema %}\
{\
  \"name\": \"Call to Action\",\
  \"settings\": [\
    {\
      \"type\": \"text\",\
      \"id\": \"heading\",\
      \"label\": \"Heading\",\
      \"default\": \"Join the Green Movement\"\
    },\
    {\
      \"type\": \"text\",\
      \"id\": \"subheading\",\
      \"label\": \"Subheading\",\
      \"default\": \"Stay updated on eco-friendly products and tips\"\
    },\
    {\
      \"type\": \"email\",\
      \"id\": \"newsletter_email\",\
      \"label\": \"Newsletter email\"\
    }\
  ],\
  \"presets\": [\
    {\"name\": \"Eco-Friendly Promise\"}\
  ]\
},\
{% endschema %}\
<h2>{{ settings.heading | escape }}</h2>\
<p>{{ settings.subheading | escape }}</p>\
<form id=\"newsletter-form\">\
  <input id=\"newsletter-email\" type=\"email\" name=\"newsletter_email\" placeholder=\"Your email\" required>\
  <button id=\"newsletter-submit\">Subscribe</button>\
</form>\
</section>