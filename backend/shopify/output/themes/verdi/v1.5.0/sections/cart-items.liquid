{% schema %}{% assigns settings = config.settings %}{% if settings.cart_items %}{% assign items = settings.cart_items.items %}{% if items %}<div class=\"cart-items\" style=\"grid-template-columns: repeat(2, 1fr); grid-gap: 20px;\" aria-label=\"{{ 'cart_items.aria_label' | t }}\"><div class=\"row\"><div class=\"col-12\"><div class=\"grid\"><div class=\"item\">{% for item in items %}<div class=\"card\"><img src=\"{% if item.image | image_url: width: 400 %}{{ item.image | image_url: width: 400 }}{% else %}{{ asset 'default-product-image.jpg' }}{% endif %}\" alt=\"{{ item.title }}\" style=\"object-fit: cover;\" aria-label=\"{{ item.title }}\"><div class=\"card-body\"><div class=\"card-title\"><h2>{{ item.title }}</h2><p>{{ item.price | money }}</p></div><div class=\"card-text\"><p>{{ item.description }}</p></div></div></div>{% endfor %}</div></div></div></div>{% endif %}{% endif %}{% schema %}{% assign settings = config.settings %}{% if settings.cart_items %}{% schema_setting type: 'product_list' id: 'items' label: 'Cart items' %}{% endif %}{% endschema %}