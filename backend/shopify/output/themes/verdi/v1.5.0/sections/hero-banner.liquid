<section class="hero-banner" style="--primary-color:#34C759;--bg-color:#F2F2F2;"> 
  <div class="container"> 
    <div class="hero-banner__inner"> 
      <div class="hero-banner__image" style="background-image:url('{{ section.settings.image | image_url: width: 1200 }}');"> 
      </div> 
      <div class="hero-banner__content"> 
        <h1>{{ section.settings.heading | escape }}</h1> 
        <p>{{ section.settings.subheading | escape }}</p> 
        <div class="hero-banner__cta"> 
          <a href="{{ section.settings.cta_url | escape }}" class="btn" aria-label="{{ section.settings.cta_label | escape }}">{{ section.settings.cta_label | escape }}</a> 
        </div> 
      </div> 
    </div> 
  </div> 
</section>{% schema %}{% assign schema = 'sections/hero-banner.schema.json' %}{% include schema %}{% endschema %}