<!-- Page Hero Section -->
<section class="page-hero section section--padding section--lg-padding">
    <div class="container">
        <div class="grid grid--1x1 grid--2x2--tablet grid--1x1--mobile">
            <div class="grid__item">
                <div class="page-hero__image">
                    <img src="{{ image | image_url: width: 1200 }}" alt="{{ image.alt | escape }}" loading="lazy" aria-label="Background image">
                </div>
                <div class="page-hero__content">
                    <h1>{{ heading | escape }}</h1>
                    <p>{{ subheading | escape }}</p>
                </div>
            </div>
        </div>
    </div>
</section>

{% schema %}
{
    "name": "Page Hero",
    "settings": [
        {
            "type": "image_picker",
            "id": "image",
            "label": "Background image"
        },
        {
            "type": "text",
            "id": "heading",
            "label": "Heading",
            "default": "{title}"
        },
        {
            "type": "text",
            "id": "subheading",
            "label": "Subheading",
            "default": "{description}"
        }
    ],
    "presets": [
        {
            "name": "Page Hero"
        }
    ],
    "blocks": [
    ],
    "responsive_notes": "Stack vertically on mobile, reduce hero height to 60vh"
}
{% endschema %}