<!-- Product details with prices, sizes, and colors -->
<div class="product-details" aria-label="Product details">
  <h2>{{ section.settings.details | t }}</h2>
  <ul>
    {% for option in product.options %}
      <li>{{ option.name }}: {{ option.values | join: ', ' }}</li>
    {% endfor %}
  </ul>
  <p>Price: {{ product.price | money }}</p>
</div>

{% schema %}
{
  "name": "Product details",
  "settings": [
    {
      "type": "product_details",
      "id": "details",
      "label": "Product details"
    }
  ],
  "presets": [
    {
      "name": "Default"
    }
  ]
}
{% endschema %}