<!-- Page content with text and images -->
<section>
  <div class="container">
    <div class="row">
      <div class="col-md-12">
        <p>{{ section.settings.content | escape }}</p>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Page Content",
  "settings": [
    {
      "type": "text",
      "id": "content",
      "label": "Page content",
      "default": ""
    }
  ],
  "presets": [
    {
      "name": "Default"
    }
  ]
}
{% endschema %}