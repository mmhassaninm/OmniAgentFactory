<section class=\"hero-banner\" style=\"background-image: url({{ section.settings.image | image_url: width: 1200 | default: 'https://via.placeholder.com/1200x600' }}); --primary-color: #34C759; --bg-color: #F2F2F2;\">\n  <div class=\"container\">\n    <h1>{{ section.settings.heading | escape }}</h1>\n    <p>{{ section.settings.subheading | escape }}</p>\n    <div class=\"call-out\">Best Sellers <span aria-label=\"Best Sellers\">&#8595;</span></div>\n    <a href=\"{{ section.settings.cta_url | escape }}\" class=\"btn {{ section.settings.cta_label | escape }}\" role=\"button\">{{ section.settings.cta_label | escape }}</a>\n  </div>\n</section>\n\n{% schema %}\nname: Hero Banner\nsettings:\n  - type: image_picker\n    id: image\n    label: Background image\n  - type: text\n    id: heading\n    label: Heading\n    default: Eco-Friendly Products for a Greener Tomorrow\n  - type: text\n    id: subheading\n    label: Subheading\n    default: Discover sustainable products for your home, garden, and lifestyle\n  - type: text\n    id: cta_label\n    label: Button label\n    default: Shop Now\n  - type: url\n    id: cta_url\n    label: Button URL\npresets:\n  - name: Hero Banner\n{% endschema %}