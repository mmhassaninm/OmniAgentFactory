<section class="container" style="padding-top: 20px;"><h2>{{ t 'Sign up for our newsletter' }}</h2><form method="post" action="/subscribe" id="subscribe-form"><input type="email" name="email" placeholder="Enter your email address" style="width: 100%; height: 30px; padding: 10px; font-size: 16px; font-family: Lato; border: none; border-radius: 5px; box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);"><button type="submit" style="background-color: #34C759; color: #F2F2F2; padding: 10px 20px; border: none; border-radius: 5px; transition: background-color 0.3s ease; cursor: pointer;">Subscribe</button></form><script>alert("Newsletter form submitted");document.getElementById('subscribe-form').reset();</script>{% schema %}  
  "name": "Newsletter Signup",
  "settings": [
    {
      "type": "email_address",
      "id": "email",
      "label": "Email address"
    }
  ],
  "presets": [
    {
      "name": "Default"
    }
  ]{% endschema %}