<section class=\"cart-items\" aria-label=\"Cart items\">\n  <h2 class=\"section-title\">{{ section.settings.heading | t }}</h2>\n  <ul class=\"cart-list\">\n    {% for item in cart.items %}\n      <li>\n        {{ item.name }}\n        ({{ item.quantity }})\n        {{ item.price | money }}\n      </li>\n    {% endfor %}\n  </ul>\n</section>{% schema %}\n{\n  \"name\": \"Cart items\",\n  \"settings\": [\n    {\n      \"type\": \"cart_item_list\",\n      \"id\": \"items\",\n      \"label\": \"Cart items\"\n    }\n  ],\n  \"presets\": [\n    {\n      \"name\": \"Default\"\n    }\n  ]\n}{% endschema %}