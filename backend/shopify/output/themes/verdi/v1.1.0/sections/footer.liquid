{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Contact Us"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Get in touch with us"
    }
  ],
  "presets": [
    {
      "name": "Default"
    }
  ]
}
{% endschema %}
<section class="footer">
  <div class="container">
    <div class="footer__content">
      <h3>{{ heading | escape }}</h3>
      <p>{{ subheading | escape }}</p>
      <!-- Add contact information, social links, and copyright here -->
    </div>
  </div>
</section>
