<section class="container" style="padding-top: 20px; background-color: #F2F2F2;"><h2>{{ section.settings.heading | escape }}<br>{{ section.settings.subheading | escape }}</h2><img src="{{ section.settings.image | image_url: width: 1200 }}" alt="{{ section.settings.image.alt | escape }}" style="width: 100%; height: auto; display: block; margin: 20px auto; border-radius: 5px; box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);"><a href="/collections/all" style="background-color: #34C759; color: #F2F2F2; padding: 10px 20px; border: none; border-radius: 5px; transition: background-color 0.3s ease; cursor: pointer;">Shop Now</a>{% schema %}  
  "name": "Product Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Product image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Product Name"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Product description"
    }
  ],
  "presets": [
    {
      "name": "Default"
    }
  ]{% endschema %}