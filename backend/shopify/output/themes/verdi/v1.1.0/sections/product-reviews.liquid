<!-- Product reviews to build trust and credibility -->
<div class="product-reviews" aria-label="Product reviews">
  <h2>{{ section.settings.reviews | t }}</h2>
  <ul>
    {% for review in product.reviews %}
      <li>{{ review.body }}
        <span>Rated {{ review.rating }} stars</span>
      </li>
    {% endfor %}
  </ul>
</div>

{% schema %}
{
  "name": "Product reviews",
  "settings": [
    {
      "type": "review_list",
      "id": "reviews",
      "label": "Product reviews"
    }
  ],
  "presets": [
    {
      "name": "Default"
    }
  ]
}
{% endschema %}