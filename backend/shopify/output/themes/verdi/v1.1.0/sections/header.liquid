{% schema %}\n{\n  \"name\": \"Header\",\n  \"settings\": [\n    {\n      \"type\": \"image_picker\",\n      \"id\": \"logo\",\n      \"label\": \"Logo\"\n    },\n    {\n      \"type\": \"range\",\n      \"id\": \"logo_width\",\n      \"min\": 80,\n      \"max\": 300,\n      \"step\": 10,\n      \"unit\": \"px\",\n      \"label\": \"Logo width\",\n      \"default\": 150\n    },\n    {\n      \"type\": \"link_list\",\n      \"id\": \"menu\",\n      \"label\": \"Navigation menu\",\n      \"default\": \"main-menu\"\n    }\n  ],\n  \"presets\": [\n    {\n      \"name\": \"Default\"\n    }\n  ]\n}\n{% endschema %}\n\n<div class=\"header\" role=\"banner\">\n  <div class=\"container\">\n    <div class=\"header__inner\">\n      <a href=\"{{ shop.url }}\" class=\"header__logo\">\n        <img src=\"{{ section.settings.logo | image_url: width: 1200 }}\" alt=\"{{ shop.name }}\" aria-label=\"{{ shop.name }}\">\n      </a>\n      <button class=\"header__menu-toggle\" aria-controls=\"header-menu\" aria-expanded=\"false\" aria-label=\"Toggle navigation\">\n        <svg class=\"icon icon--menu\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\">\n          <path d=\"M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6\">\n          </path>\n        </svg>\n      </button>\n      <nav id=\"header-menu\" class=\"header__menu\" role=\"navigation\">\n        <ul>\n          {% for link in linklists.menu.links %}\n            <li {{ link.class | escape }}>\n              <a href=\"{{ link.url }}\"{% if link.active %} class=\"active\"{% endif %}>{% if link.label %}{{ link.label }}{% else %}{{ link.title }}{% endif %}</a>\n            </li>\n          {% endfor %}\n        </ul>\n      </nav>\n      <form role=\"search\" class=\"header__search\">\n        <input type=\"search\" placeholder=\"Search\" name=\"q\" autocomplete=\"off\" value=\"\" role=\"textbox\" aria-label=\"Search\">\n        <button type=\"submit\" class=\"search-submit\">\n          <svg class=\"icon icon--search\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\">\n            <circle cx=\"10\" cy=\"10\" r=\"10\"/>\n            <line x1=\"21\" y1=\"21\" x2=\"15\" y2=\"15\"/>\n          </svg>\n        </button>\n      </form>\n      <a href=\"{{ cart.url }}\" class=\"header__cart\">\n        <span class=\"cart-contents\">{{ cart.item_count }}</span>\n        <svg class=\"icon icon--cart\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\">\n          <path d=\"M3 3l7.729 3 9.333 9.333L21 3m0 0l-15 15 1.354 2 14.25 14.25 2.664-1 12.342-12.25L3 16.29m21-13l-5.689 2.134-2.667 7.488 1 9c0 .55-.003.62-.01 1.15C17.65 18.38 17.153 18.75 16.898 19L5 22.29m9.342 0c0 .55-.003.62-.01 1.15C25.35 18.38 24.853 18.75 24.598 19L13.65 22.29\"/>\n        </svg>\n      </a>\n    </div>\n  </div>\n</div>