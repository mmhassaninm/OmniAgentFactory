{% schema %}\n{\n  \"name\": \"Announcement Bar\",\n  \"settings\": [\n    {\n      \"type\": \"text\",\n      \"id\": \"heading\",\n      \"label\": \"Heading\",\n      \"default\": \"Promotions\"\n    },\n    {\n      \"type\": \"text\",\n      \"id\": \"subheading\",\n      \"label\": \"Subheading\",\n      \"default\": \"Limited time offers\"\n    }\n  ],\n  \"presets\": [\n    {\n      \"name\": \"Default\"\n    }\n  ]\n}\n{% endschema %}\n\n<div class=\"announcement-bar\" role=\"alert\" aria-live=\"assertive\">\n  <div class=\"container\">\n    <div class=\"announcement-bar__inner\">\n      <h2>{{ section.settings.heading }}</h2>\n      <p>{{ section.settings.subheading }}</p>\n    </div>\n  </div>\n</div>