{% schema %}
{
  "name": "Collection Grid",
  "settings": [
    {
      "type": "product_list",
      "id": "products",
      "label": "Collection products"
    }
  ],
  "presets": [
    {
      "name": "Default"
    }
  ],
  "blocks": [
  ],
  "responsive_notes": "Grid 4 columns on desktop, 2 columns on tablet, 1 column on mobile"
}
{% endschema %}

<div class="collection-grid" role="region" aria-label="{{ 'collection.grid' | t }}">
  <div class="container">
    <div class="row">
      {% for product in section.settings.products.products %}
        <div class="col-md-3 col-lg-2 col-xl-1">
          <div class="product-grid-item">
            <a href="{{ product.url | escape }}" role="link" aria-label="{{ product.title | escape }}">
              <img src="{{ product.image | image_url: width: 400 | escape }}" alt="{{ product.image.alt | escape }}" class="lazy-image" data-src="{{ product.image | image_url: width: 400 | escape }}">
              <h2>{{ product.title | escape }}</h2>
              <p>{{ product.description | truncate: 100 | escape }}</p>
              <p>{{ product.price | money | escape }}</p>
            </a>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

<style>
  .collection-grid {
    padding: 2rem 0;
  }
  .collection-grid .product-grid-item {
    background-color: #F2F2F2;
    border: 1px solid #ddd;
    border-radius: 0.5rem;
    padding: 1rem;
  }
  .collection-grid .product-grid-item img {
    width: 100%;
    height: 15rem;
    object-fit: cover;
    border-radius: 0.5rem 0.5rem 0 0;
  }
  .collection-grid .product-grid-item h2 {
    font-family: Montserrat;
    font-size: 1.5rem;
    font-weight: bold;
  }
  .collection-grid .product-grid-item p {
    font-family: Lato;
    font-size: 1rem;
    color: #666;
  }
</style>
