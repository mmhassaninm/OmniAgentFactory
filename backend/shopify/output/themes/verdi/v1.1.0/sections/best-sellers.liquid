<section class=\"best-sellers\" style=\"--primary-color: #34C759; --bg-color: #F2F2F2;\">\n  <div class=\"container grid\">\n    {% for product in section.settings.products %}\n      <div class=\"item\">\n        <img src=\"{{ product | image_url: width: 400 | alt: product.title | default: 'https://via.placeholder.com/400x400' }}\" alt=\"{{ product.title | escape }}\" width=\"400\" height=\"400\" loading=\"lazy\" role=\"img\" aria-label=\"{{ product.title | escape }}\" />\n        <h2>{{ product.title | escape }}</h2>\n        <p>{{ product.price | money }}</p>\n      </div>\n    {% endfor %}\n  </div>\n</section>\n\n{% schema %}\nname: Best Sellers\nsettings:\n  - type: product_list\n    id: products\n    label: Best-selling products\npresets:\n  - name: Best Sellers\n{% endschema %}