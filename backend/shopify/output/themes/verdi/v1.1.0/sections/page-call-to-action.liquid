<!-- Page call-to-action to encourage conversion -->
<section class="cta">
  <div class="container">
    <div class="row">
      <div class="col-md-12">
        <h2>{{ section.settings.heading | escape }}</h2>
        <p>{{ section.settings.subheading | escape }}</p>
        <a href="{{ route | url }}" class="btn btn-primary">Learn more</a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Page Call-to-Action",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Call-to-action"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Encourage customers to take action"
    }
  ],
  "presets": [
    {
      "name": "Default"
    }
  ]
}
{% endschema %}