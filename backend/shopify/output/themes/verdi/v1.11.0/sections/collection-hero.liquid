<section class=\"collection-hero\" style=\"--primary-color: #34C759; --background-color: #F2F2F2;\">\n  <div class=\"collection-hero__bg\" style=\"background-image: {{ section.settings.image | image_url: width: 1200 | image_tag }};\"></div>\n  <div class=\"collection-hero__content\">\n    <h1>{{ section.settings.heading | escape }}</h1>\n    <div class=\"collection-hero__products\">\n      {% for product in section.settings.products.products %}\n        <div class=\"collection-hero__product\">\n          <img src=\"{{ product.image | image_url: width: 100 | image_tag }}\" alt=\"{{ product.title | escape }}\">\n          <h2>{{ product.title | escape }}</h2>\n        </div>\n      {% endfor %}\n    </div>\n  </div>\n</section>\n\n{% schema %}\n{\n  \"name\": \"Collection Hero\",\n  \"settings\": [\n    {\n      \"type\": \"image_picker\",\n      \"id\": \"image\",\n      \"label\": \"Background image\"\n    },\n    {\n      \"type\": \"text\",\n      \"id\": \"heading\",\n      \"label\": \"Collection name\"\n    },\n    {\n      \"type\": \"product_list\",\n      \"id\": \"products\",\n      \"label\": \"Featured products\"\n    }\n  ],\n  \"presets\": [\n    {\n      \"name\": \"Default\"\n    }\n  ]\n}\n{% endschema %}\n\n<script>\n  document.addEventListener(\"DOMContentLoaded\", function () {\n    const collectionHero = document.querySelector(\".collection-hero\");\n    if (collectionHero) {\n      collectionHero.addEventListener(\"keydown\", function (event) {\n        if (event.key === \"Escape\") {\n          collectionHero.classList.remove(\"aria-expanded\");\n        }\n      });\n    }\n  });\n</script>\n\n{% if section.settings.products.products.count > 0 %}\n  <script>\n    document.addEventListener(\"DOMContentLoaded\", function () {\n      const productGrid = document.querySelector(\".collection-hero__products\");\n      if (productGrid) {\n        productGrid.addEventListener(\"keydown\", function (event) {\n          if (event.key === \"ArrowRight\") {\n            const products = productGrid.querySelectorAll(\".collection-hero__product\");\n            const currentIndex = Array.prototype.indexOf.call(products, productGrid.querySelector(\".collection-hero__product:focus\"));\n            const nextIndex = (currentIndex + 1) % products.length;\n            products[nextIndex].focus();\n          } else if (event.key === \"ArrowLeft\") {\n            const products = productGrid.querySelectorAll(\".collection-hero__product\");\n            const currentIndex = Array.prototype.indexOf.call(products, productGrid.querySelector(\".collection-hero__product:focus\"));\n            const nextIndex = (currentIndex - 1 + products.length) % products.length;\n            products[nextIndex].focus();\n          }\n        });\n      }\n    });\n  {% endif %}\n\n{% schema %}\n{\n  \"name\": \"Collection Hero\",\n  \"settings\": [\n    {\n      \"type\": \"image_picker\",\n      \"id\": \"image\",\n      \"label\": \"Background image\"\n    },\n    {\n      \"type\": \"text\",\n      \"id\": \"heading\",\n      \"label\": \"Collection name\"\n    },\n    {\n      \"type\": \"product_list\",\n      \"id\": \"products\",\n      \"label\": \"Featured products\"\n    }\n  ],\n  \"presets\": [\n    {\n      \"name\": \"Default\"\n    }\n  ],\n  \"blocks\": [\n    {\n      \"type\": \"section\",\n      \"name\": \"collection-hero\",\n      \"settings\": [\n        {\n          \"type\": \"image_picker\",\n          \"id\": \"image\",\n          \"label\": \"Background image\"\n        },\n        {\n          \"type\": \"text\",\n          \"id\": \"heading\",\n          \"label\": \"Collection name\"\n        },\n        {\n          \"type\": \"product_list\",\n          \"id\": \"products\",\n          \"label\": \"Featured products\"\n        }\n      ],\n      \"responsive_notes\": \"Reduce hero height to 60vh on mobile\"\n    }\n  ]\n}\n{% endschema %}