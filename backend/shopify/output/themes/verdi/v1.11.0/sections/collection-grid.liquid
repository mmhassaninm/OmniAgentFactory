<section class=\"collection-grid\" style=\"--primary-color: #34C759; --background-color: #F2F2F2;\">\n  <div class=\"collection-grid__products\">\n    {% for product in section.settings.products.products %}\n      <div class=\"collection-grid__product\">\n        <img src=\"{{ product.image | image_url: width: 100 | image_tag }}\" alt=\"{{ product.title | escape }}\">\n        <h2>{{ product.title | escape }}</h2>\n        <p>{{ product.description | escape }}</p>\n      </div>\n    {% endfor %}\n  </div>\n</section>\n\n{% schema %}\n{\n  \"name\": \"Collection Grid\",\n  \"settings\": [\n    {\n      \"type\": \"product_list\",\n      \"id\": \"products\",\n      \"label\": \"Collection products\"\n    }\n  ],\n  \"presets\": [\n    {\n      \"name\": \"Default\"\n    }\n  ],\n  \"blocks\": [\n    {\n      \"type\": \"section\",\n      \"name\": \"collection-grid\",\n      \"settings\": [\n        {\n          \"type\": \"product_list\",\n          \"id\": \"products\",\n          \"label\": \"Collection products\"\n        }\n      ],\n      \"responsive_notes\": \"Switch to 2-column grid on desktop, 1-column grid on mobile\"\n    }\n  ]\n}\n{% endschema %}