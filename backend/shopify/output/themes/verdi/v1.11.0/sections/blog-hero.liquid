<section class="blog-hero" role="banner" aria-label="{{ 'blog.hero' | t }}">
  <div class="blog-hero__background" style="background-image: url('{{ section.settings.image | image_url: width: 1200 | image_tag }}');"></div>
  <div class="blog-hero__content">
    <h1 class="blog-hero__heading" style="font-family: Montserrat, sans-serif; color: #34C759;">{{ section.settings.heading | escape }}</h1>
    <ul class="blog-hero__articles">
      {% for article in section.settings.articles %}
        <li class="blog-hero__article">
          <a href="{{ article.url }}" class="blog-hero__article-link" aria-label="{{ article.title | t }}">
            <div class="blog-hero__article-thumbnail" style="background-image: url('{{ article.image | image_url: width: 400 | image_tag }}');"></div>
            <h3 class="blog-hero__article-title" style="font-family: Lato, sans-serif; color: #34C759;">{{ article.title | escape }}</h3>
          </a>
        </li>
      {% endfor %}
    </ul>
  </div>
</section>

{% schema %}
{
  "name": "Blog Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Blog name"
    },
    {
      "type": "blog_list",
      "id": "articles",
      "label": "Featured articles"
    }
  ],
  "presets": [
    {
      "name": "Blog Hero"
    }
  ],
  "blocks": [
  ],
  "responsive_notes": "Reduce hero height to 60vh on mobile"
}
{% endschema %}

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const hero = document.querySelector('.blog-hero');
    if (hero) {
      hero.style.height = window.innerHeight * 0.6 + 'px';
    }
  });
</script>