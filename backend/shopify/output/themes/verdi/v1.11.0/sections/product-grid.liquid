<div class=\"container product-grid\" style=\"background-color: #F2F2F2;\" aria-label=\"{{ 'product_grid' | t }}\">\n  <div class=\"row align-items-center justify-content-center\">\n    <div class=\"col-12 col-md-12 product-list\" style=\"grid-template-columns: repeat(2, 1fr);\" aria-label=\"{{ 'featured_products' | t }}\">\n      {% for product in section.settings.products %}\n        <div class=\"col-6 col-md-6 mb-4\">\n          <h3 class=\"mb-2\" style=\"font-family: Montserrat, sans-serif; color: #333;\" aria-label=\"{{ 'product_name' | t }}\">{{ product.title }}</h3>\n          <p class=\"mb-3\" style=\"font-family: Lato, sans-serif; color: #666;\" aria-label=\"{{ 'product_description' | t }}\">{{ product.description }}</p>\n          <a href=\"{{ product.url | escape }}\" style=\"background-color: {{ settings.primary }}; border-color: {{ settings.primary }};\" aria-label=\"{{ 'shop_now' | t }}\">Shop Now</a>\n        </div>\n      {% endfor %}\n    </div>\n  </div>\n</div>\n\n{% schema %}\n{\n  \"name\":\"product-grid\",\n  \"settings\":[\n    {\n      \"type\":\"product_list\",\n      \"id\":\"products\",\n      \"label\":\"Featured products\"\n    }\n  ],\n  \"presets\":[{\"name\":\"Product Grid\"}],\n  \"blocks\":[],\n  \"default_settings\":{},\n  \"section_id\":\"product-grid\",\n  \"id\":\"product-grid\",\n  \"type\":\"section\"\n}\n{% endschema %}