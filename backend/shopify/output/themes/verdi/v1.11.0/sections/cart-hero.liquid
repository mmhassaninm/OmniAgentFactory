<section class="cart-hero" aria-label="Cart hero">
  <div class="hero-image" style="background-image:url({{ section.settings.image | image_url: width: 1200 | image_tag }})"></div>
  <h1>{{ section.settings.heading | escape }}</h1>
  <h2>Items in cart:</h2>
  <ul>
    {% for item in section.settings.items %}
      <li>{{ item.title }} x {{ item.quantity }}</li>
    {% endfor %}
  </ul>
  {% schema %}
  {
    "name":"cart-hero",
    "settings":[
      {
      "type":"image_picker",
      "id":"image",
      "label":"{{ 'cart.hero.image' | t }}"
      },
      {
      "type":"text",
      "id":"heading",
      "label":"{{ 'cart.hero.heading' | t }}"
      },
      {
      "type":"cart_list",
      "id":"items",
      "label":"{{ 'cart.hero.items' | t }}"
      }
    ],
    "presets":[
      {
      "name":"Cart Hero"
      }
    ],
    "blocks":[],
    "responsive_notes":"Reduce hero height to 60vh on mobile"
  }
  {% endschema %}
</section>
