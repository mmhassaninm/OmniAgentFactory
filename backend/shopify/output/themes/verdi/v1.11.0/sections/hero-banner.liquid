<section class=\"container hero-banner\" style=\"background-color: {{ settings.bg }};\" aria-label=\"{{ 'hero_banner' | t }}\">\n  <div class=\"row align-items-center justify-content-center hero-content\">\n    <div class=\"col-12 col-md-8 text-center\">\n      <img src=\"{{ section.settings.image | image_url: width: 1200 }}\" alt=\"{{ section.settings.image | escape }}\" style=\"object-fit: cover;\" class=\"img-fluid mb-4\" aria-label=\"{{ 'image' | t }}\">\n      <h1 class=\"display-4 mb-3\" style=\"font-family: Montserrat, sans-serif; color: {{ settings.primary }};\" aria-label=\"{{ 'heading' | t }}\">{{ section.settings.heading | escape }}</h1>\n      <h2 class=\"mb-3\" style=\"font-family: Lato, sans-serif; color: #333;\" aria-label=\"{{ 'subheading' | t }}\">{{ section.settings.subheading | escape }}</h2>\n      <a class=\"btn btn-primary\" href=\"{{ section.settings.cta_url | escape }}\" style=\"background-color: {{ settings.primary }}; border-color: {{ settings.primary }};\" aria-label=\"{{ 'shop_now' | t }}\">{{ section.settings.cta_label | escape }}</a>\n    </div>\n  </div>\n</section>\n\n{% schema %}\n{\n  \"name\":\"hero-banner\",\n  \"settings\":[\n    {\n      \"type\":\"image_picker\",\n      \"id\":\"image\",\n      \"label\":\"Background image\"\n    },\n    {\n      \"type\":\"text\",\n      \"id\":\"heading\",\n      \"label\":\"Heading\",\n      \"default\":\"Eco-Friendly Products for a Sustainable Future\"\n    },\n    {\n      \"type\":\"text\",\n      \"id\":\"subheading\",\n      \"label\":\"Subheading\",\n      \"default\":\"Shop with us and make a positive impact\"\n    },\n    {\n      \"type\":\"text\",\n      \"id\":\"cta_label\",\n      \"label\":\"Button label\",\n      \"default\":\"Shop Eco-Friendly\"\n    },\n    {\n      \"type\":\"url\",\n      \"id\":\"cta_url\",\n      \"label\":\"Button URL\"\n    }\n  ],\n  \"presets\":[{\"name\":\"Hero Banner\"}],\n  \"blocks\":[],\n  \"default_settings\":{},\n  \"section_id\":\"hero-banner\",\n  \"id\":\"hero-banner\",\n  \"type\":\"section\"\n}\n{% endschema %}