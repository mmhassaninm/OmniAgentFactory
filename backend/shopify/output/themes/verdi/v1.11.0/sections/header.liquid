{% schema %}\n{\n  \"name\": \"Header\",\n  \"settings\": [\n    {\n      \"type\": \"image_picker\",\n      \"id\": \"logo\",\n      \"label\": \"Logo\"\n    },\n    {\n      \"type\": \"range\",\n      \"id\": \"logo_width\",\n      \"min\": 80,\n      \"max\": 300,\n      \"step\": 10,\n      \"unit\": \"px\",\n      \"label\": \"Logo width\",\n      \"default\": 150\n    },\n    {\n      \"type\": \"link_list\",\n      \"id\": \"menu\",\n      \"label\": \"Navigation menu\",\n      \"default\": \"main-menu\"\n    }\n  ],\n  \"presets\": [\n    {\n      \"name\": \"Default\"\n    }\n  ]\n}\n{% endschema %}\n<div class=\"container\">\n  <header role=\"banner\" aria-label=\"Header\">\n    <div class=\"logo-wrapper\">\n      <img class=\"logo\" src=\"{{ section.settings.logo | image_url: width: 80 }}\" alt=\"{{ shop.name }}\" width=\"{{ section.settings.logo_width }}\" height=\"80\" loading=\"lazy\" aria-label=\"Logo\">\n    </div>\n    <div class=\"nav-menu\">\n      <button class=\"hamburger\" aria-label=\"Toggle navigation menu\">\n        <svg width=\"24\" height=\"24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" viewBox=\"0 0 24 24\" xmlns=\"http://www.w3.org/2000/svg\">\n          <path d=\"M3 18h18v-2H3v2zm0-8h18v-2H3v2zm0-8h18v-2H3v2zm1.5-9L4.5 12l1.5 1.5 5-5zm11.25 11.25L21 12 23.5 9.5z\"/>\n        </svg>\n      </button>\n      <nav role=\"navigation\" aria-label=\"Navigation menu\">\n        <ul class=\"nav-links\">\n          {% for link in section.settings.menu %}\n            <li>\n              <a href=\"{{ link.url }}\" aria-label=\"{{ link.text }}\">{{ link.text | escape }}</a>\n            </li>\n          {% endfor %}\n        </ul>\n      </nav>\n      <button class=\"search-icon\" aria-label=\"Search\">\n        <svg width=\"24\" height=\"24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" viewBox=\"0 0 24 24\" xmlns=\"http://www.w3.org/2000/svg\">\n          <path d=\"M0 0h24v24H0V0z\" fill=\"none\"/>\n          <path d=\"M15.5 14h-1.75c-.83 0-1.5-.67-1.5-1.5s-.67-1.5 1.5-1.5h1.75c.83 0 1.5.67 1.5 1.5s-.67 1.5-1.5 1.5zM20 4h-3.5v5c0 .55-.45 1-1 1s-1-.45-1-1V4h-2v16h-2V4h-.5a1.5 1.5 0 00-1.5-1.5A1.5 1.5 0 001 4c0-.28-.22-.5-.5-.5a1.5 1.5 0 10-1.5 1.5v.5a.5.5 0 00.5.5z\"/>\n        </svg>\n      </button>\n      <button class=\"cart-icon\" aria-label=\"View cart\">\n        <svg width=\"24\" height=\"24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" viewBox=\"0 0 24 24\" xmlns=\"http://www.w3.org/2000/svg\">\n          <path d=\"M3 3l18 18\"\n                stroke-linecap=\"round\"\n                stroke-linejoin=\"round\"\n                stroke-width=\"2\"/>\n        </svg>\n      </button>\n    </div>\n  </header>\n</div>\n\n<nav class=\"mobile-menu\" aria-label=\"Mobile navigation menu\">\n  <button class=\"hamburger\" aria-label=\"Toggle mobile navigation menu\">\n    <svg width=\"24\" height=\"24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" viewBox=\"0 0 24 24\" xmlns=\"http://www.w3.org/2000/svg\">\n      <path d=\"M3 18h18v-2H3v2zm0-8h18v-2H3v2zm0-8h18v-2H3v2zm1.5-9L4.5 12l1.5 1.5 5-5zm11.25 11.25L21 12 23.5 9.5z\"/>\n    </svg>\n  </button>\n  <ul class=\"nav-links\">\n    {% for link in section.settings.menu %}\n      <li>\n        <a href=\"{{ link.url }}\" aria-label=\"{{ link.text }}\">{{ link.text | escape }}</a>\n      </li>\n    {% endfor %}\n  </ul>\n</nav>\n\n<style>\n  .logo-wrapper {\n    display: flex;\n    align-items: center;\n  }\n  .nav-menu {\n    display: flex;\n    align-items: center;\n  }\n  .hamburger {\n    display: none;\n  }\n  .search-icon {\n    display: none;\n  }\n  .cart-icon {\n    display: none;\n  }\n  .mobile-menu {\n    display: none;\n  }\n  @media (max-width: 768px) {\n    .nav-menu {\n      flex-direction: column;\n    }\n    .hamburger {\n      display: block;\n    }\n    .search-icon {\n      display: block;\n    }\n    .cart-icon {\n      display: block;\n    }\n    .mobile-menu {\n      display: flex;\n      position: fixed;\n      top: 0;\n      left: 0;\n      width: 100%;\n      height: 100vh;\n      background-color: #34C759;\n      padding: 20px;\n      box-sizing: border-box;\n      transform: translateX(-100%);\n      transition: transform 0.3s ease;\n    }\n    .mobile-menu.open {\n      transform: translateX(0);\n    }\n  }\n</style>\n