{% schema %}
{
  "name": "Page Call-out",
  "settings": [
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    }
  ],
  "presets": [
    {
      "name": "Default"
    }
  ],
  "blocks": [],
  "responsive_notes": "Hide call-out on mobile"
}
{% endschema %}
<div class="callout-container">
  <h2>{{ cta_label | escape }}</h2>
  <p>{{ cta_label | escape }}: <a href="{{ cta_url | escape }}">Learn More</a></p>
</div>

<style>
  .callout-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 20px;
    background-color: #F2F2F2;
    border: 1px solid #ddd;
    border-radius: 10px;
    box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
  }
  h2 {
    font-family: Montserrat;
    font-size: 24px;
    color: #34C759;
  }
  p {
    font-family: Lato;
    font-size: 18px;
    color: #666;
  }
</style>

<script>
  var calloutContainer = document.querySelector('.callout-container');
  calloutContainer.addEventListener('click', function() {
    alert('Call-out container clicked!');
  });
</script>