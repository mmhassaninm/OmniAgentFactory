<section class=\"call-to-action\" role=\"region\" aria-label=\"Call to Action\">\
  <div class=\"container\">\
    <h2>{{ heading | escape }}</h2>\
    <p>{{ subheading | escape }}</p>\
    <a href=\"{{ cta_url | escape }}\" class=\"btn\">{{ cta_label | escape }}</a>\
  </div>\
</section>{% schema %>\
  {\
    \"name\": \"Call to Action\",\
    \"settings\": [\
      {\
        \"type\": \"text\",\
        \"id\": \"heading\",\
        \"label\": \"Heading\"\
      },\
      {\
        \"type\": \"text\",\
        \"id\": \"subheading\",\
        \"label\": \"Subheading\"\
      },\
      {\
        \"type\": \"text\",\
        \"id\": \"cta_label\",\
        \"label\": \"Button label\"\
      },\
      {\
        \"type\": \"url\",\
        \"id\": \"cta_url\",\
        \"label\": \"Button URL\"\
      }\
    ],\
    \"presets\": [\
      {\
        \"name\": \"Default\"\
      }\
    ]\
  }{% endschema %}