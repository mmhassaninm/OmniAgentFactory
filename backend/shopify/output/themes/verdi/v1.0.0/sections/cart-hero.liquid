<section class="cart-hero" aria-label="View your cart">  <div class="cart-hero-image" style="background-image: url('{{ section.settings.image | image_url: width: 1200 }}');"></div>   <h1 class="cart-hero-heading">{{ section.settings.heading | escape }}</h1>  <p class="cart-hero-total">{{ section.settings.total | money }}</p></section>{% schema %}  {    "name": "cart-hero",    "settings": [      { "type": "image_picker", "id": "image", "label": "Background image" },      { "type": "text", "id": "heading", "label": "Heading", "default": "Your Cart" },      { "type": "text", "id": "total", "label": "Total", "default": "$0.00" }    ],    "presets": [      { "name": "Default" }    ]  }{% endschema %}