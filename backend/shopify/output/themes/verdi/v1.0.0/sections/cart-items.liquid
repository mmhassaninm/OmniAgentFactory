<section class="cart-items section" role="region" aria-labelledby="cart-items-label">
  <h2 id="cart-items-label" class="section-title">{{ section.settings.title | escape }}</h2>
  <div class="cart-grid">
    {% for item in section.blocks.cart-item %}
      <div class="cart-item">
        <img src="{{ item.settings.product | image_url: width: 80 | alt: item.settings.product.title }}" alt="{{ item.settings.product.title }}">
        <h3>{{ item.settings.product.title }}</h3>
        <p>{{ item.settings.product.price | money }}</p>
        <p>Quantity: {{ item.settings.product.quantity }}</p>
        <p>Subtotal: {{ item.settings.product.price | money }}</p>
      </div>
    {% endfor %}
  </div>
  {% schema %}
  {
    "name": "cart-items",
    "settings": [
      {
        "type": "text",
        "id": "title",
        "label": "Cart title",
        "default": "Your Cart"
      }
    ],
    "presets": [
      {
        "name": "Default"
      }
    ],
    "blocks": [
      {
        "type": "cart-item",
        "name": "cart-item",
        "settings": [
          {
            "type": "product",
            "id": "product"
          }
        ]
      }
    ],
    "responsive_notes": "Increase font size on mobile"
  }
  {% endschema %}
</section>

{% schema %}
{
  "name": "cart-item",
  "settings": [
    {
      "type": "product",
      "id": "product"
    }
  ],
  "presets": [
    {
      "name": "Default"
    }
  ],
  "blocks": [],
  "responsive_notes": "Hide shipping options on mobile"
}
{% endschema %}