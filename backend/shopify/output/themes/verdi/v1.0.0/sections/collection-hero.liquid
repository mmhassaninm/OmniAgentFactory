<section class="collection-hero" role="region" aria-label="Collection Hero" aria-describedby="collection-hero-description">
  <div class="collection-hero__background" style="background-image: url('{{ section.settings.image | image_url: width: 1200 | alt: section.settings.image.alt }}');"></div>
  <header class="collection-hero__heading">
    <h1>{{ section.settings.heading }}</h1>
  </header>
  <div class="collection-hero__products">
    {% for product in section.settings.products.products %}
      <div class="collection-hero__product">
        <img class="collection-hero__product-image" src="{{ product.image | image_url: width: 400 | alt: product.title }}" alt="{{ product.title }}">
        <h2>{{ product.title }}</h2>
        <p>{{ product.price | money }}</p>
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Collection Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image",
      "default": ""
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Collection Name"
    },
    {
      "type": "product_list",
      "id": "products",
      "label": "Featured products",
      "product_list": {
        "limit": 3,
        "product_size": "medium",
        "sort_order": "manual",
        "sort_by": "title"
      }
    }
  ],
  "presets": [
    {
      "name": "Default"
    }
  ],
  "blocks": [],
  "responsive_notes": "Reduce hero height to 40vh on mobile"
}
{% endschema %}