<!-- Theme: Verdi | Niche: Eco-Friendly Products Store | Design: sustainable | Colors: primary=#34C759 bg=#F2F2F2 | Fonts: Montserrat / Lato -->

<section class="announcement-bar" role="region" aria-label="{{ 'announcement-bar.aria-label' | t }}">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-md-8 text-md-left text-center">
        <h2>{{ section.settings.heading | escape }}</h2>
        <p>{{ section.settings.subheading | escape }}</p>
      </div>
      <div class="col-md-4 text-md-right text-center">
        <a href="{{ section.settings.cta_url | escape }}" class="btn btn-primary" role="button" aria-label="{{ 'announcement-bar.cta-button-label' | t }}">{{ section.settings.cta_label | escape }}</a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "announcement-bar",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Announcement"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Promotional message"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    }
  ],
  "presets": [
    {
      "name": "Default"
    }
  ]
}
{% endschema %}