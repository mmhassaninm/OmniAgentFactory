<section class="featured-products" aria-label="{{ ' featured-products' | t }}">
  <div class="product-grid">
    {% for product in section.settings.products.products %}
      <div class="product-card">
        <img src="{{ product.image.src | image_url: width: 400 | alt: product.title | escape }}" alt="{{ product.title | escape }}" loading="lazy">
        <h2>{{ product.title | escape }}</h2>
        <p>{{ product.price | money | escape }}</p>
        <p>{{ product.reviews.rating | escape }}</p>
      </div>
    {% endfor %}
  </div>
{% schema %}
  {
    "name": "featured-products",
    "settings": [
      {
        "type": "product_list",
        "id": "products",
        "label": "Featured products",
        "default": []
      }
    ],
    "presets": [
      {
        "name": "default"
      }
    ],
    "blocks": [
      {
        "type": "product-card",
        "name": "product-card",
        "settings": [
          {
            "type": "product",
            "id": "product"
          }
        ]
      }
    ],
    "responsive_notes": "Reduce grid columns to 2 on mobile"
  }
{% endschema %}