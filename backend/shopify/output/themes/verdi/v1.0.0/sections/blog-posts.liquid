<section class="blog-posts" style="background-color: #F2F2F2;" role="region" aria-label="Blog posts"><!-- ARIA Label for screen readers --><div class="container"><h1>Latest Posts</h1><div class="grid"><ul>{% for post in collections.all.blog %}<li><div class="blog-post"><h2><a href="{{ post.url }}">{{ post.title }}</a></h2><p>{{ post.description | escape }}</p></div></li>{% endfor %}</ul></div></div></section>{% schema %}{% extends 'section-half-width.liquid' %}{% block settings %}<section class="settings"><h2>Blog Posts Settings</h2><div class="control-group"><label for="posts">Latest posts:</label><input id="posts" class="control" type="blog_list" name="posts" data-setting="posts"><span class="help">Select the latest blog posts to display.</span></div>{% endblock %}{% block presets %}<h2>Preset</h2>{% for preset in presets %}<div class="preset"><h3>{{ preset.name }}</h3><div class="preset-settings">{% for setting in preset.settings %}<div class="control-group"><label for="{{ setting.id }}">{{ setting.label }}:</label><input id="{{ setting.id }}" class="control" type="{{ setting.type }}" name="{{ setting.id }}" data-setting="{{ setting.id }}"><span class="help">{{ setting.help }}</span></div>{% endfor %}</div></div>{% endfor %}{% endblock %}{% block blocks %}<div class="block"><h2>Blog Post</h2><div class="block-settings"><div class="control-group"><label for="blog">Blog:</label><input id="blog" class="control" type="blog" name="blog" data-setting="blog"><span class="help">Select the blog to display posts from.</span></div></div></div>{% endblock %}{% block scripts %}{% endblock %}{% block styles %}{% endblock %}{% schema %}