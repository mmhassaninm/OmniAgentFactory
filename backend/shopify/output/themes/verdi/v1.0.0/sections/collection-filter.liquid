<section class="filter-section" aria-label="Filter products by {{ 'collection-filter.title' | t }}">  <h2 class="filter-title">{{ 'collection-filter.title' | t }}</h2>  <form class="filter-form">    {% for option in collection.filter_options %}      <div class="filter-option">        <input type="checkbox" id="{{ option | handle }}" name="filter_option[]" value="{{ option | handle }}">        <label for="{{ option | handle }}">{{ option }}</label>      </div>    {% endfor %}  </form></section>{% schema %}  {    "name": "collection-filter",    "settings": [      {        "type": "text",        "id": "title",        "label": "Title",        "default": "Filter by"      }    ],    "presets": [      { "name": "Default" }    ]  }{% endschema %}