<!-- theme: Verdi, colors: #34C759, #F2F2F2 -->
<footer>
  <div class="container">
    <div class="copyright">
      {{ settings.copyright | escape }}
    </div>
    <ul class="social-links">
      {% for link in settings.social_links %}
        <li>
          <a href="{{ link.url | escape }}" aria-label="{{ link.label | escape }}" title="{{ link.label | escape }}">
            <svg viewBox="0 0 24 24" enable-background="new 0 0 24 24" height="24" width="24"><path d="M0 0h24v24H0V0z" fill="none"/><path d="M12 4c-5.523 0-10 4.477-10 10s4.477 10 10 10 10-4.477 10-10S17.523 4 12 4zm0 16c-4.418 0-8-3.582-8-8s3.582-8 8-8 8 3.582 8 8-3.582 8-8 8z" fill="#34C759"/></svg>
          </a>
        </li>
      {% endfor %}
    </ul>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "copyright",
      "label": "Copyright text",
      "default": "2023 Verdi"
    },
    {
      "type": "link_list",
      "id": "social_links",
      "label": "Social media links"
    }
  ],
  "presets": [
    {
      "name": "Default"
    }
  ]
}
{% endschema %}