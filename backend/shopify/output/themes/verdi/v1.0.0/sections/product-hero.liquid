<section class=\"product-hero\" role=\"region\" aria-label=\"Product Hero\">\
  <div class=\"container\">\
    <img src=\"{{ image | image_url: width: 1200 }}\" alt=\"{{ image.alt | escape }}\" role=\"img\" class=\"hero-image lazyload\" data-sizes=\"auto\"/>\
    <h1>{{ heading | escape }}</h1>\
    <p class=\"price\">{{ price | money }}</p>\
  </div>\
</section>{% schema %>\
  {\
    \"name\": \"Product Hero\",\
    \"settings\": [\
      {\
        \"type\": \"image_picker\",\
        \"id\": \"image\",\
        \"label\": \"Background image\"\
      },\
      {\
        \"type\": \"text\",\
        \"id\": \"heading\",\
        \"label\": \"Heading\"\
      },\
      {\
        \"type\": \"text\",\
        \"id\": \"price\",\
        \"label\": \"Price\"\
      }\
    ],\
    \"presets\": [\
      {\
        \"name\": \"Default\"\
      }\
    ]\
  }{% endschema %}