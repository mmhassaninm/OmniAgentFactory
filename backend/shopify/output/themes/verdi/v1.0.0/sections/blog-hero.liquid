<section class="blog-hero" style="background-color: #F2F2F2;" role="region" aria-label="Blog hero"><!-- ARIA Label for screen readers --><div class="container" style="background-image: url('{{ section.settings.image | image_url: width: 1200 | image_tag }}'); background-size: cover; background-position: center; height: 100vh;"><h1>{{ section.settings.heading | escape }}</h1><h2>{{ section.settings.title | escape }}</h2><div class="latest-posts"><ul>{% for post in collections.all.blog.limit(3) %}<li><a href="{{ post.url }}"><h3>{{ post.title }}</h3></a><p>{{ post.description | escape }}</p></li>{% endfor %}</ul></div></div></section>{% schema %}{% extends 'section-full-width.liquid' %}{% block settings %}<section class="settings"><h2>Blog Hero Settings</h2><div class="control-group"><label for="image">Background image:</label><input id="image" class="control" type="image_picker" name="image" data-setting="image"><span class="help">Upload an image for the background.</span></div><div class="control-group"><label for="heading">Heading:</label><input id="heading" class="control" type="text" name="heading" data-setting="heading"><span class="help">Enter the heading for the blog hero.</span></div><div class="control-group"><label for="title">Title:</label><input id="title" class="control" type="text" name="title" data-setting="title"><span class="help">Enter the title for the blog hero.</span></div>{% endblock %}{% block presets %}<h2>Preset</h2>{% for preset in presets %}<div class="preset"><h3>{{ preset.name }}</h3><div class="preset-settings">{% for setting in preset.settings %}<div class="control-group"><label for="{{ setting.id }}">{{ setting.label }}:</label><input id="{{ setting.id }}" class="control" type="{{ setting.type }}" name="{{ setting.id }}" data-setting="{{ setting.id }}"><span class="help">{{ setting.help }}</span></div>{% endfor %}</div></div>{% endfor %}{% endblock %}{% block blocks %}{% endblock %}{% block scripts %}{% endblock %}{% block styles %}{% endblock %}{% schema %}