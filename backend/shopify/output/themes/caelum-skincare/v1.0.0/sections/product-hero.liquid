<section data-section-id="product-hero" data-section-type="product-hero">\
  <div class="container mx-auto px-4 py-16 sm:px-6 lg:px-8">\
    <div class="bg-cover bg-center h-screen" style="background-image: url('{{ section.settings.image | image_url: width: 1200 | image_tag }}');">\
      <div class="absolute top-0 left-0 w-full h-full bg-gray-900 opacity-50"></div>\
      <div class="relative z-10 mx-auto max-w-7xl py-16 text-center">\
        <h1 class="text-3xl font-bold text-white tracking-tight sm:text-4xl">{{ section.settings.heading }}</h1>\
        <div class="text-lg font-medium text-white">{{ section.settings.price }}</div>\
        <div class="text-lg font-medium text-white">{{ section.settings.rating | times: 1 }}</div>\
      </div>\
    </div>\
  </div>\
</section>\
{% schema %}\
{\
  "name": "Product Hero",\
  "settings": [\
    {"type": "image_picker", "id": "image", "label": "Background image"},\
    {"type": "text", "id": "heading", "label": "Heading", "default": "Product Name"},\
    {"type": "text", "id": "price", "label": "Price", "default": "${{ price | money }}"},\
    {"type": "range", "id": "rating", "min": 1, "max": 5, "step": 1, "unit": "", "label": "Rating", "default": 5}\
  ],\
  "presets": [\
    {"name": "Product Hero"}\
  ],\
  "blocks": [],\
  "responsive_notes": "No changes on mobile"\
}{% endschema %}