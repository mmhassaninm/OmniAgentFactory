<section data-section-id="product-grid" data-section-type="product-grid">\
  <div class="container mx-auto px-4 py-16 sm:px-6 lg:px-8">\
    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">\
      {% for product in section.settings.products | product_grid: products %}\
        <div class="bg-white rounded-lg shadow-md p-4">\
          <div class="flex justify-center mb-4">\
            <img class="w-full h-48 object-cover" src="{{ product.image | image_url: width: 400 | img_url }}" alt="{{ product.title }}">\
          </div>\
          <div class="text-lg font-bold text-gray-800">{{ product.title }}</div>\
          <div class="text-gray-600">{{ product.price | money }}</div>\
        </div>\
      {% endfor %}\
    </div>\
  </div>\
</section>\
{% schema %}\
{\
  "name": "Product Grid",\
  "settings": [\
    {"type": "product_picker", "id": "products", "label": "Featured products", "default": "best-sellers"}\
  ],\
  "presets": [\
    {"name": "Product Grid"}\
  ],\
  "blocks": [\
    {"type": "product-grid-item", "name": "Product Grid Item", "settings": [\
      {"type": "product_picker", "id": "product", "label": "Product"}\
    ]}\
  ],\
  "responsive_notes": "Grid becomes a list on mobile"\
}{% endschema %}