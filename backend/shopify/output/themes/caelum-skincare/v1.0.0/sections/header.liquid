<!-- Header Section -->
<section class="header-section" role="banner">
  <div class="container">
    <nav class="header-nav" aria-label="{{ 'Header' | t }}">
      <div class="logo">
        <img src="{{ section.settings.logo | image_url: width: 1200 }}" alt="{{ section.settings.logo.alt | escape }}" loading="lazy">
      </div>
      <div class="menu">
        <ul>
          {% for item in settings.menu %}
            <li{% if item == settings.menu.last %} class="last{% endif %}"><a href="{{ item.url }}" title="{{ item.title | escape }}">{{ item.title | escape }}</a></li>
          {% endfor %}
        </ul>
      </div>
      <div class="search">
        <form role="search">
          <input type="search" placeholder="Search" aria-label="Search">
          <button type="submit">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M0 0h24v24H0V0z" fill="none"/><path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12l4.58-4.59z"/></svg>
          </button>
        </form>
      </div>
      <div class="cart">
        <a href="#"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M0 0h24v24H0V0z" fill="none"/><path d="M15.41 7.41L14 6 8 12 6 6 3.41 7.41 4.5 8l3.09 3.09L14 12z"/></svg>Cart ({{ cart.total_items }})</a>
      </div>
    </nav>
  </div>
</section>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 80,
      "max": 300,
      "step": 10,
      "unit": "px",
      "label": "Logo width",
      "default": 150
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    }
  ],
  "presets": [
    {
      "name": "Header"
    }
  ]
}
{% endschema %}