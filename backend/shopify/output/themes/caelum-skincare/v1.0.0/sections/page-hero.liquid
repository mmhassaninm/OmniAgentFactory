<section class="page-hero" role="region" aria-label="Page Hero">
  <div class="page-hero__content">
    <div class="page-hero__image" style="background-image: url('{{ section.settings.image | image_url: width: 1200 | escape }}');"></div>
    <h1 class="page-hero__heading" style="color: {{ theme.colors.primary }};">{{ section.settings.heading | escape }}</h1>
    <p class="page-hero__description" style="color: {{ theme.colors.text }};" aria-hidden="true">{{ section.settings.description | escape }}</p>
  </div>
</section>

{% schema %}
{
  "name": "Page Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Page Name"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed sit amet nulla auctor, vestibulum magna sed, convallis ex."
    }
  ],
  "presets": [
    {
      "name": "Page Hero"
    }
  ],
  "blocks": [],
  "responsive_notes": "No changes on mobile"
}
{% endschema %}