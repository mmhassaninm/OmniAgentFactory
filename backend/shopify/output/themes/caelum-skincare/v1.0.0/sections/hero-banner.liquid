{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Nourish Your Skin" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Discover our luxury skincare products" },
    { "type": "text", "id": "cta_label", "label": "Button label", "default": "Shop Now" },
    { "type": "url", "id": "cta_url", "label": "Button URL" }
  ],
  "presets": [
    { "name": "Hero Banner" }
  ],
  "blocks": [],
  "responsive_notes": "Stack vertically on mobile, reduce hero height to 60vh"
}
{% endschema %}

<div class="hero-banner">
  <img src="{{ section.settings.image | image_url: width: 1200 | escape }}" alt="{{ section.settings.image.alt }}">
  <h1>{{ section.settings.heading | escape }}</h1>
  <p>{{ section.settings.subheading | escape }}</p>
  <a href="{{ section.settings.cta_url | escape }}" class="btn">{{ section.settings.cta_label | escape }}</a>
</div>

<style>
  .hero-banner {
    background-color: #F2F2F2;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100vh;
    color: #455A64;
  }
  .hero-banner img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  .hero-banner h1 {
    font-family: Montserrat;
    font-size: 48px;
    margin-bottom: 16px;
  }
  .hero-banner p {
    font-family: Lato;
    font-size: 18px;
    margin-bottom: 32px;
  }
  .hero-banner a.btn {
    font-family: Montserrat;
    font-size: 18px;
    padding: 16px 32px;
    border-radius: 8px;
    background-color: #455A64;
    color: #F2F2F2;
    text-decoration: none;
  }
  .hero-banner a.btn:hover {
    background-color: #333;
  }
</style>

<script>
  // Add some lazy loading magic here
</script>

