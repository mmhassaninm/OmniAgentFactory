<!-- Announcement Bar Section -->
<section class="announcement-bar" role="complementary">
  <div class="container">
    <div class="announcement-bar-content">
      <h2>{{ section.settings.heading | escape }}</h2>
      <p>{{ section.settings.text | escape }}</p>
      <button>{{ 'Call to action' | t }}</button>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Announcement"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed sit amet nulla auctor, vestibulum magna sed, convallis ex."
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar"
    }
  ]
}
{% endschema %}