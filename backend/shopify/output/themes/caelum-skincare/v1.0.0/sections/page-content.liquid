{% schema %}
{
  "name": "Page Content",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Page Content"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed sit amet nulla auctor, vestibulum magna sed, convallis ex."
    }
  ],
  "presets": [
    {
      "name": "Default"
    }
  ],
  "description": "Page content with text and images"
}
{% endschema %}

<section class="page-content">
  <h2>{{ section.settings.heading | escape }}</h2>
  <p>{{ section.settings.text | escape }}</p>
  <img src="{{ section.settings.image | image_url: width: 400 }}" alt="{{ section.settings.image_alt | escape }}">
</section>