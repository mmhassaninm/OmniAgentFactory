{% schema %}
{
  "name": "Brand Story",
  "settings": [
    { "type": "text", "id": "heading", "label": "Brand Story", "default": "Our Story" },
    { "type": "text", "id": "text", "label": "Text", "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed sit amet nulla auctor, vestibulum magna sed, convallis ex." }
  ],
  "presets": [
    { "name": "Brand Story" }
  ],
  "blocks": [],
  "responsive_notes": "No changes on mobile"
}
{% endschema %}

<div class="brand-story">
  <h1>{{ section.settings.heading | escape }}</h1>
  <p>{{ section.settings.text | escape }}</p>
</div>

<style>
  .brand-story {
    font-family: Montserrat;
    font-size: 24px;
    color: #455A64;
  }
</style>