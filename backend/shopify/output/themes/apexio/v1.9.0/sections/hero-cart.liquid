{% schema %}
{
  "name": "Hero Cart",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Cart image"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Cart title"
    }
  ],
  "presets": [
    {"name": "Default"}
  ],
  "sections": [],
  "blocks": [],
  "default_settings": {}
}{% endschema %}

<div class="hero-cart">
  <img src="{{ settings.image | image_url: width: 800 }}" alt="{{ settings.title | escape }}">
  <h2>{{ settings.title | escape }}</h2>
</div>
