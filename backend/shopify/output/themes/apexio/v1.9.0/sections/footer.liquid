<footer class="bg-gray-200 py-12 text-gray-600">
  <div class="container mx-auto flex flex-col items-center justify-center pt-6 pb-6 md:flex-row md:justify-between">
    <div class="text-center mb-4 md:mb-0">
      <p class="text-gray-600">{{ settings.copyright | escape }}</p>
    </div>
    <nav class="flex justify-center md:justify-end -mx-4 mb-4 md:mb-0">
      <ul class="flex justify-center -mx-4 list-none">
        {% for link in settings.social_links %}
          <li class="mx-4">
            <a href="{{ link.url }}" class="text-gray-600 hover:text-gray-800" target="_blank" rel="noopener noreferrer">
              <svg class="w-6 h-6 text-gray-600 hover:text-gray-800" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            </a>
          </li>
        {% endfor %}
      </ul>
    </nav>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "text", "id": "copyright", "label": "Copyright text" },
    { "type": "link_list", "id": "social_links", "label": "Social links" }
  ],
  "presets": [
    { "name": "Footer" }
  ]
}
{% endschema %}