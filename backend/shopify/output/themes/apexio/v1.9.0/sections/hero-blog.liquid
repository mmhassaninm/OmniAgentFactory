{% schema %}
{
  "name": "Hero Blog",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Blog image" },
    { "type": "text", "id": "title", "label": "Blog title" }
  ],
  "presets": [{ "name": "Hero Blog" }]
}
{% endschema %}

<div class="hero-blog" aria-label="Blog Hero">
  <div class="container">
    <div class="hero-image" style="background-image: url('{{ section.settings.image | image_url: width: 1200 }}');"></div>
    <h1>{{ section.settings.title }}</h1>
  </div>
</div>
