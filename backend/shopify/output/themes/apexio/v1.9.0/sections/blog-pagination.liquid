<section class="container mb-12 md:mb-16 lg:mb-20 lg:px-12 xl:px-24">
  <h2 class="text-lg font-bold mb-4 lg:mb-6">{{ settings.title | escape }}</h2>
  <div class="flex justify-between mb-4 lg:mb-6">
    <a href="{{ settings.prev_link | t | escape }}" class="text-md font-bold text-primary hover:text-darker">Previous</a>
    <a href="{{ settings.next_link | t | escape }}" class="text-md font-bold text-primary hover:text-darker">Next</a>
  </div>
  <div class="w-full lg:w-1/2 xl:w-1/3 mb-6 lg:mb-8 lg:px-4 xl:px-8">
    <img src="{{ settings.prev_link | image_url: width: 1200 | image_tag }}" class="w-full h-full object-cover object-center mb-4 lg:mb-8">
  </div>
</section>

{% schema %}
{
  "name": "Blog Pagination",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Pagination title"
    },
    {
      "type": "link",
      "id": "prev_link",
      "label": "Previous link"
    },
    {
      "type": "link",
      "id": "next_link",
      "label": "Next link"
    }
  ],
  "presets": [
    {
      "name": "Blog Pagination"
    }
  ]
}
{% endschema %}