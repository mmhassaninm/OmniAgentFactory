<section class="container mb-20 lg:px-12 xl:px-24 bg-cover bg-center bg-no-repeat" style="background-image: url('{{ settings.image | image_url: width: 1200 }}'); background-size: cover;">
  <div class="relative z-10 py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold leading-tight text-white mb-4 lg:mb-6">{{ settings.title | escape }}</h2>
      <div class="flex justify-between mb-4 lg:mb-6">
        <a href="#" class="text-md font-bold text-primary hover:text-darker">Back</a>
        <a href="#" class="text-md font-bold text-primary hover:text-darker">Home</a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Page Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Page image"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Page title"
    }
  ],
  "presets": [
    {
      "name": "Page Hero"
    }
  ]
}
{% endschema %}