{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Welcome"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": ""
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}

<section class="hero-banner" style="background-image: url('{{ section.settings.image | image_url: width: 1200 }}'); background-size: cover; background-position: center;" role="region" aria-label="Hero banner">
  <div class="container">
    <h1>{{ section.settings.heading }}</h1>
    <h2>{{ section.settings.subheading }}</h2>
    <a href="{{ section.settings.cta_url }}" class="btn" role="button" aria-label="{{ section.settings.cta_label }}">{{ section.settings.cta_label }}</a>
  </div>
</section>