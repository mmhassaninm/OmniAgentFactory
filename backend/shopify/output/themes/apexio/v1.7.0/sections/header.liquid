{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo" },
    { "type": "range", "id": "logo_width", "min": 80, "max": 300, "step": 10, "unit": "px", "label": "Logo width", "default": 150 },
    { "type": "link_list", "id": "menu", "label": "Navigation menu", "default": "main-menu" }
  ],
  "presets": [{ "name": "Header" }]
}
{% endschema %}

<div class="header" style="background-color: {{ settings.bg_color | color: '#f9f9f9' }};">
  <div class="container">
    <div class="logo" style="width: {{ settings.logo_width }}px;">
      <img src="{{ settings.logo | image_url: width: 1200 | image_tag }}" alt="Apexio Logo">
    </div>
    <nav class="nav">
      <ul>
        {{ block.settings.menu | link_list: separator: ', ' }}
      </ul>
    </nav>
    <div class="search">
      <!-- search form goes here -->
    </div>
    <div class="cart-icon">
      <!-- cart icon goes here -->
    </div>
  </div>
</div>

{%- if settings.search != blank -%}
  <div class="search-form">
    <form>
      <input type="search" placeholder="Search...">
    </form>
  </div>
{%- endif -%}

{%- if settings.cart != blank -%}
  <div class="cart">
    <a href="{{ routes.cart }}">
      <img src="{{ 'cart-icon.png' | asset_url }}" alt="Cart Icon">
      <span>{{ cart.items_count }}</span>
    </a>
  </div>
{%- endif -%}