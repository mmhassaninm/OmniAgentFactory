{% schema %}
{
  "name": "Call to Action",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Get 10% Off Your First Order"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Sign up for our newsletter and get 10% off your first order"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Sign up URL"
    }
  ],
  "presets": [
    {
      "name": "Call to Action"
    }
  ]
}
{% endschema %}

<div class="call-to-action" style="background-color: {{ settings.bg_color | hex }}">
  <h2>{{ settings.heading | escape }}</h2>
  <p>{{ settings.subheading | escape }}</p>
  <a href="{{ settings.cta_url | escape }}" style="background-color: {{ settings.bg_color | hex }}; color: {{ settings.text_color | hex }}">Sign Up</a>
</div>