{% schema %}
{
  "name": "Blog Grid",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Blog collection"
    },
    {
      "type": "range",
      "id": "grid_columns",
      "min": 1,
      "max": 5,
      "step": 1,
      "unit": "",
      "label": "Grid columns",
      "default": 3
    }
  ],
  "presets": [{"name": "Blog Grid"}]
}
{% endschema %}

<div class="blog-grid" style="grid-template-columns: repeat({{ section.settings.grid_columns }}, 1fr);">
  {% for post in collection.products %}
    <div class="blog-grid-item">
      <img src="{{ post.image | image_url: width: 400 }}" alt="{{ post.image.alt }}" />
      <h2>{{ post.title }}</h2>
    </div>
  {% endfor %}
</div>