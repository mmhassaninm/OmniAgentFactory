{% schema %}
{
  "name": "Collection Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Collection Name"
    }
  ],
  "presets": [
    {
      "name": "Collection Hero"
    }
]
}
{% endschema %}

<div class="collection-hero">
  <div class="collection-hero__image" style="background-image: url('{{ section.settings.image | image_url: width: 1200 }}');"></div>
  <div class="collection-hero__heading">{{ section.settings.heading | escape }}</div>
</div>