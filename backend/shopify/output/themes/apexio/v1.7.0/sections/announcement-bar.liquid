<section class="announcement-bar" role="alert" aria-label="Announcement Bar">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-12 col-md-10 mx-auto text-center">
        <h3 class="mb-1 text-primary" style="color: {{ theme.settings.primary_color }}">{{ section.settings.heading | escape }}</h3>
        <p class="mb-0" style="color: {{ theme.settings.primary_color }}">{{ section.settings.subheading | escape }}</p>
        <a href="{{ section.settings.cta_url | escape }}" class="btn btn-primary" style="background-color: {{ theme.settings.primary_color }}; color: #f9f9f9">Call to Action</a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Limited Time Offer"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Get 10% off your first order"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL"
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar"
    }
  ]
}
{% endschema %}

<style>
  .announcement-bar {
    background-color: {{ theme.settings.bg_color }};
    padding: 0.5rem;
    border-bottom: 1px solid #ccc;
  }

  @media (max-width: 768px) {
    .announcement-bar {
      height: 40vh;
      flex-direction: column;
      align-items: center;
    }
  }
</style>
