<section class="page-hero">
  <div class="container">
    <img src="{{ section.settings.image | image_url: width: 1200 }}" alt="{{ section.settings.heading }}">
    <h1>{{ section.settings.heading }}</h1>
  </div>
</section>

{% schema %}
{
  "name": "Page Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Page Name"
    }
  ],
  "presets": [
    {
      "name": "Page Hero"
    }
  ],
  "blocks": [],
  "responsive_notes": "Reduce hero height to 40vh on mobile"
}
{% endschema %}