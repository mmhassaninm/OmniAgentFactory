{% schema %}
{
  "name": "Blog Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Blog Name"
    }
  ],
  "presets": [{"name": "Blog Hero"}]
}
{% endschema %}

<section class="blog-hero" style="background-image: {{ section.settings.image | image_url: width: 1200 | alt: section.settings.heading }};">
  <div class="container">
    <h1>{{ section.settings.heading }}</h1>
  </div>
</section>