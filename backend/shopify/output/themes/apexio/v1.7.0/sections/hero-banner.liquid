{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Welcome"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": ""
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}

<section class="hero-banner" style="background-color: #f9f9f9;">
  <div class="hero-banner-content">
    <img src="{{ section.settings.image | image_url: width: 1200 }}" alt="" style="width: 100%; height: 100%; object-fit: cover;">
    <div class="container">
      <h1>{{ section.settings.heading | escape }}</h1>
      <h3>{{ section.settings.subheading | escape }}</h3>
      <p><a href="{{ section.settings.cta_url | escape }}" class="btn btn-primary">{{ section.settings.cta_label | escape }}</a></p>
    </div>
  </div>
</section>