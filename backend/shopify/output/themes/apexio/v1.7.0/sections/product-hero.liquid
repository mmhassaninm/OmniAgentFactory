{% schema %}
{
  "name": "Product Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Product Name"
    }
  ],
  "presets": [
    {
      "name": "Product Hero"
    }
  ]
}
{% endschema %}

<div class="product-hero" style="background-image: url('{{ settings.image | image_url: width: 1200 | escape }}'); background-size: cover; background-position: center; height: {{ settings.hero_height | money | escape }}vh;">
  <h1>{{ settings.heading | escape }}</h1>
</div>