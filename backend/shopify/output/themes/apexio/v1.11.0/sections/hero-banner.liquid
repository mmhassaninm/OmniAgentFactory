<section class="hero-banner" style="background-image: linear-gradient(#{% if section.settings.bg_color %}{{ section.settings.bg_color }}{% else %}#{% if section.settings.bg_color_hex %}{{ section.settings.bg_color_hex }}{% else %}#{% if section.settings.bg %}{{ section.settings.bg }}{% else %}#{% if settings.bg_color %}{{ settings.bg_color }}{% else %}#{% if settings.bg_color_hex %}{{ settings.bg_color_hex }}{% else %}#f9f9f9{% endif %}{% endif %}{% endif %}{% endif %}{% endif %}" background-size: cover;">
  <div class="container">
    <h1>{{ section.settings.heading | escape }}</h1>
    <p>{{ section.settings.subheading | escape }}</p>
    <a href="{{ section.settings.cta_url | escape }}" class="btn">{{ section.settings.cta_label | escape }}</a>
  </div>
  <div class="bg-image" style="background-image: url('{{ section.settings.image | image_url: width: 1200 | escape }}');" role="img" aria-label="Background Image"></div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Welcome to Apexio"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Shop the latest products"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    }
  ],
  "presets": [{"name": "Hero Banner"}]
}
{% endschema %}