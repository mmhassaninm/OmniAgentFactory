{% schema %}
{
  "name": "Page Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Page title",
      "default": "{page.title}"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Learn More"
    }
  ],
  "presets": [{ "name": "Page Hero" }]
}
{% endschema %}
<div class="hero" style="background-image: url({{ section.settings.image | image_url: width: 1200 }}); background-size: cover; background-position: center center;">
  <h1>{{ section.settings.heading }}</h1>
  <a href="{{ section.settings.cta_label | t }}" class="button" style="background-color: {{ theme.color.primary }};">{{ section.settings.cta_label }}</a>
</div>