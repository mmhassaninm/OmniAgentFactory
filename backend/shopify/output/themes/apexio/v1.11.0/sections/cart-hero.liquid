{% comment %}Cart Hero{% endcomment %}

<section class="cart-hero" aria-label="Cart hero">
  <div class="cart-hero__image">
    <img src="{% if section.settings.image %}{{ section.settings.image | image_url: width: 800 }}{% else %}{{ 'default-image.jpg' | image_url }}{% endif %}" alt="{{ 'Default Image Alt' | t }}" />
  </div>
  <div class="cart-hero__content">
    <h2>{{ section.settings.heading | escape }}</h2>
    <p>Subtotal: {{ section.settings.heading | money }}</p>
  </div>
</section>

{% schema %}
{
  "name": "Cart Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Cart subtotal",
      "default": "{cart.subtotal | money}"
    }
  ],
  "presets": [
    {
      "name": "Default"
    }
  ]
}
{% endschema %}