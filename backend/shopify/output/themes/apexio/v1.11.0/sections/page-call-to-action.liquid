{% schema %}
{
  "name": "Page Call-to-Action",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Limited-time offer",
      "default": "Get 10% off your first order"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Shop Now"
    }
  ],
  "presets": [{"name": "Page Call-to-Action"}]
}
{% endschema %}

<div class="container mx-auto p-4 pt-6 md:p-6 text-center">
  <h2>{{ settings.heading | escape }}</h2>
  <a href="{{ routes.cart_url }}" class="bg-{{ settings.bg_color }} hover:bg-{{ settings.bg_color }}-dark text-white font-bold py-2 px-4 rounded">
    {{ settings.cta_label | escape }}
  </a>
</div>