<section class="collection-grid" style="--primary-color: #3498db; --bg-color: #f9f9f9;"><div class="grid"><ul>{% for product in section.settings.products %}<li><a href="{{ product.url }}"><img src="{{ product.image | image_url: width: 200 }}" alt="{{ product.title }}"><h2>{{ product.title }}</h2><p>{{ product.price | money }}</p></a></li>{% endfor %}</ul></div></section>{% schema %}{% assigns settings = section.settings %}{% schema %}
{
  "name": "Collection Grid",
  "settings": [
    {
      "type": "product_list",
      "id": "products",
      "label": "Collection products",
      "default": "grid"
    }
  ],
  "presets": [
    {
      "name": "Collection Grid"
    }
  ]
}{% endschema %}