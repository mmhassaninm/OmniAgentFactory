{% schema %}
{
  "name": "Call to Action",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Limited-time offer",
      "default": "Get 10% off your first order"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Shop Now"
    }
  ],
  "presets": [{ "name": "Default" }]
}
{% endschema %}
<section class="call-to-action">
  <div class="container">
    <h2>{{ settings.heading | escape }}</h2>
    <a href="#" class="btn btn-primary">{{ settings.cta_label | escape }}</a>
  </div>
</section>