<section class="cart-actions"
  aria-label="{{ 'cart.actions' | t }}">
  <button
    class="btn btn--primary"
    type="button"
  >
    {{ settings.cta_label | escape }}
  </button>
  <button
    class="btn btn--secondary"
    type="button"
  >
    {{ 'cart.clear' | t }}
  </button>
</section>

{% schema %}
{
  "name": "Cart actions",
  "settings": [
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Checkout"
    }
  ],
  "presets": [
    {
      "name": "Cart actions"
    }
  ]
}
{% endschema %}