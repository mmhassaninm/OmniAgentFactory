{% schema %}
{
  "name": "Add to Cart",
  "settings": [
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Add to Cart"
    }
  ],
  "presets": [{"name": "Add to Cart"}]
}
{% endschema %}
<button class="btn btn-primary" onclick="this.disabled = true; this.textContent = 'Loading...'; this.dataset.ajax = 'true'; this.dataset.quantity = '{{ section.settings.cta_label }}'; this.dataset.product_id = '{{ product.id }}'; {{ 'sections/product-add-to-cart.js' | asset_url | image_url: width: 800 | image_tag }}"><i class="fas fa-cart-plus"></i> {{ section.settings.cta_label }}</button>