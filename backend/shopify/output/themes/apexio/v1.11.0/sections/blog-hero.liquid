{% schema %}
{
  "name": "Blog Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Blog title",
      "default": "Latest Blog Posts"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Read More"
    }
  ],
  "presets": [{ "name": "Blog Hero" }]
}
{% endschema %}

<section class="blog-hero" role="region" aria-label="Blog hero">
  <div class="container">
    <div class="row justify-content-center align-items-center" style="height: {{ section.settings.image | image_url: width: 800 | resize: '800x600' }};">
      <div class="col-md-6 text-center">
        <h1>{{ section.settings.heading | escape }}</h1>
        <a class="btn btn-primary" href="#"><span class="text-white" style="color: #3498db">{{ section.settings.cta_label | escape }}</span></a>
      </div>
      <div class="col-md-6 text-center">
        <img src="{{ section.settings.image | image_url: width: 800 | resize: '800x600' }}" alt="" style="object-fit: cover; width: 100%; height: 100%;">
      </div>
    </div>
  </div>
</section>
