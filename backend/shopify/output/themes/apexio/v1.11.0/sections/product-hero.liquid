{% schema %}
{
  "name": "Product Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Product name",
      "default": "{product.title}"
    },
    {
      "type": "text",
      "id": "price",
      "label": "Price",
      "default": "{product.price | money}"
    }
  ],
  "presets": [{ "name": "Default" }]
}
{% endschema %}
<section class="product-hero">
  <div class="container">
    <div class="hero-image" style="background-image: url('{{ settings.image | image_url: width: 1200 }}');"></div>
    <h1>{{ settings.heading | escape }}</h1>
    <p>{{ settings.price | escape }}</p>
  </div>
</section>