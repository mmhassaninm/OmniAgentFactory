{% schema %}
{
  "name": "Blog Header",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Blog"
    },
    {
      "type": "link_list",
      "id": "filters",
      "label": "Filters",
      "default": "category, date"
    }
  ],
  "presets": [{"name": "Blog Header"}]
}
{% endschema %}

<div class="grid-container">
  <div class="grid-x align-middle">
    <div class="cell medium-10 medium-offset-1">
      <h2>{{ settings.title }}</h2>
      <ul class="menu list-reset">
        {% for filter in settings.filters.split(',') %}
          <li>{{ filter | escape }}</li>
        {% endfor %}
      </ul>
    </div>
  </div>
</div>

<style>
  .grid-container {
    background-color: #f9f9f9;
    padding: 20px;
  }
  .grid-x {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
  }
  .grid-x.align-middle {
    align-items: center;
  }
  .cell {
    padding: 20px;
  }
  .cell.medium-10.medium-offset-1 {
    width: 75%;
  }
</style>