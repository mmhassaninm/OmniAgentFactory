<!-- Product Grid Section -->
<section class="product-grid" aria-label="{{ 'products.featured' | t }}">
  <div class="product-grid__wrapper">
    {% for product in section.settings.product_ids %}
      <a href="{{ product.url }}" class="product-grid__item">
        <img src="{{ product.image | image_url: width: 400 | image_tag }}" alt="{{ product.image.alt }}" width="{{ product.image.width }}" height="{{ product.image.height }}">
        <h2>{{ product.title }}</h2>
        <p>{{ product.price | money }}</p>
      </a>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Product Grid",
  "settings": [
    {
      "type": "array",
      "id": "product_ids",
      "label": "Featured products",
      "default": []
    },
    {
      "type": "range",
      "id": "grid_columns",
      "min": 1,
      "max": 5,
      "step": 1,
      "unit": "",
      "label": "Grid columns",
      "default": 4
    },
    {
      "type": "range",
      "id": "grid_gutter",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "label": "Grid gutter",
      "default": 10
    }
  ],
  "presets": [
    {
      "name": "Product Grid"
    }
  ]
}
{% endschema %}