<section class="blog-pagination">
  <div class="container">
    <div class="row">
      <div class="col-lg-12">
        <ul class="pagination">
          {% for page in collection.pages %}
            <li class="page-item{% if page.current %} active{% endif %}">
              <a href="{% page_url page %}">{{ page.title }}</a>
            </li>
          {% endfor %}
        </ul>
        <div class="pagination-control">
          <nav aria-label="Page navigation">
            <ul class="pagination">
              <li class="page-item"><a class="page-link" href="{% page_url page.prev %}">Previous</a></li>
              <li class="page-item"><span class="page-link">Page {{ page.current }}</span></li>
              <li class="page-item"><a class="page-link" href="{% page_url page.next %}">Next</a></li>
            </ul>
          </nav>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Blog Pagination",
  "settings": [
    {
      "type": "range",
      "id": "page_size",
      "min": 1,
      "max": 100,
      "step": 1,
      "unit": "",
      "label": "Page size",
      "default": 12
    }
  ],
  "presets": [
    {
      "name": "Blog Pagination"
    }
  ]
}
{% endschema %}