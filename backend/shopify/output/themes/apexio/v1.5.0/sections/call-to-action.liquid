{% schema %}{
  "name": "Call to Action",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Don\\'t miss out"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Shop our best-selling products"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    }
  ],
  "presets": [
    {
      "name": "Call to Action"
    }
]
}{% endschema %}

<section class="mt-4">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-lg-6">
        <h2>{{ heading | escape }}</h2>
        <p>{{ subheading | escape }}</p>
      </div>
      <div class="col-lg-6">
        <a href="{{ cta_url | escape }}" class="btn btn-primary btn-lg">{{ cta_label | escape }}</a>
      </div>
    </div>
  </div>
</section>