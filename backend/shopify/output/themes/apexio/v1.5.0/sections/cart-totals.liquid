<!-- Cart totals and checkout button -->
<section class="cart-totals" style="--primary-color:#3498db;--background-color:#f9f9f9">
  <h2>{{ 'cart.totals' | t }}</h2>
  <ul>
    <li>
      <h3>Total: {{ total | money }}</h3>
    </li>
    <li>
      <a href="{{ cta_url }}" class="btn">{{ 'cart.checkout' | t }}</a>
    </li>
  </ul>
</section>

{% schema %}
{
  "name": "Cart totals",
  "settings": [
    {
      "type": "price",
      "id": "total",
      "label": "Total",
      "default": "49.99"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    }
  ],
  "presets": [
    {
      "name": "Cart totals"
    }
  ]
}
{% endschema %}