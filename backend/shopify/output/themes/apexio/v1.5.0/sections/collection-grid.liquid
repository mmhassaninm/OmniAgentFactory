{% schema %}
{
  "name": "Collection Grid",
  "settings": [
    {
      "type": "array",
      "id": "product_ids",
      "label": "Collection products",
      "default": []
    },
    {
      "type": "range",
      "id": "grid_columns",
      "min": 1,
      "max": 5,
      "step": 1,
      "unit": "",
      "label": "Grid columns",
      "default": 4
    },
    {
      "type": "range",
      "id": "grid_gutter",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "label": "Grid gutter",
      "default": 10
    }
  ],
  "presets": [
    {
      "name": "Collection Grid"
    }
  ]
}
{% endschema %}

<div class="collection-grid">
  <div class="grid">
    {% for product in collection.products %}
      {% if product.id == section.settings.product_ids | last %}
        <div class="grid-item">
          <img src="{{ product.image | image_url: width: 400 }}" alt="{{ product.title | escape }}">
          <h2>{{ product.title | escape }}</h2>
          <p>{{ product.description | escape }}</p>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</div>