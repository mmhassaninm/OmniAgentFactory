{% schema %}
{
  "name": "Blog Post",
  "settings": [
    {
      "type": "image",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "text",
      "id": "date",
      "label": "Date"
    },
    {
      "type": "textarea",
      "id": "content",
      "label": "Content"
    }
  ],
  "presets": [{"name": "Blog Post"}]
}
{% endschema %}

<div class="blog-post">
  <h2>{{ settings.title }}</h2>
  <p>{{ settings.date }}</p>
  <p>{{ settings.content }}</p>
  <img src="{{ settings.image | image_url: width: 400 | image_tag }}">
</div>

<style>
  .blog-post {
    padding: 20px;
  }
</style>