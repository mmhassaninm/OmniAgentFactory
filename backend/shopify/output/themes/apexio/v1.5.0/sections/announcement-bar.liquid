<!-- Announcement bar section -->
<section class="announcement-bar" style="--primary-color: #3498db; --bg-color: #f9f9f9;">
  <div class="container">
    <div class="row">
      <div class="col-12">
        <h2>{{ heading | escape }}</h2>
        <p>{{ subheading | escape }}</p>
        <p class="discount">{{ 'Discount: ' | t }}{{ discount | money }}</p>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Limited time offer"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Get 10% off your first order"
    },
    {
      "type": "price",
      "id": "discount",
      "label": "Discount",
      "default": "10%"
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar"
    }
  ]
}
{% endschema %}
