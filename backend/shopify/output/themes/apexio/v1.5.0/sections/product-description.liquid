{% schema %}{
  "name": "Product Description",
  "settings": [
    { "type": "text", "id": "description", "label": "Description", "default": "Product description" },
    { "type": "text", "id": "features", "label": "Features", "default": "Product features" }
  ],
  "presets": [
    { "name": "Product Description" }
  ]
}{% endschema %}

<div class="product-description"> {{ section.settings.description | escape }}
  <ul>
    <li>{{ section.settings.features | escape }}</li>
  </ul>
</div>


<!-- Increase font size on mobile -->
<style>
  @media (max-width: 768px) {
    .product-description {
      font-size: 18px;
    }
  }
</style>
