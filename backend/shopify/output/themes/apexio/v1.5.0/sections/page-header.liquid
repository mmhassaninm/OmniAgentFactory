<section class="page-header">
  <div class="container">
    <div class="row">
      <div class="col-lg-12">
        <h1>{{ section.settings.title | escape }}</h1>
        <ol class="breadcrumb">
          {% for link in section.settings.breadcrumbs %}
            <li class="breadcrumb-item"><a href="{% if link == 'Home' %}{{ shop.url }}{% else %}{{ link | escape }}{% endif %}">{{ link | escape }}</a></li>
          {% endfor %}
        </ol>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Page Header",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Page Title"
    },
    {
      "type": "link_list",
      "id": "breadcrumbs",
      "label": "Breadcrumbs",
      "default": "Home > Page"
    }
  ],
  "presets": [
    {
      "name": "Page Header"
    }
  ]
}
{% endschema %}