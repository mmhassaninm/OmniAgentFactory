{% schema %}{"name": "Product Description", "settings": [{"type": "text", "id": "description", "label": "Description"}], "blocks": [{"type": "feature_list", "name": "Feature List", "settings": [{"type": "text", "id": "feature", "label": "Feature"}]}], "responsive_notes": "Hide feature list on mobile"}{% endschema %}

{% assign description = section.settings.description | escape %}
{% if description != blank %}
<div class="product-description">
  <h2>{{ 'product.general.description' | t }}</h2>
  <p>{{ description }}</p>
</div>
{% endif %}

{% for block in section.blocks %}
{% if block.type == 'feature_list' %}
<ul class="feature-list">
  {% for feature in block.settings.feature %}
  <li>{{ feature | escape }}</li>
  {% endfor %}
</ul>
{% endif %}
{% endfor %}