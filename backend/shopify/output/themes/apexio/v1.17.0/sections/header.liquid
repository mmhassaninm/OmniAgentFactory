{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo" },
    { "type": "range", "id": "logo_width", "min": 80, "max": 300, "step": 10, "unit": "px", "label": "Logo width", "default": 150 },
    { "type": "link_list", "id": "menu", "label": "Navigation menu", "default": "main-menu" }
  ],
  "presets": [{ "name": "Header" }]
}
{% endschema %}

<header class="header" aria-label="Header">
  <div class="header-inner container">
    <a class="logo" href="{% link index" style="width: {{ settings.logo_width }}px" aria-label="Apexio logo">
      <img src="{{ settings.logo | image_url: width: 1200 }}" alt="Apexio logo">
    </a>
    <nav class="nav">
      <ul>
        {{ content_for_partial: 'menu' }}
      </ul>
    </nav>
    <div class="search">
      <form action="/search" method="get">
        <input type="search" placeholder="Search" name="q" value="" aria-label="Search input">
        <button type="submit" aria-label="Search button"><i class="fas fa-search"></i></button>
      </form>
    </div>
    <div class="cart">
      <a href="/cart" role="button" aria-label="Cart button"><i class="fas fa-shopping-cart"></i> <span class="cart-count">{{ cart.item_count }}</span></a>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo" },
    { "type": "range", "id": "logo_width", "min": 80, "max": 300, "step": 10, "unit": "px", "label": "Logo width", "default": 150 },
    { "type": "link_list", "id": "menu", "label": "Navigation menu", "default": "main-menu" }
  ],
  "presets": [{ "name": "Header" }]
}
{% endschema %}

<script>
  // Lazy load images
  var lazyImages = document.querySelectorAll("img.lazy");
  var observer = new IntersectionObserver(function(entries) {
    if (entries[0].isIntersecting) {
      entries[0].target.src = entries[0].target.dataset.src;
      entries[0].target.classList.remove("lazy");
      observer.unobserve(entries[0].target);
    }
  }, {
    rootMargin: "50px"
  });
  lazyImages.forEach(function(image) {
    observer.observe(image);
  });
</script>

<style>
  /* Custom styles for the header section */
  .header {
    background-color: #3498db;
    color: #fff;
    padding: 1rem;
    position: sticky;
    top: 0;
    z-index: 1;
  }
  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
  }
  .logo {
    display: inline-block;
    margin-right: 20px;
  }
  .nav {
    float: right;
  }
  .search, .cart {
    float: right;
    margin-left: 20px;
  }
</style>

<div id="header-placeholder"></div>

<script>
  // Add event listener to the header placeholder
  document.getElementById("header-placeholder").addEventListener("scroll", function() {
    var header = document.querySelector(".header");
    header.classList.toggle("scrolled", this.scrollTop > 0);
  });
</script>