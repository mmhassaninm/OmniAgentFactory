<style>
  /* Custom styles for the footer section */
  .footer {
    background-color: #f9f9f9;
    color: #333;
    padding: 1rem;
    text-align: center;
  }
  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
  }
  .contact-info {
    margin-bottom: 20px;
  }
