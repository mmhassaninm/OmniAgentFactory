{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "text", "id": "contact_info", "label": "Contact information" },
    { "type": "link_list", "id": "social_links", "label": "Social links" }
  ],
  "presets": [{ "name": "Footer" }]
}
{% endschema %}

<footer class="footer" aria-label="Footer">
  <div class="footer-inner container">
    <p class="contact-info">{{ settings.contact_info }}</p>
    <ul class="social-links">
      {{ settings.social_links | social_links }}
    </ul>
  </div>
</footer>

