{% schema %}
{
  "name": "Collection Grid",
  "settings": [
    {
      "type": "collection_list",
      "id": "collections",
      "label": "Featured collections"
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product Card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        }
      ]
    }
  ],
  "presets": [{ "name": "Collection Grid" }]
}
{% endschema %}

<div class="collection-grid">
  {% for collection in collections %}
    <div class="collection-grid-item">
      <h2>{{ collection.title | escape }}</h2>
      {% for product in collection.products %}
        <div class="product-card">
          <img src="{{ product.image | image_url: width: 400 | image_tag }}" alt="{{ product.title | escape }}">
          <h3>{{ product.title | escape }}</h3>
        </div>
      {% endfor %}
    </div>
  {% endfor %}
</div>