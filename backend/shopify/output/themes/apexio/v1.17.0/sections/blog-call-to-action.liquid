<section class="blog-cta">
  <h2>{{ section.settings.heading }}</h2>
  <p>{{ section.settings.subheading }}</p>
</section>{% schema %}
{
  "name": "Blog CTA",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Read more"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover new articles and insights"
    }
  ],
  "presets": [{"name": "Blog CTA"}]
}
{% endschema %}