<section class="cta-section">
  <div class="container">
    <h2>{{ section.settings.heading | escape }}</h2>
    <p>{{ section.settings.subheading | escape }}</p>
  </div>
</section>{% schema %}
{
  "name": "Call to Action",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Join our community"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Get exclusive discounts and early access"
    }
  ],
  "presets": [{"name": "Default CTA"}]
}
{% endschema %}