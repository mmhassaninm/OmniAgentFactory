{% schema %}
{
  "name": "Collection Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Apexio - Explore"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover our collections"
    }
  ],
  "presets": [{ "name": "Collection Hero" }]
}
{% endschema %}

<div class="collection-hero" style="background-image: {{ section.settings.image | image_url: width: 1200 | image_tag }};">
  <h1>{{ section.settings.heading | escape }}</h1>
  <p>{{ section.settings.subheading | escape }}</p>
  <button class="cta">Explore</button>
</div>