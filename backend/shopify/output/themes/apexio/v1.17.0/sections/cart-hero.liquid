<section class="cart-hero" style="--primary-color: #3498db; --background-color: #f9f9f9;">
  <img src="{{ settings.image | image_url: width: 1200 }}" alt="Cart background image" style="object-fit: cover; object-position: center; width: 100%; height: 100vh;">
  <h2 class="heading" style="color: var(--primary-color); text-align: center; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);">{{ settings.heading | escape }}</h2>
  <h3 class="subheading" style="color: var(--primary-color); text-align: center; position: absolute; bottom: 20px; left: 50%; transform: translate(-50%, -50%);">{{ settings.subheading | escape }}</h3>
</section>

{% schema %}
{
  "name": "Cart Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Apexio - Cart"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Review your order"
    }
  ],
  "presets": [{"name": "Cart Hero"}]
}
{% endschema %}