<section class="page-hero" style="background-image: url({{ section.settings.image | image_url: width: 1200 }})">
  <div class="hero-content">
    <h1>{{ section.settings.heading }}</h1>
    <p>{{ section.settings.subheading }}</p>
  </div>
</section>{% schema %}
{
  "name": "Page Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Apexio - Page"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Learn more about us"
    }
  ],
  "presets": [{"name": "Page Hero"}]
}
{% endschema %}