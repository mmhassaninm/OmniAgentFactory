<section class="blog-grid">
  <div class="grid-container">
    {% for post in section.settings.blog.articles %}
      <div class="grid-item">
        <a href="{{ post.url | absolute_url }}" aria-label="Read {{ post.title | escape }}">
          <img src="{{ post.featured_image | image_url: width: 400 }}" alt="{{ post.title | escape }}" loading="lazy" />
          <h2>{{ post.title }}</h2>
          <p>{{ post.excerpt }}</p>
        </a>
      </div>
    {% endfor %}
  </div>
</section>{% schema %}
{
  "name": "Blog Grid",
  "settings": [
    {
      "type": "blog_list",
      "id": "blog",
      "label": "Featured blog posts"
    }
  ],
  "presets": [{"name": "Blog Grid"}]
}
{% endschema %}