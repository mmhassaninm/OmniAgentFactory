{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Apexio - Shop Now"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover the best DTC products"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}

<main class="hero-banner" role="region" aria-label="Hero Banner">
  <section class="hero" style="background-image: url('{{ section.settings.image | image_url: width: 1200 | image_tag }}');">
    <div class="container">
      <h1>{{ section.settings.heading }}</h1>
      <p>{{ section.settings.subheading }}</p>
      <a href="{{ section.settings.cta_url }}" class="btn">{{ section.settings.cta_label }}</a>
    </div>
  </section>
</main>