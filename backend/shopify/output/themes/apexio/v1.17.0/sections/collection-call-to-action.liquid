<section class="collection-call-to-action" style="--primary-color: #3498db; --background-color: #f9f9f9;">
  <h2 class="heading" style="color: var(--primary-color)">{{ settings.heading | escape }}</h2>
  <h3 class="subheading" style="color: var(--primary-color)">{{ settings.subheading | escape }}</h3>
</section>

{% schema %}
{
  "name": "Collection Call to Action",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Explore more"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover new products and collections"
    }
  ],
  "presets": [{"name": "Collection Call to Action"}]
}
{% endschema %}