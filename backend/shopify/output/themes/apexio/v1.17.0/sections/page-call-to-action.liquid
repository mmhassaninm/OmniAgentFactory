{% schema %}
{
  "name": "Page Call to Action",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Take action" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Contact us to learn more" }
  ],
  "presets": [
    { "name": "Default" }
  ]
}
{% endschema %}

<div class="page-call-to-action">
  <h2>{{ section.settings.heading | escape }}</h2>
  <p>{{ section.settings.subheading | escape }}</p>
</div>

