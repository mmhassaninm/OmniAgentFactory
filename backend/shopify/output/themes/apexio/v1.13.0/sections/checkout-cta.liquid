{"% schema %}
{
  "name": "Checkout CTA",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Proceed to checkout" },
    { "type": "text", "id": "cta_label", "label": "Button label", "default": "Checkout Now" }
  ],
  "presets": [{ "name": "Checkout CTA" }]
}
{% endschema %}
<div class="cta-container">
  <h2>{{ settings.heading | escape }}</h2>
  <a href="#" class="cta-button" role="button" aria-label="{{ settings.cta_label | escape }}">
    {{ settings.cta_label | escape }}
  </a>
</div>