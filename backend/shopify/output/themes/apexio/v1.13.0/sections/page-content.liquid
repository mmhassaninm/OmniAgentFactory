{% schema %}
{
  "name": "Page Content",
  "settings": [
    {
      "type": "text",
      "id": "content",
      "label": "Page content"
    }
  ],
  "presets": [{"name": "Page Content"}]
}
{% endschema %}

<div class="page-content">
  {{ content | escape }}
  <img src="{{ 'default-image.jpg' | image_url: width: 800 }}" alt="Default Image">
</div>