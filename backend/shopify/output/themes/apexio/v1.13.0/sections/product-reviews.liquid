{% schema %}
{
  "name": "Product Reviews",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Product reviews",
      "default": "What our customers say"
    }
  ],
  "presets": [
    {
      "name": "Default"
    }
  ],
  "blocks": [
  ],
  "sections": [
  ],
  "default_settings": {}
}
{% endschema %}

<div class="product-reviews">
  <h2>{{ settings.heading | escape }}</h2>
  <div class="reviews">
    {{ section.settings.reviews | json }}
  </div>
</div>

{% responsive_notes %}
Review text increases font size on mobile