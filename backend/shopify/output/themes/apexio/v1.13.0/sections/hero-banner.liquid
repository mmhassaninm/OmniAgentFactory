<section class="hero-banner" aria-label="Hero banner section"><div class="hero-banner__image" style="background-image: url('{{ section.settings.image | image_url: width: 1200 | image_tag }}');"></div><h1 class="hero-banner__heading">{{ section.settings.heading | escape }}</h1><h2 class="hero-banner__subheading">{{ section.settings.subheading | escape }}</h2><button class="hero-banner__cta" aria-label="Shop now button" onclick="window.location.href = '{{ section.settings.cta_url }}';"><span>{{ section.settings.cta_label | escape }}</span></button>{% schema %}{% raw %}{% if settings.image != blank %}{% endif %}{% endif %}{% schema %}{% endschema %}<script>document.addEventListener('DOMContentLoaded', function(){ var ctaButton = document.querySelector('.hero-banner__cta'); ctaButton.addEventListener('click', function(){ ctaButton.blur(); }); });</script></section>{% schema %}{% raw %}{% if settings.image != blank %}{% endif %}{% endif %}{% schema %}{% endschema %}