<section class="call-to-action" aria-label="Call to Action">
  <div class="container flex flex-col items-center justify-center p-12 md:p-20">
    <h2 class="heading mb-4 mt-0 md:mt-12 text-2xl lg:text-4xl xl:text-5xl font-bold text-gray-800 text-center" data-aria-label="{{ section.settings.heading }}">{{ section.settings.heading }}</h2>
    <a href="{{ route_link 'shop.index' }}" class="btn btn-primary btn-block button px-12 py-4 lg:px-20 lg:py-6 rounded-md shadow-md focus:outline-none focus:ring-2 focus:ring-opacity-75 text-center" aria-label="{{ section.settings.cta_label }}">
      {{ section.settings.cta_label }}
    </a>
  </div>
</section>

{% schema %}
{
  "name": "Call to Action",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop now and discover more"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Explore Now"
    }
  ],
  "presets": [
    {
      "name": "Call to Action"
    }
  ],
  "blocks": [],
  "responsive_notes": "Button size increases on mobile"
}
{% endschema %}