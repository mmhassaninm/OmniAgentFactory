{% schema %}
{
  "name": "Page Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Page image"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Page title"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Page description"
    }
  ],
  "presets": [{"name": "Default"}]
}
{% endschema %}

<section class="page-hero" style="background-image: url('{{ section.settings.image | image_url: width: 1200 }}');">
  <div class="hero-content">
    <h1>{{ section.settings.title }}</h1>
    <p>{{ section.settings.description }}</p>
  </div>
</section>