<section class="product-hero" style="--primary-color: #3498db; --background-color: #f9f9f9">
  <div class="container">
    <img class="product-image" src="{{ section.settings.image | image_url: width: 1200 }}" alt="{{ section.settings.title }}" loading="lazy" aria-label="{{ section.settings.title }} image">
    <h1>{{ section.settings.title }}</h1>
    <p class="price">{{ section.settings.price | money }}</p>
  </div>
</section>

{% schema %}
{
  "name": "Product Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Product image"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Product title"
    },
    {
      "type": "price",
      "id": "price",
      "label": "Product price"
    }
  ],
  "presets": [
    {"name": "Product Hero"}
  ],
  "blocks": []
}
{% endschema %}