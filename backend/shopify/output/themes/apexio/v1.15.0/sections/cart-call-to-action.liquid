{% schema %}
{
  "name": "Cart Call-to-Action",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Proceed to Checkout"
    },
    {
      "type": "text",
      "id": "price",
      "label": "Price",
      "default": "$0.00"
    }
  ],
  "presets": [{ "name": "Proceed to Checkout" }]
}
{% endschema %}

{% if cart.items != empty %}
  <h2>{{ settings.heading | escape }}</h2>
  <p>Subtotal: {{ cart.subtotal_price | money }}</p>
  <p>Shipping: {{ cart.shipping_price | money }}</p>
  <p>Total: {{ cart.total_price | money }}</p>
  <button type="button" aria-label="Proceed to checkout"><a href="{{ routes.checkout }}">{{ settings.price | escape }}</a></button>
{% else %}
  <p>Cart is empty.</p>
  <button type="button" aria-label="Empty cart"><a href="{{ routes.cart }}">View cart</a></button>
{% endif %}