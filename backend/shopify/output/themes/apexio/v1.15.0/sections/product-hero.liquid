{% schema %}
{
  "name": "Product Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Product Name"
    }
  ],
  "presets": [
    {
      "name": "Default"
    }
  ]
}
{% endschema %}

<section class="product-hero" style="background-image: url('{{ section.settings.image | image_url:width:1200 }}'); background-size: cover; background-position: center; background-color: {{ section.settings.bg | default: '#f9f9f9' }};">
  <h1>{{ section.settings.heading | default: 'Product Name' | escape }}</h1>
  <p style="color: {{ theme.settings.primary_color | default: '#3498db' }};">From {{ price | money }}</p>
</section>
