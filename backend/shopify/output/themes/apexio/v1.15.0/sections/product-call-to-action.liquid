<section class="product-call-to-action">
  <h2>{{ settings.heading | escape | raw }}</h2>
  <span class="price">{{ settings.price | money }}</span>
  <button class="add-to-cart" aria-label="Add to Cart">Add to Cart</button>
</section>{% schema %}
{
  "name": "Product Call-to-Action",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Add to Cart"
    },
    {
      "type": "text",
      "id": "price",
      "label": "Price",
      "default": "$0.00"
    }
  ],
  "presets": [{"name": "Product Call-to-Action"}]
}
{% endschema %}