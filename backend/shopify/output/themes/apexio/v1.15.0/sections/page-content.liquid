{% schema %}
{
  "name": "Page Content",
  "settings": [
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": ""
    }
  ],
  "presets": [
    {
      "name": "Page Content"
    }
  ]
}
{% endschema %}

<div class="page-content">
  <h2>{{ section.settings.description | escape }}</h2>
  <div class="image">
    {{ section.settings.image | image_url: width: 400 | image_tag }}
  </div>
  <div class="spec">
    {{ section.settings.spec | escape }}
  </div>
</div>