{% schema %}
{
  "name": "Call to Action",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop Now"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Browse our latest products"
    }
  ],
  "presets": [
    {
      "name": "Default"
    }
  ]
}
{% endschema %}

<section class="call-to-action" style="background-color: {{ section.settings.bg | default: '#f9f9f9' }}">
  <h2>{{ section.settings.heading | escape }}</h2>
  <p>{{ section.settings.subheading | escape }}</p>
  <a href="{{ shop.url }}" class="btn btn-primary" style="background-color: {{ theme.settings.primary_color | default: '#3498db' }};">{{ section.settings.heading | default: 'Shop Now' }}</a>
</section>
