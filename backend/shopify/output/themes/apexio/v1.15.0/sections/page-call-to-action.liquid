{% schema %}
{
  "name": "Call-to-Action",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Call to Action"
    },
    {
      "type": "text",
      "id": "price",
      "label": "Price",
      "default": "$0.00"
    }
  ],
  "presets": [
    {
      "name": "Call-to-Action"
    }
  ]
}
{% endschema %}

<div class="call-to-action">
  <h2>{{ section.settings.heading | escape }}</h2>
  <p>{{ section.settings.price | escape }}</p>
  <button>Buy Now</button>
</div>