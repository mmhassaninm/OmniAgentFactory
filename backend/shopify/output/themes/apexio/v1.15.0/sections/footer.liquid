{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "copyright",
      "label": "Copyright text",
      "default": "Copyright 2023"
    },
    {
      "type": "text",
      "id": "social_links",
      "label": "Social media links",
      "default": ""
    },
    {
      "type": "text",
      "id": "contact_info",
      "label": "Contact information",
      "default": ""
    }
  ],
  "presets": [
    {
      "name": "Footer"
    }
  ]
}
{% endschema %}
<footer>
  <div class="copyright">
    {{ section.settings.copyright | escape }}
  </div>
  <div class="social-links">
    {{ section.settings.social_links | escape }}
  </div>
  <div class="contact-info">
    {{ section.settings.contact_info | escape }}
  </div>
</footer>

<style>
  footer {
    padding: 20px;
    background-color: #f9f9f9;
    border-top: 1px solid #ddd;
  }
  .copyright {
    font-size: 14px;
  }
  .social-links {
    display: flex;
  }
  .contact-info {
    font-size: 14px;
  }
</style>