{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Welcome"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": ""
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
]
}
{% endschema %}

<div class="hero-banner" style="background-image: url({{ section.settings.image | image_url: width: 1200 }});">
  <div class="container">
    <h1>{{ section.settings.heading | escape }}</h1>
    <p>{{ section.settings.subheading | escape }}</p>
    <a href="{{ section.settings.cta_url | escape }}" class="btn">{{ section.settings.cta_label | escape }}</a>
  </div>
</div>