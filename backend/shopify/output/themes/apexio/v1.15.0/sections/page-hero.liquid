{% schema %}
{
  "name": "Page Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Page Name"
    }
  ],
  "presets": [{ "name": "Page Hero" }]
}
{% endschema %}

<div class="c-page-hero" style="background-image: url('{{ image | image_url: width: 1200 }}'); background-size: cover; background-position: center; height: 80vh; display: flex; justify-content: center; align-items: center;">
  <h1>{{ heading | escape }}</h1>
</div>

<style>
  .c-page-hero {
    color: #f9f9f9;
    display: flex;
    justify-content: center;
    align-items: center;
    height: 80vh;
  }
  .c-page-hero h1 {
    font-size: 3em;
    font-weight: bold;
    color: #3498db;
  }
</style>