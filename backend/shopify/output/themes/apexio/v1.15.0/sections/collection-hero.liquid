<section class="hero">
  <div class="hero__background" style="background-image: url({{ section.settings.image | image_url: width: 1200 }});"></div>
  <div class="hero__content">
    <h1>{{ section.settings.heading }}</h1>
  </div>
</section>{% schema %}
{
  "name": "Collection Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Collection Name"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}