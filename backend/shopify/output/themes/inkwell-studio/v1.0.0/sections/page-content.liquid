{% schema %}
{
  "name": "Page Content",
  "settings": [
    {
      "type": "text",
      "id": "content",
      "label": "Content",
      "default": "Page content"
    }
  ],
  "presets": [
    {
      "name": "Default"
    }
  ],
  "blocks": [
  ],
  "responsive_notes": "Expand on mobile"
}
{% endschema %}

<div class="page-content">
  <h2>{{ block.settings.content | escape }}</h2>
  <div class="content">
    {{ content | escape }}
  </div>
</div>

<style>
  .page-content {
    max-width: 800px;
    margin: 0 auto;
    padding: 20px;
    background-color: #f9f9f9;
    border: 1px solid #ddd;
  }
</style>

<style>
  @media (max-width: 768px) {
    .page-content {
      max-width: 90vw;
    }
  }
</style>
