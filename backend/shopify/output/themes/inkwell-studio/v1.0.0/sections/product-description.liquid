{% schema %}
{
  "name": "Product Description",
  "settings": [
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "Product description"
    },
    {
      "type": "price",
      "id": "price",
      "label": "Price",
      "default": 50
    }
  ],
  "presets": [
    {
      "name": "Default"
    }
  ]
}
{% endschema %}
<div class="product-description">
  <h2>{{ product.title }}</h2>
  <p>{{ section.settings.description | escape }}</p>
  <p>Price: {{ product.price | money }}</p>
</div>
