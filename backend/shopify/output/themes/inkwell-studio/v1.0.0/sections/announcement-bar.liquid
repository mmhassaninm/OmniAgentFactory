<section class="announcement-bar" aria-label="Announcement Bar" role="alert"><div class="container"><div class="row"><div class="col-md-12"><div class="announcement-bar__content"><h2>{{ t 'Announcement' }}</h2><p>{{ settings.message }}</p><a href="{{ settings.link }}" class="btn btn-primary">{{ t 'Learn More' }}</a></div></div></div></div></section>{% schema %}{% if settings.message == blank %}  {% schema-def %}{% assign settings.message = 'Sign up for our newsletter' %}{% endschema-def %}{% endif %}{% settings.message | escape %}{% settings.link | escape %}{% schema %}{% endschema %}