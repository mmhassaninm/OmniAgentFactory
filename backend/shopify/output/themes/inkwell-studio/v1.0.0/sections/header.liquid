<div class="header" aria-label="Main navigation"><div class="container mx-auto px-4 py-4"><div class="flex justify-between items-center"><img src="{{ section.settings.logo | image_url: width: 1200 | image_tag }}" alt="{{ section.settings.logo.alt }}" style="width: {{ section.settings.logo_width }}px;"/><nav class="nav"><ul><li><a href="#" class="menu-link" aria-label="Navigation menu">Menu</a></li></ul></nav><button class="search-button"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M12 16v2m0-10a4 4 0 100 8 4 4 0 100-8"></path></svg></button><button class="cart-button"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3l7.07 7.07 1.41 1.41L20 6.41 23.58 9H24v10h-1.58l-3.58 3.58L14 20 6.41 13.59 3 9z"></path></svg></button></div></div>{% schema %}{% if settings.menu != blank %}{% for item in settings.menu %}<a href="{{ item.url | escape }}" aria-label="{{ item.label | escape }}" class="menu-link{% if item.url == root_url %} active{% endif %}">{% if item.label != blank %}{{ item.label | escape }}{% else %}{{ item.title | escape }}{% endif %}</a>{% endfor %}{% endif %}{% endschema %}