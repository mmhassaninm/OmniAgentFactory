<section class="blog-posts" style="--primary-color: #3498db; --bg-color: #f9f9f9;">
  <div class="blog-post-grid">
    {% for post in section.settings.posts %}
      <div class="blog-post">
        <img class="blog-post-image" src="{{ post.image | image_url: width: 400 | escape }}" alt="{{ post.title }}">
        <h3>{{ post.title }}</h3>
        <p>{{ post.content | truncate: 100 }}</p>
      </div>
    {% endfor %}
  </div>
  {% if section.settings.columns > 1 %}
    <div class="blog-post-grid-desktop">
      {% for post in section.settings.posts %}
        <div class="blog-post">
          <img class="blog-post-image" src="{{ post.image | image_url: width: 400 | escape }}" alt="{{ post.title }}">
          <h3>{{ post.title }}</h3>
          <p>{{ post.content | truncate: 100 }}</p>
        </div>
      {% endfor %}
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Blog Posts",
  "settings": [
    {
      "type": "blog_list",
      "id": "posts",
      "label": "Posts",
      "default": "new-posts"
    }
  ],
  "blocks": [
    {
      "type": "post-grid",
      "name": "post-grid",
      "settings": [
        {
          "type": "range",
          "id": "columns",
          "min": 1,
          "max": 4,
          "step": 1,
          "unit": "columns",
          "label": "Columns",
          "default": 3
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Default"
    }
  ],
  "responsive_notes": "Grid layout on desktop, list layout on mobile"
}
{% endschema %}