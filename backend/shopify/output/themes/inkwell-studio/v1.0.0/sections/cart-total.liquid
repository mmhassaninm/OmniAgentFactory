<section class="mt-12 md:mt-24 border-t border-gray-300 pt-6">
  <h2 class="text-2xl font-bold mb-4">{{ section.settings.heading | t }}</h2>
  <div class="bg-gray-100 p-6">
    <p class="text-lg font-bold">{{ section.settings.price | money }}</p>
    <a href="{{ shop.url }}/checkout" class="text-lg font-bold bg-blue-500 hover:bg-blue-700 text-white py-2 px-4 rounded">Checkout</a>
  </div>
</section>

{% schema %}
{
  "name": "Cart Total",
  "settings": [
    {
      "type": "price",
      "id": "price",
      "label": "Price",
      "default": 149
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Total: $149"
    }
  ],
  "presets": [
    {
      "name": "Default"
    }
  ],
  "blocks": [
  ],
  "responsive_notes": "Centered on mobile"
}
{% endschema %}