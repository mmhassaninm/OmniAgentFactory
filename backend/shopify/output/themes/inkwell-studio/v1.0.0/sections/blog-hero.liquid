<section class="blog-hero" style="--primary-color: #3498db; --bg-color: #f9f9f9;">
  <img class="blog-image" src="{{ section.settings.image | escape }}" alt="{{ section.settings.heading }}">
  <h2>{{ section.settings.heading }}</h2>
</section>

{% schema %}
{
  "name": "Blog Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Blog image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Blog title"
    }
  ],
  "presets": [
    {
      "name": "Default"
    }
  ],
  "blocks": [
  ],
  "responsive_notes": "Image zoom on hover on desktop"
}
{% endschema %}