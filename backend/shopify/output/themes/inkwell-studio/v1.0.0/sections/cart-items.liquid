<section class="mb-12 md:mb-24 border-b border-gray-300 pb-6">
  <h2 class="text-2xl font-bold mb-4">{{ section.settings.products | t }}</h2>
  <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
    {% for product in cart.products %}
      <div class="border border-gray-300 p-6">
        <img src="{{ product.image | image_url: width: 100 }}" alt="{{ product.title | escape }}">
        <h3 class="text-lg font-bold mb-2">{{ product.title }}</h3>
        <p class="text-gray-600">{{ product.description }}</p>
        <p class="text-sm text-gray-600">{{ product.price | money }}</p>
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Cart Items",
  "settings": [
    {
      "type": "product_list",
      "id": "products",
      "label": "Products",
      "default": "cart-products"
    }
  ],
  "presets": [
    {
      "name": "Default"
    }
  ],
  "blocks": [
  ],
  "responsive_notes": "Expand on mobile"
}
{% endschema %}