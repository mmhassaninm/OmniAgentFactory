{% schema %}
{
  "name": "Calls to Action",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "CTA heading"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    }
  ],
  "presets": [
    {
      "name": "Default"
    }
  ],
  "blocks": [
  ],
  "responsive_notes": "Centered on mobile"
}
{% endschema %}

<div class="page-calls-to-action">
  <h2>{{ block.settings.heading | escape }}</h2>
  <a href="{{ block.settings.cta_url | escape }}" class="button">
    Learn More
  </a>
</div>

<style>
  .page-calls-to-action {
    max-width: 800px;
    margin: 0 auto;
    padding: 20px;
    background-color: #f9f9f9;
    border: 1px solid #ddd;
  }
</style>

<style>
  @media (max-width: 768px) {
    .page-calls-to-action {
      max-width: 90vw;
    }
  }
</style>
