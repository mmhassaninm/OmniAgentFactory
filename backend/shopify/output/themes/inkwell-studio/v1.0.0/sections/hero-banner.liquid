<!-- Hero Banner Section --><section class=\"hero-banner\" role=\"region\" aria-label=\"Hero Banner\" style=\"--primary-color: #3498db; --bg-color: #f9f9f9;\">   <div class=\"hero-banner__background\" style=\"background-image: url('{{ section.settings.image | image_url: width: 1200 | escape }}');\"></div>   <h1 class=\"hero-banner__heading\" style=\"font-family: 'Montserrat', sans-serif;\">{{ section.settings.heading | escape }}</h1>   <h2 class=\"hero-banner__subheading\" style=\"font-family: 'Lato', sans-serif;\">{{ section.settings.subheading | escape }}</h2>   <a class=\"hero-banner__cta\" href=\"{{ section.settings.cta_url | escape }}\" style=\"background-color: #3498db; color: #ffffff;\">{{ section.settings.cta_label | escape }}</a> </section>{% schema %}   {\n    \"name\":\"Hero Banner\",\n    \"settings\":[\n      {\n        \"type\":\"image_picker\",\n        \"id\":\"image\",\n        \"label\":\"Background image\"\n      },\n      {\n        \"type\":\"text\",\n        \"id\":\"heading\",\n        \"label\":\"Heading\",\n        \"default\":\"Personalized stationery for every occasion\"\n      },\n      {\n        \"type\":\"text\",\n        \"id\":\"subheading\",\n        \"label\":\"Subheading\",\n        \"default\":\"Create and order custom stationery today\"\n      },\n      {\n        \"type\":\"text\",\n        \"id\":\"cta_label\",\n        \"label\":\"Button label\",\n        \"default\":\"Get started\"\n      },\n      {\n        \"type\":\"url\",\n        \"id\":\"cta_url\",\n        \"label\":\"Button URL\"\n      }\n    ],\n    \"presets\":[\n      {\n        \"name\":\"Hero Banner\"\n      }\n    ]\n  }{% endschema %}