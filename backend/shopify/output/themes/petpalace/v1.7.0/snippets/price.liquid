{% comment %}
  Renders product price with optional compare-at price and sale badge.
  Accepts: product, show_badges
{% endcomment %}

{%- liquid
  assign target = product
  if variant
    assign target = variant
  endif
  assign compare_at_price = target.compare_at_price
  assign price = target.price | default: 1999
  assign available = target.available | default: false
  assign on_sale = false
  if compare_at_price > price
    assign on_sale = true
  endif
-%}

<div class="price {% if on_sale %}price--on-sale{% endif %} {% unless available %}price--sold-out{% endunless %}">
  <div class="price__container">
    <span class="price__current">
      {%- if target.price_varies -%}
        {{ 'products.product.from_price_html' | t: price: price | money }}
      {%- else -%}
        {{ price | money }}
      {%- endif -%}
    </span>

    {%- if on_sale -%}
      <s class="price__compare">{{ compare_at_price | money }}</s>
    {%- endif -%}
  </div>

  {%- if show_badges -%}
    <div class="price__badges">
      {%- if on_sale -%}
        <span class="badge badge--sale">{{ 'products.product.on_sale' | t }}</span>
      {%- endif -%}
      {%- unless available -%}
        <span class="badge badge--sold-out">{{ 'products.product.sold_out' | t }}</span>
      {%- endunless -%}
    </div>
  {%- endif -%}
</div>
