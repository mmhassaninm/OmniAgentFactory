{% schema %}
{
  'name': 'footer',
  'settings': [
    {
      'type': 'text',
      'id': 'address',
      'label': 'Address'
    },
    {
      'type': 'text',
      'id': 'phone',
      'label': 'Phone'
    },
    {
      'type': 'text',
      'id': 'email',
      'label': 'Email'
    }
  ],
  'presets': []
}
{% endschema %}
<footer class="footer" style="--primary-color: #8B9467;">
  <div class="container">
    <div class="contact-info">
      <p>{{ settings.address }}</p>
      <p>{{ settings.phone }}</p>
      <p>{{ settings.email }}</p>
    </div>
    <ul class="social-links">
      <li><a href="#"><i class="fab fa-twitter"></i></a></li>
      <li><a href="#"><i class="fab fa-facebook"></i></a></li>
      <li><a href="#"><i class="fab fa-instagram"></i></a></li>
    </ul>
  </div>
</footer>
