<!-- Featured Categories Section -->
<section class="featured-categories" role="region" aria-label="{{ settings.categories | escape }}">
  <div class="container">
    <div class="row">
      {%- if settings.categories != "main-menu"  -%}
        {%- for category in categories -%}
          <div class="col-md-4 text-center">
            <div class="category-box">
              <h2>{{ category.name | escape }}</h2>
              <img src="{{ category.image | img_url }}" alt="{{ category.name | escape }}" loading="lazy">
            </div>
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- assign categories = all_categories -%}
        {%- for category in categories -%}
          <div class="col-md-4 text-center">
            <div class="category-box">
              <h2>{{ category.name | escape }}</h2>
              <img src="{{ category.image | img_url }}" alt="{{ category.name | escape }}" loading="lazy">
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Categories",
  "settings": [
    {
      "type": "link_list",
      "id": "categories",
      "label": "Categories",
      "default": "main-menu"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "category",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Category name"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Category image"
        }
      ]
    }
  ],
  "responsive_notes": "Grid of 3 categories on desktop, list on mobile"
}
{% endschema %}