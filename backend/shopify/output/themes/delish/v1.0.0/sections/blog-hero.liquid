<!-- Blog hero image section -->
{% schema %}
{
  "name": "blog-hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Blog image"
    }
  ],
  "presets": []
}
{% endschema %}
<div class="blog-hero">
  <img src="{{ settings.image | img_url: 'large' }}" alt="Blog hero image">
</div>
