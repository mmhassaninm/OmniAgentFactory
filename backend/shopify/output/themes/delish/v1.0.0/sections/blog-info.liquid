<!-- Blog info and title section -->
{% schema %}
{
  "name": "blog-info",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description"
    }
  ],
  "presets": []
}
{% endschema %}
<div class="blog-info">
  <h1>{{ settings.title }}</h1>
  <p>{{ settings.description }}</p>
</div>
