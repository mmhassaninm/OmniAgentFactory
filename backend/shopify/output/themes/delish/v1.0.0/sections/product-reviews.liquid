{% schema %}
{
  'name': 'product_reviews',
  'settings': [
    {
      'type': 'text',
      'id': 'rating',
      'label': 'Rating',
      'default': 4.5
    },
    {
      'type': 'text',
      'id': 'count',
      'label': 'Count',
      'default': 10
    }
  ],
  'presets': [
    {
      'name': 'Default',
      'settings': {
        'rating': 4.5,
        'count': 10
      }
    }
  ]
}
{% endschema %}
<div class="grid grid-cols-3 gap-4 mb-8">
  {% for review in collection.reviews limit: settings.count %}
    <div class="bg-secondary p-4 rounded shadow-sm">
      <h3>{{ review.title }}</h3>
      <span class="text-lg">{{ review.content }}</span>
    </div>
  {% endfor %}
</div>
<div class="text-center">
  <span class="text-2xl">{{ rating | money }}</span>
</div>