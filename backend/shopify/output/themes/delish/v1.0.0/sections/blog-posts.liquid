<!-- Blog posts grid section -->
{% schema %}
{
  "name": "blog-posts",
  "settings": [
    {
      "type": "text",
      "id": "rows",
      "label": "Rows",
      "default": 3
    },
    {
      "type": "text",
      "id": "columns",
      "label": "Columns",
      "default": 4
    }
  ],
  "blocks": [
    {
      "type": "post",
      "name": "post",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Post image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "text",
          "id": "date",
          "label": "Date"
        }
      ]
    }
  ],
  "presets": []
}
{% endschema %}
<div class="blog-posts">
  {% for block in blocks %}
    <div class="post">
      <img src="{{ block.settings.image | img_url: 'medium' }}" alt="{{ block.settings.title }}">
      <h4>{{ block.settings.title }}</h4>
      <p>{{ block.settings.date }}</p>
    </div>
  {% endfor %}
</div>
