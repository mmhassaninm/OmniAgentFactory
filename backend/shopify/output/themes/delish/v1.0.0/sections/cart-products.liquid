<!-- Cart products grid section -->
{% schema %}
{
  "name": "cart-products",
  "settings": [
    {
      "type": "text",
      "id": "rows",
      "label": "Rows",
      "default": 3
    },
    {
      "type": "text",
      "id": "columns",
      "label": "Columns",
      "default": 4
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "product",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Product image"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Product name"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price"
        },
        {
          "type": "text",
          "id": "quantity",
          "label": "Quantity"
        }
      ]
    }
  ],
  "presets": []
}
{% endschema %}
<div class="cart-products">
  {% for block in blocks %}
    <div class="product">
      <img src="{{ block.settings.image | img_url: 'medium' }}" alt="{{ block.settings.name }}">
      <h4>{{ block.settings.name }}</h4>
      <p>{{ block.settings.price | money }}</p>
      <p>Quantity: {{ block.settings.quantity }}</p>
    </div>
  {% endfor %}
</div>
