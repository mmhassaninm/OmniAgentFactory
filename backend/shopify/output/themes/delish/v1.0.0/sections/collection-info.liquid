{% schema %}
{
  'name': 'collection_info',
  'settings': [
    {
      'type': 'text',
      'id': 'title',
      'label': 'Title'
    },
    {
      'type': 'text',
      'id': 'description',
      'label': 'Description'
    }
  ],
  'presets': [
    {
      'name': 'Default',
      'settings': {
        'title': 'Collection Title',
        'description': 'Collection Description'
      }
    }
  ]
}
{% endschema %}
<div class="flex flex-col items-center mb-8">
  {% if collection.title %}
    <h2 class="text-3xl mb-4">{{ collection.title }}</h2>
  {% endif %}
  {% if collection.description %}
    <p class="text-lg text-center">{{ collection.description }}</p>
  {% endif %}
</div>