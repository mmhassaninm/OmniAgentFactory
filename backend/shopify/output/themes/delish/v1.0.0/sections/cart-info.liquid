<!-- Cart info and subtotal section -->
{% schema %}
{
  "name": "cart-info",
  "settings": [
    {
      "type": "text",
      "id": "subtotal",
      "label": "Subtotal"
    },
    {
      "type": "text",
      "id": "tax",
      "label": "Tax"
    },
    {
      "type": "text",
      "id": "total",
      "label": "Total"
    }
  ],
  "presets": []
}
{% endschema %}
<div class="cart-info">
  <h3>{{ settings.subtotal | money }}</h3>
  <p>{{ settings.tax | money }}</p>
  <p>{{ settings.total | money }}</p>
</div>
