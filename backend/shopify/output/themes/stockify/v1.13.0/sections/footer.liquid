{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Contact Us"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone number",
      "default": ""
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email address",
      "default": ""
    },
    {
      "type": "text",
      "id": "address",
      "label": "Address",
      "default": ""
    }
  ],
  "presets": [
    {
      "name": "Default",
      "settings": {
        "heading": "Footer",
        "phone": "123-456-7890",
        "email": "example@example.com",
        "address": "123 Main St"
      }
    }
  ]
}
{% endschema %}

<footer class="footer" style="background-color: #f9f9f9; padding: 20px;">
  <div class="container">
    <h2>{{ settings.heading }}</h2>
    <p>Phone: {{ settings.phone }}</p>
    <p>Email: {{ settings.email }}</p>
    <p>Address: {{ settings.address }}</p>
  </div>
</footer>

<style>
.footer {
  clear: both;
  background-color: #f9f9f9;
}
</style>