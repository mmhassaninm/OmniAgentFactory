<section class="announcement-bar" role="alert" aria-label="Promotional banner" style="background-color: {{ settings.bg_color | default: '#f9f9f9' }}; color: {{ settings.bg_text_color | default: '#333' }};">
  <div class="container">
    <div class="row">
      <div class="col-12 col-md-10 mx-auto text-center">
        <h2>{{ settings.heading | escape }}</h2>
        <p>{{ settings.subheading | escape }}</p>
        <a href="{{ routes.home }}" class="btn btn-primary" style="background-color: {{ settings.primary_color | default: '#3498db' }}; color: {{ settings.text_color | default: '#fff' }};">
          {{ settings.cta_label | escape }}
        </a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "announcement-bar",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Limited Time Offer"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Get 10% off your first order! Use code STOCK10"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Shop Now"
    }
  ],
  "presets": []
}
{% endschema %}