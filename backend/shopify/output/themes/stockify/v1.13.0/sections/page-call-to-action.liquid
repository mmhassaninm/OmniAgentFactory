{% schema %}
{
  "name": "Page Call to Action",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Get in Touch"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Have questions or need help? Contact us today!"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Contact Us"
    }
  ],
  "presets": [
    {
      "name": "Default",
      "settings": {
        "heading": "Page Call to Action",
        "subheading": "Have questions or need help? Contact us today!",
        "cta_label": "Contact Us"
      }
    }
  ]
}
{% endschema %}

<section class="page-call-to-action" style="background-color: #3498db; color: #ffffff;">
  <div class="container">
    <h1>{{ settings.heading }}</h1>
    <p>{{ settings.subheading }}</p>
    <button>{{ settings.cta_label }}</button>
  </div>
</section>

<style>
.page-call-to-action {
  padding: 20px;
  text-align: center;
}
</style>