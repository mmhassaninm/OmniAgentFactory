<section class="blog-hero" aria-label="Blog image, headline, and CTA">
  <img src="{{ settings.image | img_url }}" alt="Background image">
  <h1>{{ settings.heading }}</h1>
  <p>{{ settings.subheading }}</p>
  <a href="{{ shop.url }}" class="cta">Learn More</a>
</section>

{% schema %}
{
  "name":"Blog Hero",
  "settings":[
    {
      "type":"image_picker",
      "id":"image",
      "label":"Background image"
    },
    {
      "type":"text",
      "id":"heading",
      "label":"Heading",
      "default":"Stay Up-to-Date with the Latest News"
    },
    {
      "type":"text",
      "id":"subheading",
      "label":"Subheading",
      "default":""
    }
  ],
  "presets":[
  ]
}
{% endschema %}