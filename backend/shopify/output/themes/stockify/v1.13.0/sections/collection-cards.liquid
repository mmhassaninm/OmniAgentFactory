{% schema %}
{
  "name": "Collection Cards",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Popular Products"
    }
  ],
  "presets": []
}
{% endschema %}
<div class="collection-cards">
  <div class="container">
    <h2>{{ settings.heading }}</h2>
    <div class="product-grid">
      {% for product in collection.products %}
        <div class="product">
          <img src="{{ product.image | img_url: 'medium' }}" alt="{{ product.title }}" lazy-load>
          <h3>{{ product.title }}</h3>
          <p>{{ product.price | money }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</div>