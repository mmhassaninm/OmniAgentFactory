<aside class="blog-sidebar" aria-label="Sidebar with categories and search">
  <h2>{{ settings.heading }}</h2>
  <ul>
    {% for category in collections.all %}
      <li>
        <a href="{{ category.url }}">{{ category.title }}</a>
      </li>
    {% endfor %}
  </ul>
  <form role="search">
    <label for="search-input">Search:</label>
    <input id="search-input" type="search" placeholder="Search...">
  </form>
</aside>

{% schema %}
{
  "name":"Blog Sidebar",
  "settings":[
    {
      "type":"text",
      "id":"heading",
      "label":"Heading",
      "default":"Categories"
    }
  ],
  "presets":[
  ]
}
{% endschema %}