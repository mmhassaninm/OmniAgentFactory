{% schema %}
{
  'name': 'header',
  'settings': [
    {
      'type': 'image_picker',
      'id': 'logo',
      'label': 'Logo'
    },
    {
      'type': 'range',
      'id': 'logo_width',
      'min': 80,
      'max': 300,
      'step': 10,
      'unit': 'px',
      'label': 'Logo width',
      'default': 150
    },
    {
      'type': 'link_list',
      'id': 'menu',
      'label': 'Navigation menu',
      'default': 'main-menu'
    }
  ],
  'presets': [
    {
      'name': 'default',
      'settings': {
        'logo': null,
        'logo_width': 150,
        'menu': 'main-menu'
      }
    }
  ]
}
{% endschema %}

<header class="header" style="background-color: #f9f9f9;">
  <div class="container">
    <nav class="nav">
      <div class="logo">
        <img src="{{ settings.logo | img_url }}" alt="Logo" style="width: {{ settings.logo_width }}px; max-width: 100%;"/>
      </div>
      <ul>
        {% for item in settings.menu %}
          <li><a href="#" class="nav-link">{{ item }}</a></li>
        {% endfor %}
      </ul>
    </nav>
  </div>
</header>