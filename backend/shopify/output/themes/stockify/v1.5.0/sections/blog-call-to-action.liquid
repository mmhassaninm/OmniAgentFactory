<section class="blog-call-to-action" role="region" aria-label="Read More Articles">
  <h2>{{ settings.heading | escape }}</h2>
  <p>{{ settings.description | escape }}</p>
  {% if settings.show_button %}
    <button type="button">Read More Articles</button>
  {% endif %}
</section>

{% schema %}
{
  "name": "Blog Call to Action",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Read More Articles"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "Discover more insights and tips on inventory management"
    },
    {
      "type": "checkbox",
      "id": "show_button",
      "label": "Show button"
    }
  ],
  "presets": []
}
{% endschema %}