{% schema %}
{
  'name': 'page-content',
  'settings': [
    {
      'type': 'text',
      'id': 'heading',
      'label': 'Heading',
      'default': 'Page Content'
    },
    {
      'type': 'text',
      'id': 'description',
      'label': 'Description',
      'default': 'This is a sample page content'
    }
  ],
  'presets': [
    {
      'name': 'default',
      'settings': {
        'heading': 'Page Content',
        'description': 'This is a sample page content'
      }
    }
  ]
}
{% endschema %}

<section class="page-content">
  <div class="container">
    <h2>{{ settings.heading | escape }}</h2>
    <p>{{ settings.description | escape }}</p>
  </div>
</section>