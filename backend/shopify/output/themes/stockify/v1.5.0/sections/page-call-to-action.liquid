{% schema %}
{
  'name': 'page-call-to-action',
  'settings': [
    {
      'type': 'text',
      'id': 'heading',
      'label': 'Heading',
      'default': 'Contact Us'
    },
    {
      'type': 'text',
      'id': 'description',
      'label': 'Description',
      'default': 'Get in touch with us to learn more about Stockify'
    },
    {
      'type': 'checkbox',
      'id': 'show_button',
      'label': 'Show button'
    }
  ],
  'presets': [
    {
      'name': 'default',
      'settings': {
        'heading': 'Contact Us',
        'description': 'Get in touch with us to learn more about Stockify',
        'show_button': false
      }
    }
  ]
}
{% endschema %}

<section class="page-call-to-action">
  <div class="container">
    <h2>{{ settings.heading | escape }}</h2>
    <p>{{ settings.description | escape }}</p>
    {% if settings.show_button == true %}
      <a href="#" class="button">Contact Us</a>
    {% endif %}
  </div>
</section>