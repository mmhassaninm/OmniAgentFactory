<section class="cart-items" role="region" aria-label="Your Cart">
  <h2>{{ settings.heading | escape }}</h2>
  <p>{{ settings.description | escape }}</p>
  <ul>
    {% for item in cart.items %}
      <li>
        {{ item.name }} x {{ item.quantity }}
        <span> {{ item.price | money }} </span>
      </li>
    {% endfor %}
  </ul>
</section>

{% schema %}
{
  "name": "Cart Items",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your Cart"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "Review your cart items and proceed to checkout"
    }
  ],
  "presets": []
}
{% endschema %}