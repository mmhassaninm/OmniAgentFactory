<section class="cart-call-to-action" role="region" aria-label="Proceed to Checkout">
  <h2>{{ settings.heading | escape }}</h2>
  <p>{{ settings.description | escape }}</p>
  {% if settings.show_button %}
    <button type="button">Proceed to Checkout</button>
  {% endif %}
</section>

{% schema %}
{
  "name": "Cart Call to Action",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Proceed to Checkout"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "Complete your purchase and unlock the power of Stockify"
    },
    {
      "type": "checkbox",
      "id": "show_button",
      "label": "Show button"
    }
  ],
  "presets": []
}
{% endschema %}