<section class="announcement-bar" role="alert" aria-label="{{ settings.message | escape }}">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-md-8">
        <p class="mb-0">{{ settings.message | escape }}</p>
      </div>
      <div class="col-md-4 text-right">
        <a href="{{ settings.button_url | escape }}" class="btn btn-primary">{{ settings.button_label | escape }}</a>
      </div>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "announcement-bar",
  "settings": [
    {
      "type": "text",
      "id": "message",
      "label": "Announcement message"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    }
  ],
  "presets": [
    {
      "name": "default",
      "settings": {
        "message": "",
        "button_label": "Learn More",
        "button_url": ""
      }
    }
  ]
}
{% endschema %}