<section class="call-to-action" role="region" aria-label="Call to action">
  <div class="container">
    <h1>{{ settings.heading | escape }}</h1>
    <p>{{ settings.description | escape }}</p>
    {% if settings.show_button %}<a href="{{ settings.cta_url }}" class="button">{{ settings.cta_label | escape }}</a>{% endif %}
  </div>
{% schema %}
{
  "name": "call-to-action",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Get Started Today"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "Unlock the power of Stockify and manage your inventory with ease"
    },
    {
      "type": "checkbox",
      "id": "show_button",
      "label": "Show button"
    }
  ],
  "presets": []
}
{% endschema %}
</section>
