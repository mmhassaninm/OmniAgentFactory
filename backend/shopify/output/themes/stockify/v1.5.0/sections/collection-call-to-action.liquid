<!-- theme settings -->
{% schema %}
{
  'name': 'collection-call-to-action",
  'settings': [
    {
      'type': 'text",
      'id': 'heading",
      'label': 'Heading',
      'default': 'Explore the Collection'
    },
    {
      'type': 'text",
      'id': 'description",
      'label': 'Description',
      'default': 'Discover more products like this and enhance your inventory management'
    },
    {
      'type': 'checkbox",
      'id': 'show_button',
      'label': 'Show button'
    }
  ],
  'presets': []
}
{% endschema %}

<!-- section content -->
<div class="collection-call-to-action" role="region" aria-label="{{ 'collection-call-to-action.label' | t }}">
  <h2>{{ settings.heading | escape }}</h2>
  <p>{{ settings.description | escape }}</p>
  {% if settings.show_button %}
    <button type="submit">Explore the Collection</button>
  {% endif %}
</div>

<!-- styles -->
<style>
  .collection-call-to-action {
    background-color: {{ theme.settings.backgroundcolor | escape }};
    color: {{ theme.settings.textcolor | escape }};
  }
  .collection-call-to-action h2 {
    font-family: 'Montserrat', sans-serif;
  }
  .collection-call-to-action p {
    font-family: 'Lato', sans-serif;
  }
</style>