<section class="blog-hero" role="region" aria-label="Blog Hero">
  <div class="background-image" style="background-image: url('{{ settings.image | img_url | escape }}');"></div>
  <h1>{{ settings.title | escape }}</h1>
  <p>{{ settings.description | escape }}</p>
</section>

{% schema %}
{
  "name": "Blog Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description"
    }
  ],
  "presets": []
}
{% endschema %}