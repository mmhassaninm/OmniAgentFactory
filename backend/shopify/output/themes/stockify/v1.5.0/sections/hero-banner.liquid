<section class="hero-banner" role="region" aria-label="Hero banner">
  <div class="container">
    <div class="image" style="background-image: url('{{ settings.image | img_url: 'master' }}');"></div>
    <h1>{{ settings.heading | escape }}</h1>
    <h2>{{ settings.subheading | escape }}</h2>
    <a href="{{ settings.cta_url }}" class="button">{{ settings.cta_label | escape }}</a>
  </div>
{% schema %}
{
  "name": "hero-banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Streamline Your Inventory"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Efficiently manage your dropshipping inventory"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Get Started Today"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    }
  ],
  "presets": []
}
{% endschema %}
</section>
