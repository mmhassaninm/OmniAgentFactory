<!-- theme settings -->
{% schema %}
{
  'name': 'product-call-to-action",
  'settings': [
    {
      'type': 'text",
      'id': 'heading",
      'label': 'Heading",
      'default': 'Add to Cart'
    },
    {
      'type': 'text",
      'id': 'description",
      'label': 'Description",
      'default': 'Unlock the power of this product and enhance your inventory management'
    },
    {
      'type': 'checkbox",
      'id': 'show_button",
      'label': 'Show button'
    }
  ],
  'presets': []
}
{% endschema %}

<!-- section content -->
<div class="product-call-to-action" role="region" aria-label="{{ 'product-call-to-action.label' | t }}">
  <h2>{{ settings.heading | escape }}</h2>
  <p>{{ settings.description | escape }}</p>
  {% if settings.show_button %}
    <button type="submit">Add to Cart</button>
  {% endif %}
</div>

<!-- styles -->
<style>
  .product-call-to-action {
    background-color: {{ themesettings.backgroundcolor | escape }};
    color: {{ theme.settings.textcolor | escape }};
  }
  .product-call-to-action h2 {
    font-family: 'Montserrat', sans-serif;
  }
  .product-call-to-action p {
    font-family: 'Lato', sans-serif;
  }
</style>