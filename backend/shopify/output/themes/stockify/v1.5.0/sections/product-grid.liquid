<section class="product-grid" role="region" aria-label="Product grid">
  <div class="container">
    <div class="grid" style="grid-template-columns: repeat({{ settings.grid_columns }}, 1fr);">
      {% for product in product_collection.products %}
        <div class="product">
          <div class="image" style="background-image: url('{{ product.image | img_url: 'master' }}');"></div>
          <h2>{{ product.title }}</h2>
          {% if settings.show_price %}<p>{{ product.price | money }}</p>{% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
{% schema %}
{
  "name": "product-grid",
  "settings": [
    {
      "type": "collection",
      "id": "product_collection",
      "label": "Featured Product Collection"
    },
    {
      "type": "range",
      "id": "grid_columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "unit": "",
      "label": "Grid columns",
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "show_price",
      "label": "Show price"
    }
  ],
  "presets": []
}
{% endschema %}
</section>
