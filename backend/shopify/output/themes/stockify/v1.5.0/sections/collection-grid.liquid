<!-- theme settings -->
{% schema %}
{
  'name': 'collection-grid",
  'settings': [
    {
      'type': 'collection",
      'id': 'collection",
      'label': 'Collection'
    },
    {
      'type': 'range",
      'id': 'grid_columns",
      'min': 2,
      'max': 4,
      'step': 1,
      'unit': '',
      'label': 'Grid columns',
      'default': 3
    },
    {
      'type': 'checkbox",
      'id': 'show_price",
      'label': 'Show price'
    }
  ],
  'presets': []
}
{% endschema %}

<!-- section content -->
<div class="collection-grid" role="region" aria-label="{{ 'collection-grid.label' | t }}">
  <div class="collection-grid-inner">
    {% for product in collection.products limit: settings.grid_columns %}
      <div class="collection-grid-item">
        <img src="{{ product.image | img_url: 'large' }}" alt="{{ product.title | escape }}">
        <h2>{{ product.title | escape }}</h2>
        {% if settings.show_price %}
          <p>{{ product.price | money }}</p>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</div>

<!-- styles -->
<style>
  .collection-grid {
    display: grid;
    grid-template-columns: repeat({{ settings.grid_columns }}, 1fr);
    gap: 10px;
  }
  .collection-grid-inner {
    max-width: 1200px;
    margin: 0 auto;
  }
  .collection-grid-item {
    background-color: {{ theme.settings.backgroundcolor | escape }};
    color: {{ theme.settings.textcolor | escape }};
  }
  .collection-grid-item img {
    width: 100%;
    height: auto;
  }
  .collection-grid-item h2 {
    font-family: 'Montserrat', sans-serif;
  }
  .collection-grid-item p {
    font-family: 'Lato', sans-serif;
  }
</style>