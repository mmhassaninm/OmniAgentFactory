<!-- sections/cart-hero.liquid -->

<div class="cart-hero" role="img" aria-label="{{ 'cart_hero' | t }}">
  <img src="{{ settings.image | img_url: '1x' }}" alt="{{ settings.heading | escape }}" style="width: 100%; height: auto;" role="img" aria-label="{{ settings.heading | t }}">
  <h2>{{ settings.heading | escape }}</h2>
  <p>{{ settings.subheading | escape }}</p>
</div>

{% schema %}
{
  "name":"cart-hero",
  "settings":[
    {
      "type":"image_picker",
      "id":"image",
      "label":"Cart image"
    },
    {
      "type":"text",
      "id":"heading",
      "label":"Heading"
    },
    {
      "type":"text",
      "id":"subheading",
      "label":"Subheading"
    }
  ],
  "presets":[]
}
{% endschema %}