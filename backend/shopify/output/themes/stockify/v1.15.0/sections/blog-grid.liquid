<section class="blog-grid" data-section-id="blog-grid">
  <div class="container">
    <div class="blog-grid-items">
      {% for post in blog.id | blog_list: blog_id %}
        <article class="blog-grid-item">
          <img src="{{ post.image | img_url: 'small' }}" alt="{{ post.title | escape }}" width="50" height="50" loading="lazy">
          <div class="blog-grid-item-info">
            <h3>{{ post.title | escape }}</h3>
            <p>{{ post.published_at | date }}</p>
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Blog Grid",
  "settings": [
    {
      "type": "blog_list",
      "id": "blog_id",
      "label": "Blog ID"
    }
  ],
  "presets": [
    {
      "name": "Default",
      "settings": {}
    }
  ]
}
{% endschema %}