<section class="cart-summary" data-section-id="cart-summary">
  <div class="container">
    <h2 id="cart-summary-heading" class="heading">{{ settings.heading | escape }}</h2>
    <ul class="cart-items">
      {% for item in cart.items %}
        <li class="cart-item">
          <img src="{{ item.image | img_url: 'small' }}" alt="{{ item.title | escape }}" width="50" height="50" loading="lazy">
          <div class="cart-item-info">
            <h3>{{ item.title | escape }}</h3>
            <p>Quantity: {{ item.quantity }}</p>
            <p>Price: {{ item.price | money }}</p>
          </div>
        </li>
      {% endfor %}
    </ul>
    <div class="cart-totals">
      <p>Subtotal: {{ cart.subtotal | money }}</p>
      <p>Tax: {{ cart.tax_amount | money }}</p>
      <p>Total: {{ cart.total_price | money }}</p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Cart Summary",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your cart summary"
    }
  ],
  "presets": [
    {
      "name": "Default",
      "settings": {}
    }
  ]
}
{% endschema %}