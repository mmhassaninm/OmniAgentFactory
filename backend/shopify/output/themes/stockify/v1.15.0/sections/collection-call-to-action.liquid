<!-- sections/collection-call-to-action.liquid -->

<div class="collection-call-to-action" role="button" aria-label="{{ 'collection_call_to_action' | t }}">
  <h3>{{ settings.heading | escape }}</h3>
  <p>{{ settings.subheading | escape }}</p>
  <button class="btn" type="button" aria-label="{{ 'browse_products' | t }}" role="button" style="background-color: #3498db; color: #f9f9f9; border: none; padding: 10px 20px; font-size: 16px; cursor: pointer; border-radius: 5px;">
    {{ 'browse_products' | t }}
  </button>
</div>

{% schema %}
{
  "name":"collection-call-to-action",
  "settings":[
    {
      "type":"text",
      "id":"heading",
      "label":"Heading",
      "default":"Explore more in this collection"
    },
    {
      "type":"text",
      "id":"subheading",
      "label":"Subheading",
      "default":"Browse similar products"
    }
  ],
  "presets":[]
}
{% endschema %}