
{% schema %}
{
  "name": "Page Content",
  "settings": [
    {
      "type": "markdown",
      "id": "content",
      "label": "Content"
    }
  ],
  "presets": [
    [
      {
        "setting": [
          {
            "id": "content",
            "value": "# Page Content

Lorem ipsum dolor sit amet, consectetur adipiscing elit.

## Heading

### Subheading"
          }
        ]
      }
    ]
  ]
}
{% endschema %}

<div class="page-content" aria-label="Page Content">
  <div class="content-wrapper">
    {{ settings.content | escape }}
  </div>
</div>

<style>
  .page-content {
    padding: 50px;
  }
  
  .content-wrapper {
    width: 80%;
    margin: 0 auto;
  }
  
  @media (max-width: 768px) {
    .content-wrapper {
      width: 100%;
    }
  }
</style>
