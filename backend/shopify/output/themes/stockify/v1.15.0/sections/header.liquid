
{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 80,
      "max": 300,
      "step": 10,
      "unit": "px",
      "label": "Logo Width",
      "default": 150
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation Menu",
      "default": "main-menu"
    }
  ],
  "presets": [
    [
      {
        "setting": [
          {
            "id": "logo",
            "value": "https://example.com/logo.png"
          },
          {
            "id": "logo_width",
            "value": 150
          },
          {
            "id": "menu",
            "value": "main-menu"
          }
        ]
      }
    ]
  ]
}
{% endschema %}

<header class="header" aria-label="Header">
  <div class="logo">
    <img src="{{ settings.logo | img_url: 'master' }}" alt="Logo" style="width: {{ settings.logo_width }}px;">
  </div>
  <nav class="nav">
    <ul>
      <li><a href="#">Home</a></li>
      <li><a href="#">About</a></li>
      <li><a href="#">Contact</a></li>
    </ul>
  </nav>
</header>

<style>
  .header {
    background-color: #f9f9f9;
    padding: 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  
  .logo {
    width: 20%;
  }
  
  .logo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .nav {
    width: 80%;
  }
  
  .nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  
  .nav li {
    display: inline-block;
    margin-right: 20px;
  }
  
  .nav a {
    color: #3498db;
    text-decoration: none;
  }
  
  @media (max-width: 768px) {
    .header {
      flex-direction: column;
    }
    
    .logo {
      width: 100%;
      text-align: center;
    }
    
    .nav {
      width: 100%;
    }
    
    .nav ul {
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    
    .nav li {
      margin-right: 0;
      margin-bottom: 10px;
    }
  }
</style>
