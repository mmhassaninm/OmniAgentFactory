<!-- sections/product-call-to-action.liquid -->

<div class="product-call-to-action" role="button" aria-label="{{ 'call_to_action' | t }}">
  <h3>{{ settings.heading | escape }}</h3>
  <p>{{ settings.subheading | escape }}</p>
  <button class="btn" type="button" aria-label="{{ settings.cta_label | t }}" role="button" style="background-color: #3498db; color: #f9f9f9; border: none; padding: 10px 20px; font-size: 16px; cursor: pointer; border-radius: 5px;">
    {{ settings.cta_label | escape }}
  </button>
</div>

{% schema %}
{
  "name":"product-call-to-action",
  "settings":[
    {
      "type":"text",
      "id":"heading",
      "label":"Heading",
      "default":"Ready to order?"
    },
    {
      "type":"text",
      "id":"subheading",
      "label":"Subheading",
      "default":"Add to cart now and start selling"
    },
    {
      "type":"text",
      "id":"cta_label",
      "label":"Button label",
      "default":"Add to Cart"
    }
  ],
  "presets":[]
}
{% endschema %}