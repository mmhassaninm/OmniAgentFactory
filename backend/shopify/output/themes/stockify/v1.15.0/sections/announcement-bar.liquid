<!-- announcement-bar.liquid -->
<div class="announcement-bar" role="alert">
  <div class="container">
    <div class="row justify-content-between align-items-center">
      <div class="col-auto">
        <h5>{{ heading | escape }}</h5>
        <p>{{ subheading | escape }}</p>
      </div>
      <div class="col-auto">
        <a href="{{ cta_url }}" class="btn btn-primary" aria-label="{{ cta_label | escape }}">
          {{ cta_label | escape }}
        </a>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "announcement-bar",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Limited time offer"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Get 10% off your first order"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    }
  ],
  "presets": []
}
{% endschema %}