<section class="blog-call-to-action" data-section-id="blog-call-to-action">
  <div class="container">
    <h2 id="blog-call-to-action-heading" class="heading">{{ settings.heading | escape }}</h2>
    <p id="blog-call-to-action-subheading" class="subheading">{{ settings.subheading | escape }}</p>
    <a href="/blogs" class="button">Discover more articles</a>
  </div>
</section>

{% schema %}
{
  "name": "Blog Call-to-Action",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Read more articles"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover the latest news and trends"
    }
  ],
  "presets": [
    {
      "name": "Default",
      "settings": {}
    }
  ]
}
{% endschema %}