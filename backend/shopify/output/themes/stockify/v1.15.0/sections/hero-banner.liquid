{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Streamline Your Dropshipping Operations"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Effortlessly manage your inventory and products"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Get Started"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    }
  ],
  "presets": [
    [
      "image",
      "heading",
      "subheading",
      "cta_label",
      "cta_url"
    ]
  ]
}
{% endschema %}

<section class="hero-banner" style="background-image: {{ settings.image | img_url: 'master' }}">
  <div class="container">
    <h1>{{ settings.heading | escape }}</h1>
    <p>{{ settings.subheading | escape }}</p>
    <a href="{{ settings.cta_url | escape }}" class="btn">{{ settings.cta_label | escape }}</a>
  </div>
</section>