
{% schema %}
{
  "name": "Page Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Page Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    }
  ],
  "presets": [
    [
      {
        "setting": [
          {
            "id": "image",
            "value": "https://example.com/image.jpg"
          },
          {
            "id": "heading",
            "value": "Page Heading"
          },
          {
            "id": "subheading",
            "value": "Page Subheading"
          }
        ]
      }
    ]
  ]
}
{% endschema %}

<div class="page-hero" aria-label="Page Hero">
  <div class="hero-image">
    <img src="{{ settings.image | img_url: 'master' }}" alt="{{ settings.heading }}">
  </div>
  <h1>{{ settings.heading }}</h1>
  <p>{{ settings.subheading }}</p>
</div>

<style>
  .page-hero {
    background-color: #f9f9f9;
    padding: 50px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  
  .hero-image {
    width: 50%;
  }
  
  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  @media (max-width: 768px) {
    .page-hero {
      flex-direction: column;
    }
    
    .hero-image {
      width: 100%;
    }
  }
</style>
