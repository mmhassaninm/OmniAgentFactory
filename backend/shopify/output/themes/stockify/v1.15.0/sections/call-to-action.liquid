{% schema %}
{
  "name": "Call-to-Action",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Ready to optimize your dropshipping business?"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Sign up for a free trial or contact us for more information"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Get Started"
    }
  ],
  "presets": [
    [
      "heading",
      "subheading",
      "cta_label"
    ]
  ]
}
{% endschema %}

<div class="call-to-action" style="text-align: center">
  <h2>{{ settings.heading | escape }}</h2>
  <p>{{ settings.subheading | escape }}</p>
  <a href="{{ settings.cta_url | escape }}" class="btn">{{ settings.cta_label | escape }}</a>
</div>