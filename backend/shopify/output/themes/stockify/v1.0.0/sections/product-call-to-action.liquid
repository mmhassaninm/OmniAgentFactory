{% schema %}
{
  "name": "product-call-to-action",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Purchase Now",
      "default": "Purchase Now"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Get your product now",
      "default": ""
    }
  ],
  "presets": [
    [
      {
        "settings": {
          "heading": "Buy now!",
          "subheading": "Get yours today!"
        }
      }
    ],
    [
      {
        "settings": {
          "heading": "Shop now",
          "subheading": "Find your favorite products"
        }
      }
    ]
  ]
}
{% endschema %}

<div class="product-call-to-action" role="button" aria-label="Purchase Now">
  <h2>{{ settings.heading | escape }}</h2>
  <p>{{ settings.subheading | escape }}</p>
  <a href="{{ routes.cart_url }}" class="btn btn-primary">{{ settings.heading | escape }}</a>
</div>