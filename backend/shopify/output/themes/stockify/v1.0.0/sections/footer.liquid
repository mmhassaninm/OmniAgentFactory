<!-- Footer Section -->
<footer class="container mx-auto p-4 mt-8 bg-gray-200 text-gray-600">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <p class="text-lg font-bold mb-2">{{ settings.copyright | escape }}</p>
      <ul class="list-none mb-0">
        <li class="mb-2"><a href="#" class="text-blue-500 hover:text-blue-700">Terms and Conditions</a></li>
        <li class="mb-2"><a href="#" class="text-blue-500 hover:text-blue-700">Privacy Policy</a></li>
        <li><a href="#" class="text-blue-500 hover:text-blue-700">Contact</a></li>
      </ul>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "footer",
  "settings": [
    {
      "type": "text",
      "id": "copyright",
      "label": "Copyright"
    }
  ],
  "presets": []
}
{% endschema %}