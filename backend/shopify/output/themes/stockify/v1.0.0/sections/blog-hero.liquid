<section class="blog-hero" role="region" aria-label="Blog Hero">
  <img class="blog-hero__image" src="{{ settings.image | img_url: 'master' }}" alt="{{ settings.heading }}">
  <h1 class="blog-hero__heading" id="blog-hero-heading">{{ settings.heading }}</h1>
</section>

{% schema %}
{
  "name": "blog-hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Blog image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Blog name",
      "default": "Blog name"
    }
  ],
  "presets": []
}
{% endschema %}