{% schema %}
  {
    "name": "Call to Action",
    "settings": [
      {
        "type": "text",
        "id": "heading",
        "label": "Start Your Free Trial",
        "default": "Start Your Free Trial"
      },
      {
        "type": "text",
        "id": "subheading",
        "label": "No credit card required",
        "default": ""
      }
    ],
    "presets": [
      [
        {
          "setting": [
            "heading",
            "subheading"
          ],
          "default": [
            "Start Your Free Trial",
            "No credit card required"
          ]
        }
      ]
    ]
  }
  {% endschema %}
  <section class="call-to-action">
    <div class="container">
      <h2>{{ settings.heading | escape }}</h2>
      <p>{{ settings.subheading | escape }}</p>
      <a href="https://example.com" class="cta-button" style="width: 100%;">Get Started</a>
    </div>
  </section>