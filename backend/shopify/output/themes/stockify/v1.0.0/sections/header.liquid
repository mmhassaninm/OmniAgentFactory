<header class="header" role="banner" aria-label="Header">
  <nav class="header__nav" aria-label="Navigation">
    <div class="header__logo">
      <img src="{{ settings.logo | img_url: 'master' }}" alt="Logo" width="{{ settings.logo_width }}" height="auto">
    </div>
    <ul class="header__menu" aria-label="Navigation menu">
      {% for link in settings.menu %}
        <li class="header__menu-item"><a href="{{ link.url }}" class="header__menu-link">{{ link.label }}</a></li>
      {% endfor %}
    </ul>
    <div class="header__search">
      <label for="search"
        class="header__search-label sr-only">Search</label>
      <input type="search" id="search"
        class="header__search-input" placeholder="Search">
    </div>
    <div class="header__cart">
      <a href="#" class="header__cart-link">Cart</a>
    </div>
  </nav>
</header>

{% schema %}
{
  "name": "header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 80,
      "max": 300,
      "step": 10,
      "unit": "px",
      "label": "Logo width",
      "default": 150
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    }
  ],
  "blocks": [],
  "presets": []
}
{% endschema %}