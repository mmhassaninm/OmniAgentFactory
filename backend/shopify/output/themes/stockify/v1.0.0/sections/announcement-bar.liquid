<!-- Announcement Bar Section -->
<div class="container mx-auto p-4 mt-8 bg-gray-200 text-gray-600 mb-8">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div class="md:col-span-2">
      <h2 class="text-lg font-bold mb-2">{{ settings.heading | escape }}</h2>
      <p class="mb-4">{{ settings.subheading | escape }}</p>
      <a href="#" class="text-blue-500 hover:text-blue-700">Learn More</a>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "announcement-bar",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Announcement",
      "default": "Announcement"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": ""
    }
  ],
  "presets": []
}
{% endschema %}