{% schema %}
{
  "name": "cart-hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Cart image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Your cart",
      "default": "Your cart"
    }
  ],
  "presets": [
    [
      {
        "settings": {
          "image": "cart/hero1.jpg",
          "heading": "Your Shopping Cart"
        }
      }
    ],
    [
      {
        "settings": {
          "image": "cart/hero2.jpg",
          "heading": "Checkout"
        }
      }
    ]
  ]
}
{% endschema %}

<section class="cart-hero" role="region">
  <img src="{{ settings.image | img_url: 'large' }}" alt="{{ settings.heading | escape }}" loading="lazy">
  <h1>{{ settings.heading | escape }}</h1>
</section>