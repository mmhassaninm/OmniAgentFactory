{% schema %}
  {
    "name": "Product Description",
    "settings": [
      {
        "type": "text",
        "id": "heading",
        "label": "Product description",
        "default": "Product description"
      }
    ],
    "blocks": [
      {
        "type": "description",
        "name": "description",
        "settings": [
          {
            "type": "text",
            "id": "text",
            "label": "Text"
          }
        ]
      }
    ],
    "presets": [
      [
        {
          "setting": [
            "heading",
            "description.text"
          ],
          "default": [
            "Product description",
            "This is a product description."
          ]
        }
      ]
    ]
  }
  {% endschema %}
  <section class="product-description">
    <div class="container">
      <h2>{{ settings.heading | escape }}</h2>
      <p>{{ block.description.text | escape }}</p>
    </div>
  </section>