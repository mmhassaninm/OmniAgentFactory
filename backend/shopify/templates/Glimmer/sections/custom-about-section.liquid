<div class="custom-about-wrapper" style="padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px 0; background-color: {{ section.settings.bg_color }};">
  <div class="page-width">
    
    {%- if section.settings.heading != blank -%}
      <h2 class="section-heading" style="text-align: {{ section.settings.text_alignment }};">
        {{ section.settings.heading }}
      </h2>
    {%- endif -%}

    <div class="custom-about-content">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          
          {%- comment -%} Text Block {%- endcomment -%}
          {%- when 'text_block' -%}
            <div class="block-text" {{ block.shopify_attributes }} style="text-align: {{ section.settings.text_alignment }}; margin-bottom: 20px;">
              {%- if block.settings.text != blank -%}
                <div class="rte">
                  {{ block.settings.text }}
                </div>
              {%- endif -%}
            </div>

          {%- comment -%} Image Block {%- endcomment -%}
          {%- when 'image_block' -%}
            <div class="block-image" {{ block.shopify_attributes }} style="margin-bottom: 20px; text-align: center;">
              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 800 }}" 
                     alt="{{ block.settings.image.alt | escape }}" 
                     loading="lazy" 
                     style="max-width: 100%; height: auto; border-radius: 8px;">
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>

          {%- comment -%} Video Block {%- endcomment -%}
          {%- when 'video_block' -%}
            <div class="block-video" {{ block.shopify_attributes }} style="margin-bottom: 20px; text-align: center;">
              {%- if block.settings.video != blank -%}
                {{ block.settings.video | video_tag: controls: true, autoplay: false, style: "max-width: 100%; border-radius: 8px;" }}
              {%- else -%}
                <div style="background: #f4f4f4; padding: 40px; border-radius: 8px; text-align: center;">
                  <p>برجاء اختيار فيديو من الـ Theme Editor</p>
                </div>
              {%- endif -%}
            </div>

        {%- endcase -%}
      {%- endfor -%}
    </div>
    
  </div>
</div>

{% schema %}
{
  "name": "Custom About Section",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "About Our Brand"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "text_block",
      "name": "Rich Text",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Text Content",
          "default": "<p>Share details about your brand, products, or values here.</p>"
        }
      ]
    },
    {
      "type": "image_block",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Select Image"
        }
      ]
    },
    {
      "type": "video_block",
      "name": "Shopify Video",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Select Video (Shopify Hosted)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom About Section",
      "blocks": [
        { "type": "text_block" },
        { "type": "image_block" }
      ]
    }
  ]
}
{% endschema %}