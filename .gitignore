# OmniBot — Security-First .gitignore

# === SECRETS & CREDENTIALS (NEVER COMMIT) ===
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.pfx
secrets/
credentials/
*_credentials.json
_secrets.json
service_account.json

# === SENSITIVE DATA ===
ERROR_LOG.md
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*
backend/logs/
exports/
Project_Docs/Logs/*
Project_Docs/Secrets/*

# === DATABASE ===
*.db
*.sqlite
*.sqlite3
*.rdb
*.bson
chroma_data/
data/
backend/data/*
mongodb_data/

# === PYTHON ===
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
venv/
env/
.venv/
pip-log.txt

# === NODE / FRONTEND ===
node_modules/
frontend/node_modules/
jspm_packages/
frontend/dist/
.npm
*.tsbuildinfo

# === OS FILES ===
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~

# === EDITOR ===
.vscode/settings.json
.idea/
*.suo
.ntvs
*.njsproj
*.sln
.vibelab_config
.vibelab_drafts/

# === DOCKER ===
docker-compose.override.yml

# === SENSITIVE RUNTIME FILES ===
*.pid
nohup.out

# === BUILD OUTPUTS ===
out/
coverage/
