# ═══════════════════════════════════════════
# OmniBot — Autonomous Agent Factory
# Environment Configuration
# ═══════════════════════════════════════════

# ── Model Provider Keys ──────────────────
# Support up to 8 keys per provider for rotation
OPENROUTER_KEY_1=
OPENROUTER_KEY_2=
OPENROUTER_KEY_3=
OPENROUTER_KEY_4=
OPENROUTER_KEY_5=
OPENROUTER_KEY_6=
OPENROUTER_KEY_7=
OPENROUTER_KEY_8=

GROQ_KEY_1=
GROQ_KEY_2=
GROQ_KEY_3=
GROQ_KEY_4=
GROQ_KEY_5=
GROQ_KEY_6=
GROQ_KEY_7=
GROQ_KEY_8=

GEMINI_KEY_1=
GEMINI_KEY_2=
GEMINI_KEY_3=
GEMINI_KEY_4=

ANTHROPIC_KEY=

# ── Local Models ─────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── Database ─────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=omnibot
CHROMA_HOST=localhost
CHROMA_PORT=8000

# ── Night Mode Schedule ──────────────────
NIGHT_MODE_START=00:00
NIGHT_MODE_END=07:00

# ── Concurrency Limits ───────────────────
MAX_CONCURRENT_AGENTS_DAY=5
MAX_CONCURRENT_AGENTS_NIGHT=2

# ── Evolution Settings ───────────────────
DEFAULT_EVOLVE_INTERVAL_SECONDS=120

# ── Budget Limits ────────────────────────
MAX_TOKENS_PER_KEY_PER_DAY=100000

# ── Legacy (existing OmniBot) ────────────
OMNIBOT_ENCRYPTION_KEY=OmniBotEncryptionKey

# Free Providers
# GitHub Models (free — use your GitHub Personal Access Token)
# Generate at: https://github.com/settings/tokens — select "models:read" scope
GITHUB_TOKEN_1=
GITHUB_TOKEN_2=

# Hugging Face (free — register at huggingface.co)
# Generate at: https://huggingface.co/settings/tokens
HF_KEY_1=
HF_KEY_2=

# Google AI Studio (free — 1B tokens/month)
# Generate at: https://aistudio.google.com/apikey
GOOGLE_AI_STUDIO_KEY_1=
GOOGLE_AI_STUDIO_KEY_2=

# NVIDIA NIM (free with developer program)
# Register at: https://build.nvidia.com
NVIDIA_NIM_KEY_1=

# Cerebras (free — fast inference, 900 req/day)
# Get key: cloud.cerebras.ai → API Keys
CEREBRAS_KEY_1=
CEREBRAS_KEY_2=

# Cloudflare Workers AI (free — 10,000 req/day)
# Get: dash.cloudflare.com → AI → API Tokens
# Account ID: dash.cloudflare.com → right sidebar
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_KEY_1=
CLOUDFLARE_KEY_2=

# LlamaCloud / LlamaIndex (free tier available)
# Get key: cloud.llamaindex.ai → API Keys
LLAMACLOUD_KEY_1=
LLAMACLOUD_KEY_2=

# ── Revenue Engine ───────────────────────
# PayPal.me link for payment collection (e.g. https://paypal.me/yourusername)
PAYPAL_ME_LINK=
# Default service price in USD
DEFAULT_SERVICE_PRICE=25
# Set to true to enable revenue mode
REVENUE_MODE=false

# ── Telegram Command Center ──────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
