# ═══════════════════════════════════════════
# OmniBot — Autonomous Agent Factory
# Environment Configuration
# ═══════════════════════════════════════════

# ── Model Provider Keys ──────────────────
# Support up to 8 keys per provider for rotation
OPENROUTER_KEY_1=
OPENROUTER_KEY_2=
OPENROUTER_KEY_3=
OPENROUTER_KEY_4=
OPENROUTER_KEY_5=
OPENROUTER_KEY_6=
OPENROUTER_KEY_7=
OPENROUTER_KEY_8=

GROQ_KEY_1=
GROQ_KEY_2=
GROQ_KEY_3=
GROQ_KEY_4=
GROQ_KEY_5=
GROQ_KEY_6=
GROQ_KEY_7=
GROQ_KEY_8=

GEMINI_KEY_1=
GEMINI_KEY_2=
GEMINI_KEY_3=
GEMINI_KEY_4=

ANTHROPIC_KEY=

# ── Local Models ─────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── Database ─────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=omnibot
CHROMA_HOST=localhost
CHROMA_PORT=8000

# ── Night Mode Schedule ──────────────────
NIGHT_MODE_START=00:00
NIGHT_MODE_END=07:00

# ── Concurrency Limits ───────────────────
MAX_CONCURRENT_AGENTS_DAY=5
MAX_CONCURRENT_AGENTS_NIGHT=2

# ── Evolution Settings ───────────────────
DEFAULT_EVOLVE_INTERVAL_SECONDS=120

# ── Budget Limits ────────────────────────
MAX_TOKENS_PER_KEY_PER_DAY=100000

# ── Legacy (existing OmniBot) ────────────
OMNIBOT_ENCRYPTION_KEY=OmniBotEncryptionKey

# Free Providers
# GitHub Models (free — use your GitHub Personal Access Token)
# Generate at: https://github.com/settings/tokens — select "models:read" scope
GITHUB_TOKEN_1=
GITHUB_TOKEN_2=

# Hugging Face (free — register at huggingface.co)
# Generate at: https://huggingface.co/settings/tokens
HF_KEY_1=
HF_KEY_2=

# Google AI Studio (free — 1B tokens/month)
# Generate at: https://aistudio.google.com/apikey
GOOGLE_AI_STUDIO_KEY_1=
GOOGLE_AI_STUDIO_KEY_2=

# NVIDIA NIM (free with developer program)
# Register at: https://build.nvidia.com
NVIDIA_NIM_KEY_1=

# Cerebras (free — fast inference, 900 req/day)
# Get key: cloud.cerebras.ai → API Keys
CEREBRAS_KEY_1=
CEREBRAS_KEY_2=

# Cloudflare Workers AI (free — 10,000 req/day)
# Get: dash.cloudflare.com → AI → API Tokens
# Account ID: dash.cloudflare.com → right sidebar
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_KEY_1=
CLOUDFLARE_KEY_2=

# LlamaCloud / LlamaIndex (free tier available)
# Get key: cloud.llamaindex.ai → API Keys
LLAMACLOUD_KEY_1=
LLAMACLOUD_KEY_2=

# ── Revenue Engine ───────────────────────
# PayPal.me link for payment collection (e.g. https://paypal.me/yourusername)
PAYPAL_ME_LINK=
# Default service price in USD
DEFAULT_SERVICE_PRICE=25
# Set to true to enable revenue mode
REVENUE_MODE=false

# ── Telegram Command Center ──────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Money Agent ──────────────────────────
# PayPal REST API credentials (developer.paypal.com → My Apps & Credentials)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_EMAIL=your-paypal-email@gmail.com
# Set PAYPAL_SANDBOX=false to switch from sandbox to live PayPal API
PAYPAL_SANDBOX=true
# Gmail address and App Password for sending/reading emails
# Generate App Password: myaccount.google.com → Security → App passwords
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
# Agent mode: human_in_loop | supervised | review_only
AGENT_MODE=human_in_loop

# ── Infinite Dev Loop Orchestrator ──────
ENABLE_DEV_LOOP=true
DEV_LOOP_INTERVAL_MINUTES=60

# ── Shopify Theme Factory ────────────────
# Unsplash API key for fetching royalty-free demo images
# Get free key at: unsplash.com/developers (50 req/hr on free plan)
# If not set, falls back to picsum.photos placeholders
UNSPLASH_ACCESS_KEY=
# Set to true to start the Shopify swarm automatically on backend boot
SHOPIFY_SWARM_AUTOSTART=false

# Active Shopify Store URL (e.g. yourstore.myshopify.com)
SHOPIFY_STORE_URL=
# Admin API Access Token (shpat_...)
SHOPIFY_ACCESS_TOKEN=
# Shopify API target version
SHOPIFY_API_VERSION=2025-01


# ── Self-Evolution Engine (Phase S) ──────
# Set to true to enable autonomous code improvement system
SELF_EVOLUTION_ENABLED=true
# How many hours between autonomous evolution cycles (default: 6)
EVOLUTION_INTERVAL_HOURS=6
# Max tokens to send to AI per evolution cycle (controls cost, default: 80000)
EVOLUTION_MAX_TOKENS=80000
# Max number of file patches per cycle (safety limit, default: 5)
EVOLUTION_MAX_PATCHES_PER_CYCLE=5
# Automatically rollback if verification fails (default: true)
EVOLUTION_ROLLBACK_ON_FAILURE=true

# ── HTTP Request Timeouts ────────────────
# Max seconds to wait for any HTTP request before returning 504
REQUEST_TIMEOUT_SECONDS=30.0

# ── CORS Configuration ───────────────────
# Comma-separated list of additional allowed origins (besides localhost:5173)
# Example: https://example.com,https://app.example.com
ALLOWED_ORIGINS=

# ── OmniBot Master Upgrade — WhatsApp Channel ──────────────────────
# Get API key at: https://whapi.cloud
WHATSAPP_API_KEY=

# ── OmniBot Master Upgrade — Discord Channel ──────────────────────
# Create bot at: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=

# ── OmniBot Master Upgrade — JWT Auth ─────────────────────────────
# Generate a random secret key for JWT token signing
AUTH_SECRET_KEY=

# ── OmniBot Master Upgrade — Redis ────────────────────────────────
# Redis connection string for rate limiter and job queues
REDIS_URL=redis://localhost:6379

# ── OmniBot Master Upgrade — Browser Agent ────────────────────────
# Set to true to run browser in headless mode
BROWSER_HEADLESS=true

# ── OmniBot Master Upgrade — Skill Sandbox ────────────────────────
# Set to true to enable Docker-based skill execution sandbox
SKILL_SANDBOX_ENABLED=true

